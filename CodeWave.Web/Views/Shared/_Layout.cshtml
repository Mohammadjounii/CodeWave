<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CodeWave.Web</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CodeWave.Web.styles.css" asp-append-version="true" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300..700&display=swap" rel="stylesheet" />

    <style>
        /* Glowing scrollbar — placed after Tailwind CDN so it always wins */
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: rgba(255,255,255,0.04); border-radius: 999px; }
        ::-webkit-scrollbar-thumb {
            background: #9b59f5;
            border-radius: 999px;
            box-shadow: 0 0 8px rgba(155,89,245,0.6), 0 0 16px rgba(155,89,245,0.3);
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #b07eff;
            box-shadow: 0 0 14px rgba(176,126,255,0.85), 0 0 28px rgba(155,89,245,0.5);
        }
        ::-webkit-scrollbar-corner { background: transparent; }
        /* Firefox */
        * { scrollbar-width: thin; scrollbar-color: #9b59f5 rgba(255,255,255,0.04); }
    </style>
</head>
<body>
   
    <div class="w-full">
        <main role="main" >
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2025 - CodeWave.Web - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@7.0.0/dist/browser/signalr.min.js"></script>
    <script src="~/js/signalr-client.js" asp-append-version="true"></script>
    <script src="~/js/validation-enhancements.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
