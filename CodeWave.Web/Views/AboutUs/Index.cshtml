@{
    ViewData["Title"] = "About Us";
}

<div class="min-h-screen bg-[#0d1117] text-[#f5e6c8] py-16 px-6 font-[Space Grotesk]">

    <!-- Title -->
    <div class="text-center mb-12">
        <h1 class="text-4xl font-bold mb-3 text-[#FFA500]">About CodeWave</h1>
        <p class="text-lg text-gray-300 max-w-2xl mx-auto">
            Empowering learners to master programming through interactive lessons, real code execution,
            progress tracking, quizzes, and career-ready tools.
        </p>
    </div>

    <!-- Mission + Vision -->
    <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-10">

        <!-- Mission -->
        <div class="bg-[#161b22] border border-[#1f2328] rounded-xl p-8 hover:border-[#FFA500] transition">
            <h2 class="text-2xl font-semibold text-[#FFA500] mb-3">Our Mission</h2>
            <p class="text-gray-300 leading-relaxed">
                Our mission is to provide an accessible and engaging platform where learners can
                fully understand programming languages like Python, Java, and Web Development
                through hands-on practice and guided learning paths.
            </p>
        </div>

        <!-- Vision -->
        <div class="bg-[#161b22] border border-[#1f2328] rounded-xl p-8 hover:border-[#FFA500] transition">
            <h2 class="text-2xl font-semibold text-[#FFA500] mb-3">Our Vision</h2>
            <p class="text-gray-300 leading-relaxed">
                We envision a world where anyone can become a developer regardless of background.
                CodeWave empowers users with structured knowledge, practical examples, and
                real-world exercises that lead to continuous growth and long-term success.
            </p>
        </div>
    </div>

    <!-- Platform Features -->
    <div class="max-w-5xl mx-auto mt-16">
        <h2 class="text-3xl text-[#FFA500] font-semibold mb-8 text-center">What CodeWave Offers</h2>

        <div class="grid md:grid-cols-3 gap-8">

            <div class="bg-[#161b22] border border-[#1f2328] rounded-xl p-6 hover:border-[#FFA500] transition">
                <h3 class="text-xl font-semibold mb-3 text-[#FFA500]">Interactive Courses</h3>
                <p class="text-gray-300">Learn Python, Java, and Web Development through structured, easy-to-follow tutorials.</p>
            </div>

            <div class="bg-[#161b22] border border-[#1f2328] rounded-xl p-6 hover:border-[#FFA500] transition">
                <h3 class="text-xl font-semibold mb-3 text-[#FFA500]">Real Code Execution</h3>
                <p class="text-gray-300">Run code examples directly inside the platform and learn through experimentation.</p>
            </div>

            <div class="bg-[#161b22] border border-[#1f2328] rounded-xl p-6 hover:border-[#FFA500] transition">
                <h3 class="text-xl font-semibold mb-3 text-[#FFA500]">Progress Tracking</h3>
                <p class="text-gray-300">Track your learning journey and see how much you’ve completed at any time.</p>
            </div>

            <div class="bg-[#161b22] border border-[#1f2328] rounded-xl p-6 hover:border-[#FFA500] transition">
                <h3 class="text-xl font-semibold mb-3 text-[#FFA500]">Quizzes & Assessments</h3>
                <p class="text-gray-300">Test your knowledge with interactive quizzes designed to reinforce learning.</p>
            </div>

            <div class="bg-[#161b22] border border-[#1f2328] rounded-xl p-6 hover:border-[#FFA500] transition">
                <h3 class="text-xl font-semibold mb-3 text-[#FFA500]">Auto-Generated CV</h3>
                <p class="text-gray-300">Your completed courses and achievements automatically build a professional CV.</p>
            </div>

            <div class="bg-[#161b22] border border-[#1f2328] rounded-xl p-6 hover:border-[#FFA500] transition">
                <h3 class="text-xl font-semibold mb-3 text-[#FFA500]">Job Opportunities</h3>
                <p class="text-gray-300">Access job listings that match your skill set and experience.</p>
            </div>

        </div>
    </div>

    <!-- Footer Section -->
    <div class="mt-20 text-center text-gray-400">
        <p>© 2025 CodeWave — Built to empower the next generation of developers.</p>
    </div>
</div>
