        // -------------------------
        // CODE SNIPPETS
        // -------------------------
        function toggleSnippets() {
            if (snippetsPanel) {
                snippetsPanel.classList.toggle("hidden");
            }
        }

        function loadCodeSnippets(language) {
            const snippetsList = document.getElementById("snippetsList");
            if (!snippetsList) return;

            const snippets = getSnippetsForLanguage(language);
            snippetsList.innerHTML = "";

            snippets.forEach(snippet => {
                const snippetCard = document.createElement("div");
                snippetCard.className = "p-3 rounded-lg bg-white/5 border border-white/10 hover:bg-white/10 cursor-pointer transition-all";
                snippetCard.innerHTML = `
                    <div class="flex items-start justify-between gap-2">
                        <div class="flex-1">
                            <p class="text-sm font-semibold text-white mb-1">${snippet.title}</p>
                            <p class="text-xs text-gray-400 mb-2">${snippet.description}</p>
                            <pre class="text-xs bg-black/50 p-2 rounded text-gray-300 overflow-x-auto"><code>${snippet.code}</code></pre>
                        </div>
                    </div>
                `;
                snippetCard.addEventListener("click", () => insertSnippet(snippet.code));
                snippetsList.appendChild(snippetCard);
            });
        }

        function getSnippetsForLanguage(language) {
            const lang = language?.toLowerCase() || "python";
            
            if (lang === "python") {
                return [
                    {
                        title: "For Loop",
                        description: "Iterate over a range",
                        code: "for i in range(10):\n    print(i)"
                    },
                    {
                        title: "List Comprehension",
                        description: "Create a list efficiently",
                        code: "[x * 2 for x in range(10)]"
                    },
                    {
                        title: "Function Definition",
                        description: "Define a function",
                        code: "def my_function(param):\n    return param"
                    },
                    {
                        title: "If-Else",
                        description: "Conditional statement",
                        code: "if condition:\n    # do something\nelse:\n    # do something else"
                    },
                    {
                        title: "Try-Except",
                        description: "Error handling",
                        code: "try:\n    # code\nexcept Exception as e:\n    print(e)"
                    }
                ];
            } else if (lang === "java") {
                return [
                    {
                        title: "For Loop",
                        description: "Iterate over a range",
                        code: "for (int i = 0; i < 10; i++) {\n    System.out.println(i);\n}"
                    },
                    {
                        title: "Method Definition",
                        description: "Define a method",
                        code: "public static void myMethod() {\n    // code\n}"
                    },
                    {
                        title: "If-Else",
                        description: "Conditional statement",
                        code: "if (condition) {\n    // code\n} else {\n    // code\n}"
                    },
                    {
                        title: "Class Definition",
                        description: "Define a class",
                        code: "public class MyClass {\n    // fields and methods\n}"
                    }
                ];
            }
            return [];
        }

        function insertSnippet(code) {
            if (!monacoEditor) return;
            const selection = monacoEditor.getSelection();
            const op = {
                range: selection,
                text: code + "\n",
                forceMoveMarkers: true
            };
            monacoEditor.executeEdits("insert-snippet", [op]);
            monacoEditor.focus();
        }

        // -------------------------
        // AUTO-SAVE CODE
        // -------------------------
        function startAutoSave() {
            if (autoSaveTimer) clearInterval(autoSaveTimer);
            
            autoSaveTimer = setInterval(() => {
                if (monacoEditor && currentExerciseId) {
                    const currentCode = monacoEditor.getValue();
                    if (currentCode !== lastSavedCode) {
                        saveCodeToLocalStorage();
                    }
                }
            }, 3000); // Save every 3 seconds
        }

        function saveCodeToLocalStorage() {
            if (!monacoEditor || !currentExerciseId) return;
            
            const code = monacoEditor.getValue();
            const key = `code_${currentExerciseId}`;
            localStorage.setItem(key, code);
            lastSavedCode = code;
            
            // Show save indicator
            if (autoSaveIndicator) {
                autoSaveIndicator.classList.remove("hidden");
                setTimeout(() => {
                    autoSaveIndicator.classList.add("hidden");
                }, 2000);
            }
        }

        function loadCodeFromLocalStorage() {
            if (!currentExerciseId) return "";
            
            const key = `code_${currentExerciseId}`;
            const savedCode = localStorage.getItem(key);
            if (savedCode) {
                lastSavedCode = savedCode;
                return savedCode;
            }
            return "";
        }
    </script>




</body>
</html>
