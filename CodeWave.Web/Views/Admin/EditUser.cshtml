@model CodeWave.Domain.Entities.ApplicationUser
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Edit User";
    ViewData["Subtitle"] = "Update user details, permissions, and learning profile.";

    var initials = (Model.FirstName?.Length > 0 ? Model.FirstName[0].ToString() : "") +
                   (Model.LastName?.Length > 0 ? Model.LastName[0].ToString() : "");
    if (string.IsNullOrWhiteSpace(initials)) initials = "?";

    var levelColor = Model.Level switch
    {
        "Beginner"     => "bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400",
        "Intermediate" => "bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400",
        "Advanced"     => "bg-purple-100 text-purple-700 dark:bg-purple-900/30 dark:text-purple-400",
        _              => "bg-slate-100 text-slate-600 dark:bg-slate-800 dark:text-slate-400"
    };
}

<!-- Breadcrumbs -->
<nav class="flex items-center gap-2 text-sm mb-6">
    <a class="text-slate-500 hover:text-primary transition-colors font-medium" asp-controller="Admin" asp-action="Index">Dashboard</a>
    <span class="material-symbols-outlined text-[16px] text-slate-400">chevron_right</span>
    <a class="text-slate-500 hover:text-primary transition-colors font-medium" asp-controller="Admin" asp-action="UserManagment">Users</a>
    <span class="material-symbols-outlined text-[16px] text-slate-400">chevron_right</span>
    <span class="text-primary font-medium">Edit User</span>
</nav>

<!-- Page Header -->
<div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
    <div>
        <h1 class="text-3xl font-black text-slate-900 dark:text-white tracking-tight">Edit User</h1>
        <p class="text-slate-500 dark:text-slate-400 mt-1">Update account details, permissions, and learning profile.</p>
    </div>
    <div class="flex gap-3">
        <a asp-controller="Admin" asp-action="UserDetails" asp-route-id="@Model.Id"
           class="flex items-center gap-2 px-4 h-10 bg-surface-light dark:bg-surface-dark border border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700 text-slate-700 dark:text-slate-300 text-sm font-semibold rounded-lg transition-all shadow-sm">
            <span class="material-symbols-outlined text-[18px]">visibility</span>
            View Profile
        </a>
        <a asp-controller="Admin" asp-action="UserManagment"
           class="flex items-center gap-2 px-4 h-10 bg-surface-light dark:bg-surface-dark border border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700 text-slate-700 dark:text-slate-300 text-sm font-semibold rounded-lg transition-all shadow-sm">
            <span class="material-symbols-outlined text-[18px]">arrow_back</span>
            Back to Users
        </a>
    </div>
</div>

@if (TempData["Error"] != null)
{
    <div class="mb-6 p-4 rounded-xl bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 text-red-700 dark:text-red-400 text-sm font-medium flex items-center gap-2">
        <span class="material-symbols-outlined text-[18px]">error</span>
        @TempData["Error"]
    </div>
}
@if (TempData["Success"] != null)
{
    <div class="mb-6 p-4 rounded-xl bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 text-green-700 dark:text-green-400 text-sm font-medium flex items-center gap-2">
        <span class="material-symbols-outlined text-[18px]">check_circle</span>
        @TempData["Success"]
    </div>
}

<div class="max-w-5xl mx-auto space-y-6">

    <!-- User Identity Card -->
    <div class="bg-surface-light dark:bg-surface-dark rounded-xl border border-gray-200 dark:border-gray-700 p-6 flex flex-col sm:flex-row items-start sm:items-center gap-5">
        <div class="flex-shrink-0 h-20 w-20 rounded-full bg-gradient-to-br from-primary to-purple-400 flex items-center justify-center text-white text-2xl font-bold shadow-lg shadow-primary/30">
            @if (!string.IsNullOrEmpty(Model.ProfilePictureUrl))
            {
                <img src="@Model.ProfilePictureUrl" class="h-20 w-20 rounded-full object-cover" alt="Profile picture" />
            }
            else
            {
                @initials.ToUpper()
            }
        </div>
        <div class="flex-1 min-w-0">
            <div class="flex flex-wrap items-center gap-2 mb-1">
                <h2 class="text-xl font-bold text-slate-900 dark:text-white">@(Model.FirstName + " " + Model.LastName)</h2>
                @if (Model.IsAdmin)
                {
                    <span class="px-2 py-0.5 rounded-full text-xs font-semibold bg-purple-100 text-purple-700 dark:bg-purple-900/30 dark:text-purple-400 border border-purple-200 dark:border-purple-800">Admin</span>
                }
                @if (!string.IsNullOrEmpty(Model.Level))
                {
                    <span class="px-2 py-0.5 rounded-full text-xs font-semibold @levelColor">@Model.Level</span>
                }
            </div>
            <p class="text-slate-500 dark:text-slate-400 text-sm truncate">@Model.Email</p>
            <p class="text-slate-400 dark:text-slate-500 text-xs mt-1">
                Learning Path: <span class="font-medium text-slate-600 dark:text-slate-300">@(Model.LearningPath ?? "Not assigned")</span>
            </p>
        </div>
    </div>

    <!-- Edit Form -->
    <form asp-controller="Admin" asp-action="CreateOrUpdateUser" method="post" class="space-y-6">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <!-- Personal Information -->
        <div class="bg-surface-light dark:bg-surface-dark rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-800 flex items-center gap-2">
                <span class="material-symbols-outlined text-primary text-[20px]">person</span>
                <h2 class="text-base font-semibold text-gray-900 dark:text-white">Personal Information</h2>
            </div>
            <div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-5">
                <div class="space-y-1.5">
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">First Name <span class="text-red-500">*</span></label>
                    <input asp-for="FirstName"
                           class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white px-4 py-2.5 focus:ring-2 focus:ring-primary/30 focus:border-primary outline-none transition-all text-sm placeholder:text-gray-400"
                           placeholder="First name" />
                </div>
                <div class="space-y-1.5">
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Last Name</label>
                    <input asp-for="LastName"
                           class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white px-4 py-2.5 focus:ring-2 focus:ring-primary/30 focus:border-primary outline-none transition-all text-sm placeholder:text-gray-400"
                           placeholder="Last name" />
                </div>
                <div class="space-y-1.5 md:col-span-2">
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Email Address <span class="text-red-500">*</span></label>
                    <input asp-for="Email" type="email"
                           class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white px-4 py-2.5 focus:ring-2 focus:ring-primary/30 focus:border-primary outline-none transition-all text-sm placeholder:text-gray-400"
                           placeholder="user@example.com" />
                    <p class="text-xs text-slate-400">Changing the email also updates the login username.</p>
                </div>
            </div>
        </div>

        <!-- Learning Profile -->
        <div class="bg-surface-light dark:bg-surface-dark rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-800 flex items-center gap-2">
                <span class="material-symbols-outlined text-primary text-[20px]">school</span>
                <h2 class="text-base font-semibold text-gray-900 dark:text-white">Learning Profile</h2>
            </div>
            <div class="p-6 space-y-6">
                <!-- Skill Level -->
                <div class="space-y-3">
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Skill Level</label>
                    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
                        @foreach (var level in new[] { ("Beginner", "clover_spark", "green"), ("Advanced", "terminal", "purple") })
                        {
                            var isSelected = Model.Level == level.Item1;
                            var iconColor = level.Item3 switch {
                                "green"  => "bg-green-100 text-green-600",
                                "blue"   => "bg-blue-100 text-blue-600",
                                "purple" => "bg-purple-100 text-purple-600",
                                _        => "bg-gray-100 text-gray-600"
                            };
                            <label class="relative cursor-pointer">
                                <input type="radio" name="Level" value="@level.Item1"
                                       class="peer sr-only" @(isSelected ? "checked" : "") />
                                <div class="p-4 rounded-xl border-2 border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-800 hover:border-primary/50 peer-checked:border-primary peer-checked:bg-primary/5 dark:peer-checked:bg-primary/10 transition-all cursor-pointer">
                                    <div class="flex items-center gap-3">
                                        <div class="size-8 rounded-full @iconColor flex items-center justify-center flex-shrink-0">
                                            <span class="material-symbols-outlined text-lg">@level.Item2</span>
                                        </div>
                                        <div>
                                            <p class="font-semibold text-gray-900 dark:text-white text-sm">@level.Item1</p>
                                        </div>
                                        <div class="ml-auto text-primary opacity-0 peer-checked:opacity-100 transition-opacity">
                                            <span class="material-symbols-outlined text-[18px]">check_circle</span>
                                        </div>
                                    </div>
                                </div>
                            </label>
                        }
                    </div>
                </div>

                <!-- Learning Path -->
                <div class="space-y-1.5">
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Learning Path</label>
                    <div class="relative">
                        <select asp-for="LearningPath"
                                class="w-full appearance-none rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white px-4 py-2.5 focus:ring-2 focus:ring-primary/30 focus:border-primary outline-none transition-all text-sm pr-10">
                            <option value="">— Not assigned —</option>
                            <option value="Python">Python Development</option>
                            <option value="Java">Java Development</option>
                            <option value="Web Development">Web Development</option>
                        </select>
                        <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-3 text-gray-400">
                            <span class="material-symbols-outlined text-xl">expand_more</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Admin Permissions -->
        <div class="bg-surface-light dark:bg-surface-dark rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-800 flex items-center gap-2">
                <span class="material-symbols-outlined text-primary text-[20px]">admin_panel_settings</span>
                <h2 class="text-base font-semibold text-gray-900 dark:text-white">Permissions</h2>
            </div>
            <div class="p-6">
                <label class="flex items-start gap-4 cursor-pointer group">
                    <div class="relative flex items-center mt-0.5">
                        <input type="checkbox" name="isAdmin" value="true"
                               class="peer sr-only" @(Model.IsAdmin ? "checked" : "") />
                        <div class="w-11 h-6 bg-gray-200 dark:bg-gray-700 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all dark:border-gray-600 peer-checked:bg-primary transition-colors"></div>
                    </div>
                    <div>
                        <p class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-primary transition-colors">Administrator Access</p>
                        <p class="text-xs text-slate-400 mt-0.5">Grants full access to the admin panel, user management, and course management.</p>
                    </div>
                </label>
            </div>
        </div>

        <!-- Password Change -->
        <div class="bg-surface-light dark:bg-surface-dark rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-800 flex items-center gap-2">
                <span class="material-symbols-outlined text-primary text-[20px]">lock</span>
                <h2 class="text-base font-semibold text-gray-900 dark:text-white">Change Password</h2>
                <span class="ml-auto text-xs text-slate-400 font-normal">Leave blank to keep current password</span>
            </div>
            <div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-5">
                <div class="space-y-1.5">
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">New Password</label>
                    <div class="relative">
                        <input name="password" id="editPassword" type="password"
                               class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white px-4 py-2.5 pr-10 focus:ring-2 focus:ring-primary/30 focus:border-primary outline-none transition-all text-sm placeholder:text-gray-400"
                               placeholder="Leave blank to keep current" autocomplete="new-password" />
                        <button type="button" onclick="togglePassword('editPassword', this)"
                                class="absolute inset-y-0 right-0 pr-3 flex items-center text-gray-400 hover:text-gray-600">
                            <span class="material-symbols-outlined text-[20px]">visibility</span>
                        </button>
                    </div>
                </div>
                <div class="space-y-1.5">
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Confirm New Password</label>
                    <div class="relative">
                        <input name="confirmPassword" id="editConfirmPassword" type="password"
                               class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white px-4 py-2.5 pr-10 focus:ring-2 focus:ring-primary/30 focus:border-primary outline-none transition-all text-sm placeholder:text-gray-400"
                               placeholder="Leave blank to keep current" autocomplete="new-password" />
                        <button type="button" onclick="togglePassword('editConfirmPassword', this)"
                                class="absolute inset-y-0 right-0 pr-3 flex items-center text-gray-400 hover:text-gray-600">
                            <span class="material-symbols-outlined text-[20px]">visibility</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Action Footer -->
        <div class="flex justify-end items-center gap-3 pt-2 pb-8">
            <a asp-controller="Admin" asp-action="UserManagment"
               class="px-6 py-2.5 rounded-lg border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 font-medium hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors text-sm">
                Cancel
            </a>
            <button type="submit"
                    class="px-6 py-2.5 rounded-lg bg-primary text-white font-semibold hover:bg-primary-dark shadow-md shadow-primary/20 transition-all flex items-center gap-2 text-sm">
                <span class="material-symbols-outlined text-[18px]">save</span>
                Save Changes
            </button>
        </div>
    </form>
</div>

<script>
function togglePassword(inputId, btn) {
    const input = document.getElementById(inputId);
    const icon = btn.querySelector('.material-symbols-outlined');
    if (input.type === 'password') {
        input.type = 'text';
        icon.textContent = 'visibility_off';
    } else {
        input.type = 'password';
        icon.textContent = 'visibility';
    }
}
</script>
