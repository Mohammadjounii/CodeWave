@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "User Details";
    ViewData["Subtitle"] = "View and manage user information, progress, and activity.";
}

@{
    var user = ViewBag.User as CodeWave.Domain.Entities.ApplicationUser;
    var completedLessons = ViewBag.CompletedLessons ?? 0;
    var completedExercises = ViewBag.CompletedExercises ?? 0;
    var quizAttempts = ViewBag.QuizAttempts ?? 0;
    var passedQuizzes = ViewBag.PassedQuizzes ?? 0;
}

@if (user == null)
{
    <div class="max-w-6xl mx-auto">
        <div class="bg-surface-light dark:bg-surface-dark rounded-xl border border-slate-200 dark:border-slate-800 p-8 text-center">
            <span class="material-symbols-outlined text-6xl text-slate-400 mb-4">person_off</span>
            <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-2">User Not Found</h2>
            <p class="text-slate-500 dark:text-slate-400 mb-6">The user you're looking for doesn't exist.</p>
            <a asp-controller="Admin" asp-action="UserManagment" class="inline-flex items-center gap-2 px-4 py-2 bg-primary text-white rounded-lg hover:bg-primary-dark transition-colors">
                <span class="material-symbols-outlined">arrow_back</span>
                Back to User Management
            </a>
        </div>
    </div>
}
else
{
<!-- Breadcrumbs -->
<div class="flex items-center gap-2 text-sm mb-6">
<a class="text-slate-500 hover:text-primary transition-colors font-medium" asp-controller="Admin" asp-action="Index">Dashboard</a>
<span class="material-symbols-outlined text-[16px] text-slate-400">chevron_right</span>
<a class="text-slate-500 hover:text-primary transition-colors font-medium" asp-controller="Admin" asp-action="UserManagment">Users</a>
<span class="material-symbols-outlined text-[16px] text-slate-400">chevron_right</span>
<span class="text-primary font-medium">User Details</span>
</div>

<div class="max-w-6xl mx-auto space-y-6">
<!-- Breadcrumbs & Actions Header -->
<div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
<div>
<div class="flex items-center gap-2 text-sm text-slate-500 dark:text-slate-400 mb-1">
<a asp-controller="Admin" asp-action="UserManagment" class="hover:text-primary transition-colors">Users</a>
<span class="material-symbols-outlined text-[16px]">chevron_right</span>
<span class="text-slate-900 dark:text-white font-medium">User Details</span>
</div>
<h1 class="text-3xl font-black text-slate-900 dark:text-white tracking-tight">@(user.FirstName + " " + user.LastName)</h1>
</div>
<div class="flex gap-3">
<a asp-controller="Admin" asp-action="CRUDUser" asp-route-id="@user.Id" class="flex items-center gap-2 px-4 h-10 bg-surface-light dark:bg-surface-dark border border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700 text-slate-900 dark:text-white text-sm font-bold rounded-lg transition-all shadow-sm">
<span class="material-symbols-outlined text-[20px]">edit</span>
                                Edit User
                            </a>
<form asp-controller="Admin" asp-action="DeleteUser" method="post" class="inline" onsubmit="return confirm('Are you sure you want to delete this user?');">
@Html.AntiForgeryToken()
<input type="hidden" name="userId" value="@user.Id" />
<button type="submit" class="flex items-center gap-2 px-4 h-10 bg-red-50 text-red-600 hover:bg-red-100 dark:bg-red-900/20 dark:text-red-400 dark:hover:bg-red-900/30 text-sm font-bold rounded-lg transition-all">
<span class="material-symbols-outlined text-[20px]">delete</span>
                                Delete
                            </button>
</form>
</div>
</div>
<!-- Main Grid -->
<div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
<!-- Left Sidebar: Profile Card -->
<div class="lg:col-span-4 space-y-6">
<!-- Main Profile Card -->
<div class="bg-surface-light dark:bg-surface-dark rounded-xl shadow-sm border border-slate-200 dark:border-slate-800 p-6 flex flex-col items-center text-center">
<div class="relative mb-4">
<div class="size-28 rounded-full bg-cover bg-center ring-4 ring-primary/10" data-alt="Portrait of Alex Chen" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuA4654_6Zru0Py9PXv7Jb7JDek2yMWvXcckb1BK44UUBwp8-K_cbRg2zF7P5e9Syk2F-xAb7XR5ib6AmqfCRQFThpyMgfQuKuWxaZuERR7aV0N4BdeezxMQtvB65T76G80LZ7Vimz2a9500220EXmU6bs8PKqCJHcnuKJDTTA7yhKks5jrODLbMMfgzQZe2zEyrKd0XgPofRnUHNnCzcfeuj78WwryQ_wZwPJygPkCDHe28Ffz3J7tKQgn75XutYKEueS9gLLJ_Crk');"></div>
<div class="absolute bottom-1 right-1 size-5 bg-green-500 rounded-full border-4 border-white dark:border-card-dark" title="Active"></div>
</div>
<h2 class="text-xl font-bold text-slate-900 dark:text-white">@(user.FirstName + " " + user.LastName)</h2>
<p class="text-slate-500 dark:text-slate-400 text-sm mb-3">@(user.Level ?? "Not Specified")</p>
<span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold bg-primary/10 text-primary mb-6">
                                    @(user.LearningPath ?? "Not Assigned")
                                </span>
<div class="w-full flex gap-2 mb-6">
<button class="flex-1 h-9 flex items-center justify-center gap-2 bg-primary hover:bg-primary-dark text-white text-sm font-medium rounded-lg transition-colors">
<span class="material-symbols-outlined text-[18px]">mail</span>
                                        Message
                                     </button>
<button class="size-9 flex items-center justify-center border border-gray-200 dark:border-gray-700 rounded-lg text-slate-500 dark:text-slate-400 hover:text-primary hover:border-primary transition-all" title="Reset Password">
<span class="material-symbols-outlined text-[20px]">lock_reset</span>
</button>
</div>
<div class="w-full border-t border-gray-100 dark:border-gray-800 pt-4 space-y-3 text-left">
<div class="flex items-center justify-between text-sm">
<span class="text-slate-500 dark:text-slate-400">Email</span>
<span class="text-slate-900 dark:text-gray-200 font-medium">@user.Email</span>
</div>
<div class="flex items-center justify-between text-sm">
<span class="text-slate-500 dark:text-slate-400">Admin Status</span>
<span class="text-slate-900 dark:text-gray-200 font-medium">@(user.IsAdmin ? "Admin" : "Regular User")</span>
</div>
<div class="flex items-center justify-between text-sm">
<span class="text-slate-500 dark:text-slate-400">Learning Path</span>
<span class="text-slate-900 dark:text-gray-200 font-medium">@(user.LearningPath ?? "Not Assigned")</span>
</div>
</div>
</div>
<!-- CV / Career Card -->
<div class="bg-surface-light dark:bg-surface-dark rounded-xl shadow-sm border border-slate-200 dark:border-slate-800 p-6">
<div class="flex items-center justify-between mb-4">
<h3 class="font-bold text-slate-900 dark:text-white">User Information</h3>
</div>
<div class="mb-4">
<p class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase mb-2">Admin Status</p>
<div class="flex items-center gap-2 text-sm font-medium @(user.IsAdmin ? "text-green-600 dark:text-green-400 bg-green-50 dark:bg-green-900/20" : "text-slate-600 dark:text-slate-400 bg-slate-50 dark:bg-slate-800/50") px-3 py-2 rounded-lg">
<span class="material-symbols-outlined text-[18px]">@(user.IsAdmin ? "admin_panel_settings" : "person")</span>
                                        @(user.IsAdmin ? "Administrator" : "Regular User")
                                    </div>
</div>
<div class="mb-6">
<p class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase mb-2">Account Details</p>
<div class="space-y-2 text-sm">
<div class="flex justify-between">
<span class="text-slate-500 dark:text-slate-400">Email:</span>
<span class="text-slate-900 dark:text-white font-medium">@user.Email</span>
</div>
<div class="flex justify-between">
<span class="text-slate-500 dark:text-slate-400">Level:</span>
<span class="text-slate-900 dark:text-white font-medium">@(user.Level ?? "Not Specified")</span>
</div>
<div class="flex justify-between">
<span class="text-slate-500 dark:text-slate-400">Learning Path:</span>
<span class="text-slate-900 dark:text-white font-medium">@(user.LearningPath ?? "Not Assigned")</span>
</div>
</div>
</div>
</div>
</div>
<!-- Right Column: Content -->
<div class="lg:col-span-8 space-y-6">
<!-- Stats Row -->
<div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
<div class="bg-surface-light dark:bg-surface-dark p-4 rounded-xl shadow-sm border border-slate-200 dark:border-slate-800 flex items-center gap-4">
<div class="size-12 rounded-lg bg-orange-100 dark:bg-orange-900/30 text-orange-600 dark:text-orange-400 flex items-center justify-center">
<span class="material-symbols-outlined">menu_book</span>
</div>
<div>
<p class="text-2xl font-black text-slate-900 dark:text-white">@completedLessons</p>
<p class="text-xs text-slate-500 dark:text-slate-400 font-medium">Completed Lessons</p>
</div>
</div>
<div class="bg-surface-light dark:bg-surface-dark p-4 rounded-xl shadow-sm border border-slate-200 dark:border-slate-800 flex items-center gap-4">
<div class="size-12 rounded-lg bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 flex items-center justify-center">
<span class="material-symbols-outlined">code</span>
</div>
<div>
<p class="text-2xl font-black text-slate-900 dark:text-white">@completedExercises</p>
<p class="text-xs text-slate-500 dark:text-slate-400 font-medium">Completed Exercises</p>
</div>
</div>
<div class="bg-surface-light dark:bg-surface-dark p-4 rounded-xl shadow-sm border border-slate-200 dark:border-slate-800 flex items-center gap-4">
<div class="size-12 rounded-lg bg-purple-100 dark:bg-purple-900/30 text-purple-600 dark:text-purple-400 flex items-center justify-center">
<span class="material-symbols-outlined">quiz</span>
</div>
<div>
<p class="text-2xl font-black text-slate-900 dark:text-white">@passedQuizzes/@quizAttempts</p>
<p class="text-xs text-slate-500 dark:text-slate-400 font-medium">Quizzes Passed</p>
</div>
</div>
</div>
<!-- Learning Path Progress -->
@{
    var userCourses = user.UserCourses?.Select(uc => uc.Course).ToList() ?? new List<CodeWave.Domain.Entities.Course>();
    var totalLessons = userCourses.SelectMany(c => c.Lessons ?? new List<CodeWave.Domain.Entities.Lesson>()).Count();
    var progressPercent = totalLessons > 0 ? (int)((completedLessons * 100.0) / totalLessons) : 0;
}
<div class="bg-surface-light dark:bg-surface-dark rounded-xl shadow-sm border border-slate-200 dark:border-slate-800 p-6">
<div class="flex items-center justify-between mb-4">
<div>
<h3 class="font-bold text-lg text-slate-900 dark:text-white">Current Learning Path</h3>
<p class="text-sm text-slate-500 dark:text-slate-400">@(user.LearningPath ?? "Not Assigned")</p>
</div>
<div class="text-right">
<span class="text-2xl font-black text-primary">@progressPercent%</span>
</div>
</div>
<div class="w-full bg-slate-100 dark:bg-slate-700 rounded-full h-3 mb-4 overflow-hidden">
<div class="bg-primary h-3 rounded-full transition-all duration-1000 ease-out" style="width: @progressPercent%"></div>
</div>
<div class="flex items-center justify-between text-sm">
<span class="text-slate-500 dark:text-slate-400">Progress: <strong class="text-slate-900 dark:text-white">@completedLessons of @totalLessons lessons completed</strong></span>
<a asp-controller="Admin" asp-action="UserManagment" class="text-primary font-bold hover:underline">Back to Users</a>
</div>
</div>
<!-- Course Breakdown -->
@if (userCourses.Any())
{
<div class="bg-surface-light dark:bg-surface-dark rounded-xl shadow-sm border border-slate-200 dark:border-slate-800 overflow-hidden">
<div class="px-6 py-4 border-b border-slate-200 dark:border-slate-800 flex justify-between items-center">
<h3 class="font-bold text-lg text-slate-900 dark:text-white">Course Progress</h3>
</div>
<div class="divide-y divide-slate-200 dark:divide-slate-800">
@foreach (var course in userCourses)
{
    var courseLessons = course.Lessons?.Count ?? 0;
    var userCompletedLessons = user.LessonCompletions?.Count(lc => lc.Lesson?.CourseId == course.Id) ?? 0;
    var courseProgress = courseLessons > 0 ? (int)((userCompletedLessons * 100.0) / courseLessons) : 0;
    var lastActivity = user.LessonCompletions?.Where(lc => lc.Lesson?.CourseId == course.Id && lc.CompletionDate.HasValue)
        .OrderByDescending(lc => lc.CompletionDate).FirstOrDefault()?.CompletionDate;
    
    <div class="p-4 hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors flex items-center gap-4">
    <div class="size-10 rounded-lg bg-primary/10 text-primary flex items-center justify-center flex-shrink-0">
    <span class="material-symbols-outlined">menu_book</span>
    </div>
    <div class="flex-1 min-w-0">
    <h4 class="font-bold text-sm text-slate-900 dark:text-white truncate">@course.Title</h4>
    <p class="text-xs text-slate-500 dark:text-slate-400">@(lastActivity.HasValue ? $"Last active: {lastActivity.Value:MMM dd, yyyy}" : "Not started")</p>
    </div>
    <div class="flex items-center gap-3">
    <div class="hidden sm:block w-32 bg-slate-100 dark:bg-slate-700 rounded-full h-2">
    <div class="bg-primary h-2 rounded-full" style="width: @courseProgress%"></div>
    </div>
    <span class="px-2 py-1 rounded text-xs font-bold @(courseProgress == 100 ? "bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400" : "bg-primary/10 text-primary")">@courseProgress%</span>
    </div>
    </div>
}
</div>
</div>
}
else
{
<div class="bg-surface-light dark:bg-surface-dark rounded-xl shadow-sm border border-slate-200 dark:border-slate-800 p-8 text-center">
<span class="material-symbols-outlined text-5xl text-slate-400 mb-4">school</span>
<h3 class="font-bold text-lg text-slate-900 dark:text-white mb-2">No Courses Enrolled</h3>
<p class="text-sm text-slate-500 dark:text-slate-400">This user hasn't enrolled in any courses yet.</p>
</div>
}
<!-- Quiz Performance -->
@if (quizAttempts > 0)
{
<div>
<div class="flex justify-between items-center mb-4">
<h3 class="font-bold text-lg text-slate-900 dark:text-white">Quiz Performance</h3>
</div>
<div class="bg-surface-light dark:bg-surface-dark rounded-xl shadow-sm border border-slate-200 dark:border-slate-800 p-6">
<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
<div class="p-4 bg-slate-50 dark:bg-slate-800/50 rounded-lg">
<p class="text-sm text-slate-500 dark:text-slate-400 mb-1">Total Attempts</p>
<p class="text-2xl font-bold text-slate-900 dark:text-white">@quizAttempts</p>
</div>
<div class="p-4 bg-slate-50 dark:bg-slate-800/50 rounded-lg">
<p class="text-sm text-slate-500 dark:text-slate-400 mb-1">Passed</p>
<p class="text-2xl font-bold text-green-600 dark:text-green-400">@passedQuizzes</p>
</div>
</div>
</div>
</div>
}
</div>
<!-- Close lg:col-span-8 -->
</div>
<!-- Close grid -->
</div>
<!-- Close max-w-6xl -->
}