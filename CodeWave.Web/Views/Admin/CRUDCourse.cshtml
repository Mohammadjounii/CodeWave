@model CodeWave.Web.Models.CourseWithLessonsViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = ViewBag.IsEdit == true ? "Edit Course" : "Create Course";
    ViewData["Subtitle"] = ViewBag.IsEdit == true ? "Update course details and content." : "Fill in the details below to create a new interactive coding course.";
}

<!-- Breadcrumbs -->
<div class="flex items-center gap-2 text-sm mb-6">
<a class="text-slate-500 hover:text-primary transition-colors font-medium" asp-controller="Admin" asp-action="Index">Dashboard</a>
<span class="material-symbols-outlined text-[16px] text-slate-400">chevron_right</span>
<a class="text-slate-500 hover:text-primary transition-colors font-medium" asp-controller="Admin" asp-action="CourseManagment">Courses</a>
<span class="material-symbols-outlined text-[16px] text-slate-400">chevron_right</span>
<span class="text-primary font-medium">@(ViewBag.IsEdit == true ? "Edit" : "Create New")</span>
</div>

<form asp-controller="Admin" asp-action="CreateOrUpdateCourse" method="post" class="max-w-[1200px] mx-auto w-full">
@Html.AntiForgeryToken()
<input type="hidden" asp-for="Id" />
<!-- Page Header -->
<div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4 mb-8">
<div class="flex flex-col gap-1">
<h1 class="text-3xl md:text-4xl font-black tracking-tight text-slate-900 dark:text-white">@(ViewBag.IsEdit == true ? "Edit Course" : "Create New Course")</h1>
<p class="text-gray-500 dark:text-gray-400 text-base">Fill in the details below to create a new interactive coding course.</p>
</div>
<div class="flex items-center gap-3 shrink-0">
<a asp-controller="Admin" asp-action="CourseManagment" class="h-10 px-5 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-slate-700 dark:text-gray-200 text-sm font-bold hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
                        Cancel
                    </a>
<button type="submit" class="h-10 px-6 rounded-lg bg-primary text-white text-sm font-bold shadow-md shadow-primary/30 hover:bg-primary/90 transition-all flex items-center gap-2">
<span class="material-symbols-outlined text-[20px]">save</span>
                        Save Course
                    </button>
</div>
</div>
<!-- Form Layout: Main Content (Left) + Sidebar (Right) -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
<!-- LEFT COLUMN: Main Course Content -->
<div class="lg:col-span-2 flex flex-col gap-6">
<!-- Basic Info Card -->
<div class="bg-white dark:bg-[#251b2e] rounded-xl border border-gray-200 dark:border-gray-800 p-6 shadow-sm">
<h2 class="text-lg font-bold mb-5 flex items-center gap-2">
<span class="material-symbols-outlined text-primary">edit_document</span>
                            Course Details
                        </h2>
<div class="flex flex-col gap-6">
<!-- Course Title -->
<label class="flex flex-col gap-2">
<span class="text-sm font-semibold text-slate-700 dark:text-gray-300">Course Title</span>
<input asp-for="Title" class="w-full h-12 px-4 rounded-lg bg-background-light dark:bg-background-dark border border-gray-300 dark:border-gray-700 focus:ring-2 focus:ring-primary/50 focus:border-primary text-base placeholder:text-gray-400 dark:text-white transition-all" placeholder="e.g., Advanced Python Programming" type="text"/>
<span asp-validation-for="Title" class="text-red-500 text-xs"></span>
</label>
<!-- Short Description -->
<label class="flex flex-col gap-2">
<span class="text-sm font-semibold text-slate-700 dark:text-gray-300">Short Summary</span>
<input class="w-full h-12 px-4 rounded-lg bg-background-light dark:bg-background-dark border border-gray-300 dark:border-gray-700 focus:ring-2 focus:ring-primary/50 focus:border-primary text-base placeholder:text-gray-400 dark:text-white transition-all" placeholder="Brief tagline for card previews (Max 120 chars)" type="text"/>
</label>
<!-- Full Description (Rich Text Placeholder) -->
<label class="flex flex-col gap-2">
<span class="text-sm font-semibold text-slate-700 dark:text-gray-300">Course Description</span>
<div class="w-full rounded-lg bg-background-light dark:bg-background-dark border border-gray-300 dark:border-gray-700 overflow-hidden focus-within:ring-2 focus-within:ring-primary/50 focus-within:border-primary transition-all">
<!-- Fake Toolbar -->
<div class="flex items-center gap-1 p-2 border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50">
<button class="p-1.5 rounded hover:bg-gray-200 dark:hover:bg-gray-700 text-gray-600 dark:text-gray-400"><span class="material-symbols-outlined text-[18px]">format_bold</span></button>
<button class="p-1.5 rounded hover:bg-gray-200 dark:hover:bg-gray-700 text-gray-600 dark:text-gray-400"><span class="material-symbols-outlined text-[18px]">format_italic</span></button>
<button class="p-1.5 rounded hover:bg-gray-200 dark:hover:bg-gray-700 text-gray-600 dark:text-gray-400"><span class="material-symbols-outlined text-[18px]">link</span></button>
<div class="w-px h-4 bg-gray-300 dark:bg-gray-600 mx-1"></div>
<button class="p-1.5 rounded hover:bg-gray-200 dark:hover:bg-gray-700 text-gray-600 dark:text-gray-400"><span class="material-symbols-outlined text-[18px]">list</span></button>
<button class="p-1.5 rounded hover:bg-gray-200 dark:hover:bg-gray-700 text-gray-600 dark:text-gray-400"><span class="material-symbols-outlined text-[18px]">code</span></button>
</div>
<textarea asp-for="Description" class="w-full p-4 bg-transparent border-none focus:ring-0 min-h-[200px] resize-y placeholder:text-gray-400 dark:text-white" placeholder="Enter a detailed description of the course content, objectives, and prerequisites..."></textarea>
<span asp-validation-for="Description" class="text-red-500 text-xs"></span>
</div>
</label>
</div>
</div>
<!-- Lessons Management Card -->
<div class="bg-white dark:bg-[#251b2e] rounded-xl border border-gray-200 dark:border-gray-800 p-6 shadow-sm">
<div class="flex items-center justify-between mb-5">
<h2 class="text-lg font-bold flex items-center gap-2">
<span class="material-symbols-outlined text-primary">library_books</span>
                                Lessons
                            </h2>
<button type="button" id="addLessonBtn" class="text-sm text-primary font-bold hover:underline flex items-center gap-1">
<span class="material-symbols-outlined text-[18px]">add</span>
                                Add Lesson
                            </button>
</div>
<!-- Lessons List -->
<div id="lessonsContainer" class="flex flex-col gap-3">
@if (Model.Lessons != null && Model.Lessons.Any())
{
    @for (int i = 0; i < Model.Lessons.Count; i++)
    {
        var lesson = Model.Lessons[i];
        <div class="lesson-item border border-gray-200 dark:border-gray-700 rounded-lg p-4 bg-gray-50 dark:bg-gray-800/30" data-lesson-index="@i">
            <input type="hidden" asp-for="Lessons[i].Id" />
            <input type="hidden" asp-for="Lessons[i].CourseId" />
            <input type="hidden" asp-for="Lessons[i].IsDeleted" class="lesson-deleted" />
            <input type="hidden" asp-for="Lessons[i].OrderNumber" class="lesson-order" />
            
            <div class="flex items-start justify-between mb-4">
                <div class="flex items-center gap-3 flex-1">
                    <span class="material-symbols-outlined text-gray-400 cursor-move lesson-drag-handle">drag_indicator</span>
                    <div class="flex-1">
                        <input asp-for="Lessons[i].Title" class="w-full h-10 px-3 rounded-lg bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 focus:ring-2 focus:ring-primary/50 focus:border-primary text-sm font-semibold text-slate-800 dark:text-gray-200" placeholder="Lesson Title" />
                        <span asp-validation-for="Lessons[i].Title" class="text-red-500 text-xs"></span>
                    </div>
                </div>
                <div class="flex items-center gap-2 ml-3">
                    <button type="button" class="toggle-lesson-details p-2 text-gray-400 hover:text-primary transition-colors" title="Toggle Details">
                        <span class="material-symbols-outlined text-[20px]">expand_more</span>
                    </button>
                    <button type="button" class="delete-lesson p-2 text-gray-400 hover:text-red-500 transition-colors" title="Delete Lesson">
                        <span class="material-symbols-outlined text-[20px]">delete</span>
                    </button>
                </div>
            </div>
            
            <div class="lesson-details hidden space-y-4">
                <div>
                    <label class="block text-xs font-semibold text-slate-700 dark:text-gray-300 mb-2">Content</label>
                    <textarea asp-for="Lessons[i].Content" class="w-full px-3 py-2 rounded-lg bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 focus:ring-2 focus:ring-primary/50 focus:border-primary text-sm min-h-[150px] resize-y dark:text-white" placeholder="Enter lesson content (HTML supported)"></textarea>
                    <span asp-validation-for="Lessons[i].Content" class="text-red-500 text-xs"></span>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs font-semibold text-slate-700 dark:text-gray-300 mb-2">Video URL (Optional)</label>
                        <input asp-for="Lessons[i].VideoUrl" class="w-full h-10 px-3 rounded-lg bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 focus:ring-2 focus:ring-primary/50 focus:border-primary text-sm dark:text-white" placeholder="https://..." />
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-slate-700 dark:text-gray-300 mb-2">Image URL (Optional)</label>
                        <input asp-for="Lessons[i].ImageUrl" class="w-full h-10 px-3 rounded-lg bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 focus:ring-2 focus:ring-primary/50 focus:border-primary text-sm dark:text-white" placeholder="https://..." />
                    </div>
                </div>
            </div>
        </div>
    }
}
</div>
<!-- Add New Lesson Placeholder -->
<div id="emptyLessonsMessage" class="@(Model.Lessons != null && Model.Lessons.Any() ? "hidden" : "") w-full py-8 border-2 border-dashed border-gray-300 dark:border-gray-700 rounded-lg text-center">
<p class="text-gray-500 dark:text-gray-400 text-sm mb-3">No lessons added yet</p>
<button type="button" id="addFirstLessonBtn" class="text-primary font-bold hover:underline flex items-center gap-1 mx-auto">
<span class="material-symbols-outlined text-[18px]">add_circle</span>
                                Add First Lesson
                            </button>
</div>
</div>
<!-- Materials Upload -->
<div class="bg-white dark:bg-[#251b2e] rounded-xl border border-gray-200 dark:border-gray-800 p-6 shadow-sm">
<h2 class="text-lg font-bold mb-5 flex items-center gap-2">
<span class="material-symbols-outlined text-primary">folder_zip</span>
                            Course Materials
                        </h2>
<div class="flex flex-col gap-4">
<div class="flex items-center justify-between p-4 rounded-lg bg-gray-50 dark:bg-gray-800/30 border border-gray-200 dark:border-gray-700">
<div class="flex items-center gap-3">
<div class="w-10 h-10 rounded bg-primary/10 flex items-center justify-center text-primary">
<span class="material-symbols-outlined">description</span>
</div>
<div>
<p class="text-sm font-semibold text-slate-800 dark:text-gray-200">Syllabus_2024.pdf</p>
<p class="text-xs text-gray-500">2.4 MB</p>
</div>
</div>
<button class="text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 p-2 rounded transition-colors">
<span class="material-symbols-outlined text-[20px]">close</span>
</button>
</div>
<button class="text-sm text-primary font-bold hover:underline flex items-center gap-1 self-start">
<span class="material-symbols-outlined text-[18px]">upload_file</span>
                                Upload File
                            </button>
</div>
</div>
</div>
<!-- RIGHT COLUMN: Metadata & Settings -->
<div class="flex flex-col gap-6">
<!-- Publishing Status -->
<div class="bg-white dark:bg-[#251b2e] rounded-xl border border-gray-200 dark:border-gray-800 p-6 shadow-sm">
<h2 class="text-lg font-bold mb-5 text-slate-900 dark:text-white">Publishing</h2>
<div class="flex items-center justify-between mb-6">
<span class="text-sm font-medium text-slate-700 dark:text-gray-300">Status</span>
<div class="flex items-center gap-2">
<span class="w-2.5 h-2.5 rounded-full bg-yellow-400"></span>
<span class="text-sm font-bold text-slate-800 dark:text-white">Draft</span>
</div>
</div>
<div class="flex flex-col gap-3">
<button class="w-full py-2.5 px-4 rounded-lg bg-primary/10 text-primary font-bold text-sm hover:bg-primary/20 transition-colors flex items-center justify-center gap-2">
<span class="material-symbols-outlined text-[18px]">visibility</span>
                                Preview Course
                            </button>
<button class="w-full py-2.5 px-4 rounded-lg border border-gray-300 dark:border-gray-600 text-slate-600 dark:text-gray-300 font-bold text-sm hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
                                Save as Draft
                            </button>
</div>
<div class="mt-6 pt-6 border-t border-gray-100 dark:border-gray-700">
<label class="flex items-center justify-between cursor-pointer group">
<span class="text-sm font-medium text-slate-700 dark:text-gray-300">Public Visibility</span>
<div class="relative">
<input class="sr-only peer" type="checkbox"/>
<div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-primary/50 rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
</div>
</label>
<p class="text-xs text-gray-400 mt-2">If disabled, the course will only be visible to admins.</p>
</div>
</div>
<!-- Course Attributes -->
<div class="bg-white dark:bg-[#251b2e] rounded-xl border border-gray-200 dark:border-gray-800 p-6 shadow-sm">
<h2 class="text-lg font-bold mb-5 text-slate-900 dark:text-white">Attributes</h2>
<!-- Learning Path -->
<div class="mb-5">
<label class="block text-sm font-semibold text-slate-700 dark:text-gray-300 mb-2">Learning Path</label>
<div class="relative">
<select asp-for="LearningPath" class="w-full h-11 pl-4 pr-10 rounded-lg bg-background-light dark:bg-background-dark border border-gray-300 dark:border-gray-700 focus:ring-2 focus:ring-primary/50 focus:border-primary text-sm appearance-none cursor-pointer dark:text-white">
<option value="">Select a path...</option>
<option value="Python">Python Development</option>
<option value="Java">Java Development</option>
<option value="Web Development">Web Development</option>
<option value="Data Science">Data Science</option>
<option value="Machine Learning">Machine Learning</option>
</select>
<span asp-validation-for="LearningPath" class="text-red-500 text-xs"></span>
<span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none text-gray-500 text-[20px]">expand_more</span>
</div>
</div>
<!-- Programming Language -->
<div class="mb-5">
<label class="block text-sm font-semibold text-slate-700 dark:text-gray-300 mb-2">Programming Language</label>
<div class="relative">
<select asp-for="ProgrammingLanguage" asp-items="Html.GetEnumSelectList<CodeWave.Domain.Entities.Language>()" class="w-full h-11 pl-4 pr-10 rounded-lg bg-background-light dark:bg-background-dark border border-gray-300 dark:border-gray-700 focus:ring-2 focus:ring-primary/50 focus:border-primary text-sm appearance-none cursor-pointer dark:text-white">
<option value="">Select language...</option>
</select>
<span asp-validation-for="ProgrammingLanguage" class="text-red-500 text-xs"></span>
<span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none text-gray-500 text-[20px]">expand_more</span>
</div>
</div>
<!-- Difficulty -->
<div class="mb-5">
<label class="block text-sm font-semibold text-slate-700 dark:text-gray-300 mb-2">Difficulty Level</label>
<div class="grid grid-cols-3 gap-2">
<label class="cursor-pointer">
<input asp-for="DifficultyLevel" value="Beginner" class="peer sr-only" type="radio" checked="@(Model.DifficultyLevel == "Beginner")"/>
<div class="h-10 flex items-center justify-center rounded-md border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50 text-xs font-medium text-gray-600 dark:text-gray-400 peer-checked:bg-primary/10 peer-checked:border-primary peer-checked:text-primary transition-all">
                                        Beginner
                                    </div>
</label>
<label class="cursor-pointer">
<input asp-for="DifficultyLevel" value="Intermediate" class="peer sr-only" type="radio" checked="@(Model.DifficultyLevel == "Intermediate")"/>
<div class="h-10 flex items-center justify-center rounded-md border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50 text-xs font-medium text-gray-600 dark:text-gray-400 peer-checked:bg-primary/10 peer-checked:border-primary peer-checked:text-primary transition-all">
                                        Intermed.
                                    </div>
</label>
<label class="cursor-pointer">
<input asp-for="DifficultyLevel" value="Advanced" class="peer sr-only" type="radio" checked="@(Model.DifficultyLevel == "Advanced")"/>
<div class="h-10 flex items-center justify-center rounded-md border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50 text-xs font-medium text-gray-600 dark:text-gray-400 peer-checked:bg-primary/10 peer-checked:border-primary peer-checked:text-primary transition-all">
                                        Advanced
                                    </div>
</label>
</div>
</div>
<!-- Duration -->
<div class="mb-2">
<label class="block text-sm font-semibold text-slate-700 dark:text-gray-300 mb-2">Est. Duration</label>
<div class="flex items-center gap-2">
<input class="flex-1 h-11 px-4 rounded-lg bg-background-light dark:bg-background-dark border border-gray-300 dark:border-gray-700 focus:ring-2 focus:ring-primary/50 focus:border-primary text-sm dark:text-white" type="number" value="12"/>
<div class="relative w-1/2">
<select class="w-full h-11 pl-3 pr-8 rounded-lg bg-background-light dark:bg-background-dark border border-gray-300 dark:border-gray-700 focus:ring-2 focus:ring-primary/50 focus:border-primary text-sm appearance-none cursor-pointer dark:text-white">
<option>Weeks</option>
<option>Hours</option>
<option>Days</option>
</select>
<span class="material-symbols-outlined absolute right-2 top-1/2 -translate-y-1/2 pointer-events-none text-gray-500 text-[18px]">expand_more</span>
</div>
</div>
</div>
</div>
<!-- Cover Image Upload -->
<div class="bg-white dark:bg-[#251b2e] rounded-xl border border-gray-200 dark:border-gray-800 p-6 shadow-sm">
<h2 class="text-lg font-bold mb-5 text-slate-900 dark:text-white">Course Cover</h2>
<div class="relative group w-full aspect-video rounded-lg overflow-hidden bg-gray-100 dark:bg-gray-800 border-2 border-dashed border-gray-300 dark:border-gray-600 hover:border-primary transition-all">
<!-- Image Preview -->
<div class="absolute inset-0 bg-cover bg-center" data-alt="Abstract code on a computer screen representing programming" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuAcdUZT9f4LEG8xbrYA9Ww3TSDlwtbUOjI9N_EXhZ6m1N7qkU1-TM6kvqCuFLxlG3CfZc55J1A9iYv5ArEmeFEJ_p5vKmBHSTZkwYlWJwig0ZLVdITA-puzZH3t0z8Vk6XyhPd1yZHfWKoKTuDfBPdPDMSjXj4fWrOKFLBnRSD8KRfgGKl9RNT6JCaxlY0rWy8aaLXxsU8bkSdkQsLPE8-KCnzPtNVfQqvLorw-nsAxrD9c_C-adiK-4I2oXd0IjSRw_JMr0Yf7jJE');"></div>
<!-- Overlay on hover -->
<div class="absolute inset-0 bg-black/60 flex flex-col items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity cursor-pointer">
<span class="material-symbols-outlined text-white text-4xl mb-2">cloud_upload</span>
<p class="text-white text-sm font-bold">Change Image</p>
<p class="text-gray-300 text-xs">Recommended: 1280x720px</p>
</div>
</div>
</div>
<!-- Tags -->
<div class="bg-white dark:bg-[#251b2e] rounded-xl border border-gray-200 dark:border-gray-800 p-6 shadow-sm">
<h2 class="text-lg font-bold mb-5 text-slate-900 dark:text-white">Tags</h2>
<div class="flex flex-wrap gap-2 mb-3">
<span class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-primary/10 text-primary text-xs font-bold">
                                #Python
                                <button class="hover:text-red-500"><span class="material-symbols-outlined text-[14px]">close</span></button>
</span>
<span class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-primary/10 text-primary text-xs font-bold">
                                #Backend
                                <button class="hover:text-red-500"><span class="material-symbols-outlined text-[14px]">close</span></button>
</span>
</div>
<input class="w-full h-10 px-3 rounded-lg bg-background-light dark:bg-background-dark border border-gray-300 dark:border-gray-700 focus:ring-2 focus:ring-primary/50 focus:border-primary text-sm dark:text-white" placeholder="Add tag + Enter" type="text"/>
</div>
</div>
</div>
</div>
</form>

@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', function() {
    let lessonIndex = @(Model.Lessons?.Count ?? 0);
    const container = document.getElementById('lessonsContainer');
    const emptyMessage = document.getElementById('emptyLessonsMessage');
    
    // Template for new lesson
    function createLessonHtml(index) {
        return `
            <div class="lesson-item border border-gray-200 dark:border-gray-700 rounded-lg p-4 bg-gray-50 dark:bg-gray-800/30" data-lesson-index="${index}">
                <input type="hidden" name="Lessons[${index}].Id" value="00000000-0000-0000-0000-000000000000" />
                <input type="hidden" name="Lessons[${index}].CourseId" value="@Model.Id" />
                <input type="hidden" name="Lessons[${index}].IsDeleted" class="lesson-deleted" value="false" />
                <input type="hidden" name="Lessons[${index}].OrderNumber" class="lesson-order" value="${index + 1}" />
                
                <div class="flex items-start justify-between mb-4">
                    <div class="flex items-center gap-3 flex-1">
                        <span class="material-symbols-outlined text-gray-400 cursor-move lesson-drag-handle">drag_indicator</span>
                        <div class="flex-1">
                            <input name="Lessons[${index}].Title" class="w-full h-10 px-3 rounded-lg bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 focus:ring-2 focus:ring-primary/50 focus:border-primary text-sm font-semibold text-slate-800 dark:text-gray-200" placeholder="Lesson Title" required />
                        </div>
                    </div>
                    <div class="flex items-center gap-2 ml-3">
                        <button type="button" class="toggle-lesson-details p-2 text-gray-400 hover:text-primary transition-colors" title="Toggle Details">
                            <span class="material-symbols-outlined text-[20px]">expand_more</span>
                        </button>
                        <button type="button" class="delete-lesson p-2 text-gray-400 hover:text-red-500 transition-colors" title="Delete Lesson">
                            <span class="material-symbols-outlined text-[20px]">delete</span>
                        </button>
                    </div>
                </div>
                
                <div class="lesson-details hidden space-y-4">
                    <div>
                        <label class="block text-xs font-semibold text-slate-700 dark:text-gray-300 mb-2">Content</label>
                        <textarea name="Lessons[${index}].Content" class="w-full px-3 py-2 rounded-lg bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 focus:ring-2 focus:ring-primary/50 focus:border-primary text-sm min-h-[150px] resize-y dark:text-white" placeholder="Enter lesson content (HTML supported)" required></textarea>
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-semibold text-slate-700 dark:text-gray-300 mb-2">Video URL (Optional)</label>
                            <input name="Lessons[${index}].VideoUrl" class="w-full h-10 px-3 rounded-lg bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 focus:ring-2 focus:ring-primary/50 focus:border-primary text-sm dark:text-white" placeholder="https://..." />
                        </div>
                        <div>
                            <label class="block text-xs font-semibold text-slate-700 dark:text-gray-300 mb-2">Image URL (Optional)</label>
                            <input name="Lessons[${index}].ImageUrl" class="w-full h-10 px-3 rounded-lg bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 focus:ring-2 focus:ring-primary/50 focus:border-primary text-sm dark:text-white" placeholder="https://..." />
                        </div>
                    </div>
                </div>
            </div>
        `;
    }
    
    // Add new lesson
    function addLesson() {
        const lessonHtml = createLessonHtml(lessonIndex);
        const tempDiv = document.createElement('div');
        tempDiv.innerHTML = lessonHtml;
        const lessonElement = tempDiv.firstElementChild;
        
        container.appendChild(lessonElement);
        if (emptyMessage) emptyMessage.classList.add('hidden');
        
        // Attach event listeners
        attachLessonListeners(lessonElement);
        
        // Update order numbers
        updateOrderNumbers();
        
        lessonIndex++;
        
        // Scroll to new lesson
        lessonElement.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
    
    // Delete lesson
    function deleteLesson(button) {
        const lessonItem = button.closest('.lesson-item');
        const deletedInput = lessonItem.querySelector('.lesson-deleted');
        const lessonId = lessonItem.querySelector('input[name*=".Id"]').value;
        
        // If it's an existing lesson (not a new one), mark as deleted
        if (lessonId && lessonId !== '00000000-0000-0000-0000-000000000000') {
            deletedInput.value = 'true';
            lessonItem.style.display = 'none';
        } else {
            // Remove new lesson completely
            lessonItem.remove();
        }
        
        updateOrderNumbers();
        
        // Show empty message if no visible lessons
        const visibleLessons = container.querySelectorAll('.lesson-item:not([style*="display: none"])');
        if (visibleLessons.length === 0 && emptyMessage) {
            emptyMessage.classList.remove('hidden');
        }
    }
    
    // Toggle lesson details
    function toggleLessonDetails(button) {
        const lessonItem = button.closest('.lesson-item');
        const details = lessonItem.querySelector('.lesson-details');
        const icon = button.querySelector('.material-symbols-outlined');
        
        details.classList.toggle('hidden');
        icon.textContent = details.classList.contains('hidden') ? 'expand_more' : 'expand_less';
    }
    
    // Update order numbers
    function updateOrderNumbers() {
        const lessons = container.querySelectorAll('.lesson-item:not([style*="display: none"])');
        lessons.forEach((lesson, index) => {
            const orderInput = lesson.querySelector('.lesson-order');
            if (orderInput) {
                orderInput.value = index + 1;
            }
        });
    }
    
    // Attach event listeners to a lesson element
    function attachLessonListeners(lessonElement) {
        const deleteBtn = lessonElement.querySelector('.delete-lesson');
        const toggleBtn = lessonElement.querySelector('.toggle-lesson-details');
        
        if (deleteBtn) {
            deleteBtn.addEventListener('click', () => deleteLesson(deleteBtn));
        }
        
        if (toggleBtn) {
            toggleBtn.addEventListener('click', () => toggleLessonDetails(toggleBtn));
        }
    }
    
    // Attach listeners to existing lessons
    container.querySelectorAll('.lesson-item').forEach(attachLessonListeners);
    
    // Add lesson buttons
    const addLessonBtn = document.getElementById('addLessonBtn');
    const addFirstLessonBtn = document.getElementById('addFirstLessonBtn');
    
    if (addLessonBtn) {
        addLessonBtn.addEventListener('click', addLesson);
    }
    
    if (addFirstLessonBtn) {
        addFirstLessonBtn.addEventListener('click', addLesson);
    }
});
</script>
}