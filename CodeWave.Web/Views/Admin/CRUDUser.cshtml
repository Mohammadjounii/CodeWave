@model CodeWave.Domain.Entities.ApplicationUser
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = ViewBag.IsEdit == true ? "Edit User" : "Create User";
    ViewData["Subtitle"] = ViewBag.IsEdit == true ? "Update user details and permissions." : "Add a new student, mentor, or administrator to the platform.";
}

<!-- Breadcrumbs -->
<nav aria-label="Breadcrumb" class="flex mb-6">
<ol class="inline-flex items-center space-x-1 md:space-x-2 rtl:space-x-reverse">
<li class="inline-flex items-center">
<a class="inline-flex items-center text-sm font-medium text-slate-500 hover:text-primary dark:text-slate-400 dark:hover:text-white" asp-controller="Admin" asp-action="Index">Dashboard</a>
</li>
<li>
<div class="flex items-center">
<span class="material-symbols-outlined text-slate-400 text-lg mx-1">chevron_right</span>
<a class="text-sm font-medium text-slate-500 hover:text-primary dark:text-slate-400 dark:hover:text-white" asp-controller="Admin" asp-action="UserManagment">Users</a>
</div>
</li>
<li aria-current="page">
<div class="flex items-center">
<span class="material-symbols-outlined text-slate-400 text-lg mx-1">chevron_right</span>
<span class="text-sm font-medium text-slate-900 dark:text-white">@(ViewBag.IsEdit == true ? "Edit User" : "Create New User")</span>
</div>
</li>
</ol>
</nav>
<!-- Page Header -->
<div class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-8">
<div>
<h1 class="text-3xl font-bold tracking-tight text-slate-900 dark:text-white mb-2">@(ViewBag.IsEdit == true ? "Edit User" : "Create New User")</h1>
<p class="text-slate-500 dark:text-gray-400">@(ViewBag.IsEdit == true ? "Update user details and permissions." : "Add a new student, mentor, or administrator to the platform.")</p>
</div>
<div class="flex gap-3">
<button class="px-4 py-2 rounded-lg border border-slate-300 dark:border-slate-600 text-slate-700 dark:text-slate-300 bg-white dark:bg-surface-dark hover:bg-gray-50 dark:hover:bg-gray-700 font-medium text-sm transition-colors">
Import CSV
</button>
</div>
</div>
<div class="max-w-5xl mx-auto">
<!-- Main Form Card -->
<form asp-controller="Admin" asp-action="CreateOrUpdateUser" method="post" class="bg-surface-light dark:bg-surface-dark rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
@Html.AntiForgeryToken()
<input type="hidden" asp-for="Id" />
<!-- Section: Personal Info -->
<div class="p-6 md:p-8 border-b border-gray-100 dark:border-gray-800">
<h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-6 flex items-center gap-2">
<span class="material-symbols-outlined text-primary">person</span>
                                Personal Information
                            </h2>
<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
<div class="space-y-1.5">
<label class="block text-sm font-medium text-gray-700 dark:text-gray-300" for="firstName">First Name</label>
<input asp-for="FirstName" class="w-full rounded-lg border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-800/50 text-gray-900 dark:text-white px-4 py-2.5 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all placeholder:text-gray-400" placeholder="First Name" type="text"/>
<span asp-validation-for="FirstName" class="text-red-500 text-xs"></span>
</div>
<div class="space-y-1.5">
<label class="block text-sm font-medium text-gray-700 dark:text-gray-300" for="lastName">Last Name</label>
<input asp-for="LastName" class="w-full rounded-lg border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-800/50 text-gray-900 dark:text-white px-4 py-2.5 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all placeholder:text-gray-400" placeholder="Last Name" type="text"/>
<span asp-validation-for="LastName" class="text-red-500 text-xs"></span>
</div>
<div class="space-y-1.5">
<label class="block text-sm font-medium text-gray-700 dark:text-gray-300" for="email">Email Address</label>
<input asp-for="Email" class="w-full rounded-lg border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-800/50 text-gray-900 dark:text-white px-4 py-2.5 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all placeholder:text-gray-400" placeholder="e.g. jane@codewave.com" type="email"/>
<span asp-validation-for="Email" class="text-red-500 text-xs"></span>
</div>
<div class="space-y-1.5">
<label class="block text-sm font-medium text-gray-700 dark:text-gray-300" for="isAdmin">Is Admin</label>
<div class="flex items-center gap-2">
<input type="checkbox" name="isAdmin" value="true" class="rounded border-gray-300 text-primary focus:ring-primary" checked="@Model.IsAdmin"/>
<label class="text-sm text-gray-600 dark:text-gray-400">Grant admin privileges</label>
</div>
</div>
<div class="space-y-1.5">
<label class="block text-sm font-medium text-gray-700 dark:text-gray-300" for="phone">Phone Number <span class="text-gray-400 font-normal">(Optional)</span></label>
<input class="w-full rounded-lg border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-800/50 text-gray-900 dark:text-white px-4 py-2.5 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all placeholder:text-gray-400" id="phone" placeholder="+1 (555) 000-0000" type="tel"/>
</div>
</div>
</div>
<!-- Section: Learning Profile -->
<div class="p-6 md:p-8 border-b border-gray-100 dark:border-gray-800 bg-gray-50/50 dark:bg-gray-800/20">
<h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-6 flex items-center gap-2">
<span class="material-symbols-outlined text-primary">school</span>
                                Learning Profile
                            </h2>
<div class="space-y-6">
<!-- Skill Level Selection -->
<div class="space-y-3">
<label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Initial Skill Level</label>
<div class="grid grid-cols-1 md:grid-cols-3 gap-4">
<!-- Beginner Option -->
<label class="relative cursor-pointer group">
<input asp-for="Level" value="Beginner" class="peer sr-only" type="radio" checked="@(Model.Level == "Beginner")"/>
<div class="p-4 rounded-xl border-2 border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-800 hover:border-primary/50 peer-checked:border-primary peer-checked:bg-primary/5 transition-all h-full">
<div class="flex flex-col gap-2">
<div class="size-8 rounded-full bg-green-100 text-green-600 flex items-center justify-center">
<span class="material-symbols-outlined text-lg">clover_spark</span>
</div>
<div>
<p class="font-semibold text-gray-900 dark:text-white">Beginner</p>
<p class="text-xs text-gray-500 mt-1">New to coding concepts.</p>
</div>
</div>
<div class="absolute top-4 right-4 text-primary opacity-0 peer-checked:opacity-100 transition-opacity">
<span class="material-symbols-outlined filled">check_circle</span>
</div>
</div>
</label>
<!-- Intermediate Option -->
<label class="relative cursor-pointer group">
<input asp-for="Level" value="Intermediate" class="peer sr-only" type="radio" checked="@(Model.Level == "Intermediate")"/>
<div class="p-4 rounded-xl border-2 border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-800 hover:border-primary/50 peer-checked:border-primary peer-checked:bg-primary/5 transition-all h-full">
<div class="flex flex-col gap-2">
<div class="size-8 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center">
<span class="material-symbols-outlined text-lg">code</span>
</div>
<div>
<p class="font-semibold text-gray-900 dark:text-white">Intermediate</p>
<p class="text-xs text-gray-500 mt-1">Familiar with syntax &amp; logic.</p>
</div>
</div>
<div class="absolute top-4 right-4 text-primary opacity-0 peer-checked:opacity-100 transition-opacity">
<span class="material-symbols-outlined filled">check_circle</span>
</div>
</div>
</label>
<!-- Advanced Option -->
<label class="relative cursor-pointer group">
<input asp-for="Level" value="Advanced" class="peer sr-only" type="radio" checked="@(Model.Level == "Advanced")"/>
<div class="p-4 rounded-xl border-2 border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-800 hover:border-primary/50 peer-checked:border-primary peer-checked:bg-primary/5 transition-all h-full">
<div class="flex flex-col gap-2">
<div class="size-8 rounded-full bg-purple-100 text-purple-600 flex items-center justify-center">
<span class="material-symbols-outlined text-lg">terminal</span>
</div>
<div>
<p class="font-semibold text-gray-900 dark:text-white">Advanced</p>
<p class="text-xs text-gray-500 mt-1">Experienced developer.</p>
</div>
</div>
<div class="absolute top-4 right-4 text-primary opacity-0 peer-checked:opacity-100 transition-opacity">
<span class="material-symbols-outlined filled">check_circle</span>
</div>
</div>
</label>
</div>
</div>
<!-- Learning Path Select -->
<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
<div class="space-y-1.5">
<label class="block text-sm font-medium text-gray-700 dark:text-gray-300" for="learning_path">Assigned Learning Path</label>
<div class="relative">
<select asp-for="LearningPath" class="w-full appearance-none rounded-lg border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white px-4 py-2.5 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all pr-10" id="learning_path">
<option value="">Select a path...</option>
<option value="Python">Python Development</option>
<option value="Java">Java Development</option>
<option value="Web Development">Web Development</option>
<option value="Data Science">Data Science & Machine Learning</option>
</select>
<span asp-validation-for="LearningPath" class="text-red-500 text-xs"></span>
<div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-gray-500">
<span class="material-symbols-outlined text-xl">expand_more</span>
</div>
</div>
<p class="text-xs text-gray-500 mt-1">Based on the user's career goals and skill assessment.</p>
</div>
<!-- Feature Toggles -->
<div class="space-y-3 pt-2">
<label class="flex items-center gap-3 cursor-pointer group">
<div class="relative flex items-center">
<input class="peer sr-only" type="checkbox"/>
<div class="w-11 h-6 bg-gray-200 peer-focus:outline-none rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all dark:border-gray-600 peer-checked:bg-primary"></div>
</div>
<span class="text-sm font-medium text-gray-700 dark:text-gray-300 group-hover:text-gray-900 dark:group-hover:text-white">Enable Automated CV Updates</span>
</label>
<label class="flex items-center gap-3 cursor-pointer group">
<div class="relative flex items-center">
<input checked="" class="peer sr-only" type="checkbox"/>
<div class="w-11 h-6 bg-gray-200 peer-focus:outline-none rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all dark:border-gray-600 peer-checked:bg-primary"></div>
</div>
<span class="text-sm font-medium text-gray-700 dark:text-gray-300 group-hover:text-gray-900 dark:group-hover:text-white">Grant Job Board Access</span>
</label>
</div>
</div>
</div>
</div>
<!-- Section: Security -->
<div class="p-6 md:p-8">
<h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-6 flex items-center gap-2">
<span class="material-symbols-outlined text-primary">lock</span>
                                Security
                            </h2>
<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
<div class="space-y-1.5">
<label class="block text-sm font-medium text-gray-700 dark:text-gray-300" for="password">Password</label>
<div class="relative">
<input name="password" class="w-full rounded-lg border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-800/50 text-gray-900 dark:text-white px-4 py-2.5 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all placeholder:text-gray-400" id="password" placeholder="••••••••" type="password"/>
<button class="absolute inset-y-0 right-0 pr-3 flex items-center text-gray-400 hover:text-gray-600 cursor-pointer" type="button">
<span class="material-symbols-outlined text-[20px]">visibility</span>
</button>
</div>
</div>
<div class="space-y-1.5">
<label class="block text-sm font-medium text-gray-700 dark:text-gray-300" for="confirm_password">Confirm Password</label>
<div class="relative">
<input name="confirmPassword" class="w-full rounded-lg border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-800/50 text-gray-900 dark:text-white px-4 py-2.5 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all placeholder:text-gray-400" id="confirm_password" placeholder="••••••••" type="password"/>
<button class="absolute inset-y-0 right-0 pr-3 flex items-center text-gray-400 hover:text-gray-600 cursor-pointer" type="button">
<span class="material-symbols-outlined text-[20px]">visibility</span>
</button>
</div>
</div>
</div>
<div class="mt-4 flex items-center gap-2">
<input class="rounded border-gray-300 text-primary focus:ring-primary" id="send_email" type="checkbox"/>
<label class="text-sm text-gray-600 dark:text-gray-400" for="send_email">Send email invitation with temporary password</label>
</div>
</div>
<!-- Action Footer -->
<div class="px-6 py-4 md:px-8 md:py-6 bg-gray-50 dark:bg-gray-800/50 border-t border-gray-200 dark:border-gray-700 flex justify-end items-center gap-3">
<button class="px-6 py-2.5 rounded-lg border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 font-medium hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors" type="button">
                                Cancel
                            </button>
<button class="px-6 py-2.5 rounded-lg bg-primary text-white font-medium hover:bg-primary/90 shadow-md shadow-primary/20 transition-all flex items-center gap-2" type="submit">
<span class="material-symbols-outlined text-lg">save</span>
                                Save User
                            </button>
</div>
</form>
</div>
</div>