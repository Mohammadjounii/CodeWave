@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Overview";
    ViewData["Subtitle"] = "Welcome back, here's what's happening today.";
}

<div class="flex flex-col gap-6 max-w-[1400px] mx-auto">
<!-- KPI Cards -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
<!-- Card 1 -->
<div class="flex flex-col p-5 rounded-xl border border-border-light dark:border-border-dark bg-surface-light dark:bg-surface-dark shadow-sm hover:shadow-md transition-shadow">
<div class="flex items-center justify-between mb-4">
<div class="p-2 rounded-lg bg-blue-100 text-blue-600 dark:bg-blue-900/30 dark:text-blue-400">
<span class="material-symbols-outlined" style="font-size: 24px;">school</span>
</div>
<span class="flex items-center gap-1 text-xs font-medium text-green-600 bg-green-100 dark:bg-green-900/30 dark:text-green-400 px-2 py-1 rounded-full">
<span class="material-symbols-outlined" style="font-size: 14px;">trending_up</span> 12%
                                </span>
</div>
<p class="text-text-sub-light dark:text-text-sub-dark text-sm font-medium">Total Learners</p>
<h3 class="text-2xl font-bold text-text-main-light dark:text-text-main-dark mt-1">@ViewBag.TotalUsers</h3>
<p class="text-xs text-text-sub-light dark:text-text-sub-dark mt-2">Registered users</p>
</div>
<!-- Card 2 -->
<div class="flex flex-col p-5 rounded-xl border border-border-light dark:border-border-dark bg-surface-light dark:bg-surface-dark shadow-sm hover:shadow-md transition-shadow">
<div class="flex items-center justify-between mb-4">
<div class="p-2 rounded-lg bg-purple-100 text-purple-600 dark:bg-purple-900/30 dark:text-purple-400">
<span class="material-symbols-outlined" style="font-size: 24px;">book_2</span>
</div>
<span class="flex items-center gap-1 text-xs font-medium text-green-600 bg-green-100 dark:bg-green-900/30 dark:text-green-400 px-2 py-1 rounded-full">
<span class="material-symbols-outlined" style="font-size: 14px;">trending_up</span> 5%
                                </span>
</div>
<p class="text-text-sub-light dark:text-text-sub-dark text-sm font-medium">Active Courses</p>
<h3 class="text-2xl font-bold text-text-main-light dark:text-text-main-dark mt-1">@ViewBag.TotalCourses</h3>
<p class="text-xs text-text-sub-light dark:text-text-sub-dark mt-2">Available courses</p>
</div>
<!-- Card 3 -->
<div class="flex flex-col p-5 rounded-xl border border-border-light dark:border-border-dark bg-surface-light dark:bg-surface-dark shadow-sm hover:shadow-md transition-shadow">
<div class="flex items-center justify-between mb-4">
<div class="p-2 rounded-lg bg-orange-100 text-orange-600 dark:bg-orange-900/30 dark:text-orange-400">
<span class="material-symbols-outlined" style="font-size: 24px;">business_center</span>
</div>
<span class="flex items-center gap-1 text-xs font-medium text-green-600 bg-green-100 dark:bg-green-900/30 dark:text-green-400 px-2 py-1 rounded-full">
<span class="material-symbols-outlined" style="font-size: 14px;">trending_up</span> 8%
                                </span>
</div>
<p class="text-text-sub-light dark:text-text-sub-dark text-sm font-medium">Job Placements</p>
<h3 class="text-2xl font-bold text-text-main-light dark:text-text-main-dark mt-1">@ViewBag.TotalJobOffers</h3>
<p class="text-xs text-text-sub-light dark:text-text-sub-dark mt-2">Active job offers</p>
</div>
<!-- Card 4 -->
<div class="flex flex-col p-5 rounded-xl border border-border-light dark:border-border-dark bg-surface-light dark:bg-surface-dark shadow-sm hover:shadow-md transition-shadow">
<div class="flex items-center justify-between mb-4">
<div class="p-2 rounded-lg bg-teal-100 text-teal-600 dark:bg-teal-900/30 dark:text-teal-400">
<span class="material-symbols-outlined" style="font-size: 24px;">military_tech</span>
</div>
<span class="flex items-center gap-1 text-xs font-medium text-green-600 bg-green-100 dark:bg-green-900/30 dark:text-green-400 px-2 py-1 rounded-full">
<span class="material-symbols-outlined" style="font-size: 14px;">trending_up</span> 0.2
                                </span>
</div>
<p class="text-text-sub-light dark:text-text-sub-dark text-sm font-medium">Avg. Project Score</p>
<h3 class="text-2xl font-bold text-text-main-light dark:text-text-main-dark mt-1">8.7<span class="text-lg font-normal text-text-sub-light dark:text-text-sub-dark">/10</span></h3>
<p class="text-xs text-text-sub-light dark:text-text-sub-dark mt-2">Based on 500+ submissions</p>
</div>
</div>
<!-- Main Chart Section -->
<div class="w-full">
<!-- Big Chart: User Engagement -->
<div class="rounded-xl border border-border-light dark:border-border-dark bg-surface-light dark:bg-surface-dark p-6 shadow-sm w-full">
<div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6 w-full">
<div>
<h3 class="text-lg font-bold text-text-main-light dark:text-text-main-dark">User Engagement</h3>
<p class="text-sm text-text-sub-light dark:text-text-sub-dark">Active sessions over the last @(ViewBag.SelectedDays ?? 30) days</p>
</div>
<div class="flex items-center gap-2 p-1 bg-background-light dark:bg-background-dark rounded-lg border border-border-light dark:border-border-dark self-start sm:self-auto">
<a href="@Url.Action("Index", "Admin", new { days = 30 })" class="px-3 py-1 text-xs font-medium @((ViewBag.SelectedDays ?? 30) == 30 ? "bg-surface-light dark:bg-surface-dark text-primary shadow-sm" : "text-text-sub-light dark:text-text-sub-dark hover:text-text-main-light dark:hover:text-text-main-dark") rounded-md transition-all">30 Days</a>
<a href="@Url.Action("Index", "Admin", new { days = 7 })" class="px-3 py-1 text-xs font-medium @((ViewBag.SelectedDays ?? 30) == 7 ? "bg-surface-light dark:bg-surface-dark text-primary shadow-sm" : "text-text-sub-light dark:text-text-sub-dark hover:text-text-main-light dark:hover:text-text-main-dark") rounded-md transition-all">7 Days</a>
<a href="@Url.Action("Index", "Admin", new { days = 1 })" class="px-3 py-1 text-xs font-medium @((ViewBag.SelectedDays ?? 30) == 1 ? "bg-surface-light dark:bg-surface-dark text-primary shadow-sm" : "text-text-sub-light dark:text-text-sub-dark hover:text-text-main-light dark:hover:text-text-main-dark") rounded-md transition-all">24 Hours</a>
</div>
</div>
<div class="h-[300px] w-full relative">
<canvas id="engagementChart"></canvas>
</div>
</div>
</div>

<!-- Right Column: Stats & Distribution -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mt-6">
<!-- Skill Distribution -->
<div class="flex-1 rounded-xl border border-border-light dark:border-border-dark bg-surface-light dark:bg-surface-dark p-6 shadow-sm">
<h3 class="text-lg font-bold text-text-main-light dark:text-text-main-dark mb-4">Skill Distribution</h3>
<div class="h-[180px] w-full relative">
<canvas id="skillDistributionChart"></canvas>
</div>
</div>
<!-- Quick Stats List -->
<div class="rounded-xl border border-border-light dark:border-border-dark bg-surface-light dark:bg-surface-dark p-6 shadow-sm">
<h3 class="text-lg font-bold text-text-main-light dark:text-text-main-dark mb-4">Courses</h3>
<div class="flex flex-col gap-4 max-h-[300px] overflow-y-auto">
@{
    var topCourses = ViewBag.TopCourses as List<object>;
    if (topCourses != null && topCourses.Count > 0)
    {
        var colorClasses = new[] { 
            "bg-blue-100 text-blue-600 dark:bg-blue-900/30 dark:text-blue-400",
            "bg-yellow-100 text-yellow-600 dark:bg-yellow-900/30 dark:text-yellow-400",
            "bg-purple-100 text-purple-600 dark:bg-purple-900/30 dark:text-purple-400",
            "bg-green-100 text-green-600 dark:bg-green-900/30 dark:text-green-400",
            "bg-red-100 text-red-600 dark:bg-red-900/30 dark:text-red-400",
            "bg-indigo-100 text-indigo-600 dark:bg-indigo-900/30 dark:text-indigo-400"
        };
        var icons = new[] { "code", "terminal", "data_object", "school", "book", "menu_book" };
        
        @for (int i = 0; i < topCourses.Count; i++)
        {
            try
            {
                var course = (dynamic)topCourses[i];
                var courseTitle = course?.Title?.ToString() ?? "Unknown Course";
                var enrollmentCount = course?.EnrollmentCount?.ToString() ?? "0";
                var colorClass = colorClasses[i % colorClasses.Length];
                var icon = icons[i % icons.Length];
                
                <div class="flex items-center justify-between">
                <div class="flex items-center gap-3">
                <div class="flex items-center justify-center size-8 rounded @colorClass">
                <span class="material-symbols-outlined" style="font-size: 18px;">@icon</span>
                </div>
                <span class="text-sm font-medium text-text-main-light dark:text-text-main-dark">@courseTitle</span>
                </div>
                <span class="text-sm font-bold text-text-main-light dark:text-text-main-dark">@enrollmentCount</span>
                </div>
            }
            catch
            {
                <div class="flex items-center justify-center py-2 text-text-sub-light dark:text-text-sub-dark text-xs">
                <p>Error loading course data</p>
                </div>
            }
        }
    }
    else
    {
        <div class="flex items-center justify-center py-4 text-text-sub-light dark:text-text-sub-dark text-sm">
        <p>No courses available</p>
        </div>
    }
}
</div>
</div>
</div>

@section Scripts {
@{
    var engagementData = ViewBag.EngagementData as List<object>;
    var labels = new List<string>();
    var sessionsData = new List<int>();
    var lessonCompletionsData = new List<int>();
    
    if (engagementData != null && engagementData.Count > 0)
    {
        foreach (var item in engagementData)
        {
            var point = (dynamic)item;
            labels.Add(point.Date);
            sessionsData.Add(point.Sessions);
            lessonCompletionsData.Add(point.LessonCompletions);
        }
    }
}

<script>
document.addEventListener('DOMContentLoaded', function() {
    const ctx = document.getElementById('engagementChart');
    if (!ctx) return;
    
    const isDarkMode = document.documentElement.classList.contains('dark');
    
    const chartData = {
        labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(labels)),
        datasets: [
            {
                label: 'Active Sessions',
                data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(sessionsData)),
                borderColor: '#9e47eb',
                backgroundColor: 'rgba(158, 71, 235, 0.1)',
                borderWidth: 2.5,
                fill: true,
                tension: 0.4,
                pointRadius: 3,
                pointHoverRadius: 5,
                pointBackgroundColor: '#9e47eb',
                pointBorderColor: '#ffffff',
                pointBorderWidth: 2
            },
            {
                label: 'Lesson Completions',
                data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(lessonCompletionsData)),
                borderColor: 'rgba(158, 71, 235, 0.5)',
                backgroundColor: 'rgba(158, 71, 235, 0.05)',
                borderWidth: 1.5,
                fill: false,
                tension: 0.4,
                pointRadius: 2,
                pointHoverRadius: 4,
                borderDash: [5, 5]
            }
        ]
    };
    
    const chartOptions = {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
            legend: {
                display: @(engagementData != null && engagementData.Count > 0 ? "true" : "false"),
                position: 'top',
                labels: {
                    color: isDarkMode ? '#f8f9fc' : '#0d121b',
                    font: {
                        family: 'Inter, sans-serif',
                        size: 11
                    },
                    usePointStyle: true,
                    padding: 15
                }
            },
            tooltip: {
                backgroundColor: isDarkMode ? '#2d2438' : '#ffffff',
                titleColor: isDarkMode ? '#f8f9fc' : '#0d121b',
                bodyColor: isDarkMode ? '#f8f9fc' : '#0d121b',
                borderColor: isDarkMode ? '#3d2a4a' : '#eee7f3',
                borderWidth: 1,
                padding: 12,
                displayColors: true,
                callbacks: {
                    title: function(context) {
                        return context[0].label;
                    },
                    label: function(context) {
                        return context.dataset.label + ': ' + context.parsed.y + ' users';
                    }
                }
            }
        },
        scales: {
            x: {
                grid: {
                    color: isDarkMode ? 'rgba(61, 42, 74, 0.5)' : 'rgba(238, 231, 243, 0.5)',
                    drawBorder: false
                },
                ticks: {
                    color: isDarkMode ? '#9ca3af' : '#6b7280',
                    font: {
                        family: 'Inter, sans-serif',
                        size: 10
                    },
                    maxRotation: 45,
                    minRotation: 0
                }
            },
            y: {
                beginAtZero: true,
                grid: {
                    color: isDarkMode ? 'rgba(61, 42, 74, 0.5)' : 'rgba(238, 231, 243, 0.5)',
                    drawBorder: false
                },
                ticks: {
                    color: isDarkMode ? '#9ca3af' : '#6b7280',
                    font: {
                        family: 'Inter, sans-serif',
                        size: 10
                    },
                    precision: 0
                }
            }
        },
        interaction: {
            intersect: false,
            mode: 'index'
        }
    };
    
    const chart = new Chart(ctx, {
        type: 'line',
        data: chartData,
        options: chartOptions
    });
    
    // Skill Distribution Chart
    @{
        var skillDist = ViewBag.SkillDistribution as Dictionary<string, double>;
        var skillLabels = new List<string>();
        var skillData = new List<double>();
        
        if (skillDist != null)
        {
            skillLabels.Add("Beginner");
            skillLabels.Add("Intermediate");
            skillLabels.Add("Advanced");
            
            skillData.Add(skillDist.ContainsKey("Beginner") ? skillDist["Beginner"] : 0);
            skillData.Add(skillDist.ContainsKey("Intermediate") ? skillDist["Intermediate"] : 0);
            skillData.Add(skillDist.ContainsKey("Advanced") ? skillDist["Advanced"] : 0);
        }
    }
    
    const skillCtx = document.getElementById('skillDistributionChart');
    if (skillCtx) {
        const skillChartData = {
            labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(skillLabels)),
            datasets: [{
                label: 'Users (%)',
                data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(skillData)),
                backgroundColor: [
                    'rgba(158, 71, 235, 0.8)',
                    'rgba(158, 71, 235, 1)',
                    'rgba(158, 71, 235, 0.6)'
                ],
                borderColor: [
                    '#9e47eb',
                    '#9e47eb',
                    '#9e47eb'
                ],
                borderWidth: 2,
                borderRadius: 8,
                borderSkipped: false
            }]
        };
        
        const skillChartOptions = {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: {
                    display: false
                },
                tooltip: {
                    backgroundColor: isDarkMode ? '#2d2438' : '#ffffff',
                    titleColor: isDarkMode ? '#f8f9fc' : '#0d121b',
                    bodyColor: isDarkMode ? '#f8f9fc' : '#0d121b',
                    borderColor: isDarkMode ? '#3d2a4a' : '#eee7f3',
                    borderWidth: 1,
                    padding: 12,
                    displayColors: true,
                    callbacks: {
                        label: function(context) {
                            return context.label + ': ' + context.parsed.y.toFixed(1) + '%';
                        }
                    }
                }
            },
            scales: {
                x: {
                    grid: {
                        display: false,
                        drawBorder: false
                    },
                    ticks: {
                        color: isDarkMode ? '#9ca3af' : '#6b7280',
                        font: {
                            family: 'Inter, sans-serif',
                            size: 10,
                            weight: 'bold'
                        }
                    }
                },
                y: {
                    beginAtZero: true,
                    max: 100,
                    grid: {
                        color: isDarkMode ? 'rgba(61, 42, 74, 0.5)' : 'rgba(238, 231, 243, 0.5)',
                        drawBorder: false
                    },
                    ticks: {
                        color: isDarkMode ? '#9ca3af' : '#6b7280',
                        font: {
                            family: 'Inter, sans-serif',
                            size: 10
                        },
                        callback: function(value) {
                            return value + '%';
                        }
                    }
                }
            }
        };
        
        new Chart(skillCtx, {
            type: 'bar',
            data: skillChartData,
            options: skillChartOptions
        });
    }
});
</script>
}
</div>