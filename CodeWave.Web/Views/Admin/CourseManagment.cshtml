@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Course Management";
    ViewData["Subtitle"] = "Manage curriculum, track performance, and update content.";
}

<div class="flex flex-col gap-6 max-w-[1400px] mx-auto">
<!-- Page Header -->
<div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
<div>
<h2 class="text-slate-900 dark:text-white text-3xl font-black tracking-tight">Course Management</h2>
<p class="text-slate-500 dark:text-slate-400 mt-1">Manage curriculum, track performance, and update content.</p>
</div>
<a asp-controller="Admin" asp-action="CRUDCourse" class="flex items-center justify-center gap-2 rounded-lg h-10 px-5 bg-primary hover:bg-primary-dark text-white text-sm font-bold shadow-lg shadow-primary/30 transition-all active:scale-95">
<span class="material-symbols-outlined text-[20px]">add</span>
<span>Add New Course</span>
</a>
</div>
<!-- Stats Cards -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
<div class="flex flex-col p-5 rounded-xl border border-border-light dark:border-border-dark bg-surface-light dark:bg-surface-dark shadow-sm hover:shadow-md transition-shadow">
<div class="flex items-center justify-between mb-4">
<div class="p-2 rounded-lg bg-purple-100 text-purple-600 dark:bg-purple-900/30 dark:text-purple-400">
<span class="material-symbols-outlined" style="font-size: 24px;">menu_book</span>
</div>
<span class="flex items-center gap-1 text-xs font-medium text-green-600 bg-green-100 dark:bg-green-900/30 dark:text-green-400 px-2 py-1 rounded-full">
<span class="material-symbols-outlined" style="font-size: 14px;">trending_up</span> 5%
</span>
</div>
<p class="text-text-sub-light dark:text-text-sub-dark text-sm font-medium">Total Courses</p>
<h3 class="text-2xl font-bold text-text-main-light dark:text-text-main-dark mt-1">@ViewBag.TotalCourses</h3>
<p class="text-xs text-text-sub-light dark:text-text-sub-dark mt-2">Available courses</p>
</div>
<div class="flex flex-col p-5 rounded-xl border border-border-light dark:border-border-dark bg-surface-light dark:bg-surface-dark shadow-sm hover:shadow-md transition-shadow">
<div class="flex items-center justify-between mb-4">
<div class="p-2 rounded-lg bg-blue-100 text-blue-600 dark:bg-blue-900/30 dark:text-blue-400">
<span class="material-symbols-outlined" style="font-size: 24px;">school</span>
</div>
</div>
<p class="text-text-sub-light dark:text-text-sub-dark text-sm font-medium">Active Students</p>
<h3 class="text-2xl font-bold text-text-main-light dark:text-text-main-dark mt-1">N/A</h3>
<p class="text-xs text-text-sub-light dark:text-text-sub-dark mt-2">Enrolled learners</p>
</div>
<div class="flex flex-col p-5 rounded-xl border border-border-light dark:border-border-dark bg-surface-light dark:bg-surface-dark shadow-sm hover:shadow-md transition-shadow">
<div class="flex items-center justify-between mb-4">
<div class="p-2 rounded-lg bg-green-100 text-green-600 dark:bg-green-900/30 dark:text-green-400">
<span class="material-symbols-outlined" style="font-size: 24px;">check_circle</span>
</div>
</div>
<p class="text-text-sub-light dark:text-text-sub-dark text-sm font-medium">Published</p>
<h3 class="text-2xl font-bold text-text-main-light dark:text-text-main-dark mt-1">@ViewBag.TotalCourses</h3>
<p class="text-xs text-text-sub-light dark:text-text-sub-dark mt-2">Live courses</p>
</div>
<div class="flex flex-col p-5 rounded-xl border border-border-light dark:border-border-dark bg-surface-light dark:bg-surface-dark shadow-sm hover:shadow-md transition-shadow">
<div class="flex items-center justify-between mb-4">
<div class="p-2 rounded-lg bg-gray-100 text-gray-600 dark:bg-gray-900/30 dark:text-gray-400">
<span class="material-symbols-outlined" style="font-size: 24px;">edit_note</span>
</div>
</div>
<p class="text-text-sub-light dark:text-text-sub-dark text-sm font-medium">Drafts</p>
<h3 class="text-2xl font-bold text-text-main-light dark:text-text-main-dark mt-1">0</h3>
<p class="text-xs text-text-sub-light dark:text-text-sub-dark mt-2">Pending courses</p>
</div>
</div>

<!-- Action Bar -->
<div class="flex flex-col sm:flex-row gap-4 items-start sm:items-center justify-between p-4 rounded-xl border border-border-light dark:border-border-dark bg-surface-light dark:bg-surface-dark shadow-sm">
<form method="get" class="flex flex-1 gap-3 w-full sm:w-auto">
<div class="relative flex-1 min-w-[280px]">
<span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-text-sub-light dark:text-text-sub-dark" style="font-size: 20px;">search</span>
<input name="searchTerm" value="@ViewBag.SearchTerm" class="w-full pl-10 pr-4 py-2.5 rounded-lg bg-background-light dark:bg-background-dark border border-border-light dark:border-border-dark text-text-main-light dark:text-text-main-dark placeholder-text-sub-light dark:placeholder-text-sub-dark focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-all" placeholder="Search courses..." type="text"/>
</div>
<button type="submit" class="px-5 py-2.5 rounded-lg bg-primary hover:bg-primary-dark text-white font-semibold text-sm transition-colors shadow-sm">
Search
</button>
</form>
<a asp-controller="Admin" asp-action="CRUDCourse" class="flex items-center gap-2 px-5 py-2.5 rounded-lg bg-primary hover:bg-primary-dark text-white font-semibold text-sm transition-colors shadow-sm">
<span class="material-symbols-outlined" style="font-size: 20px;">add</span>
Create Course
</a>
</div>

<!-- Courses Table -->
<div class="rounded-xl border border-border-light dark:border-border-dark bg-surface-light dark:bg-surface-dark shadow-sm overflow-hidden">
<div class="overflow-x-auto">
<table class="w-full text-left">
<thead class="bg-background-light dark:bg-background-dark border-b border-border-light dark:border-border-dark">
<tr>
<th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-text-sub-light dark:text-text-sub-dark">Course</th>
<th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-text-sub-light dark:text-text-sub-dark">Learning Path</th>
<th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-text-sub-light dark:text-text-sub-dark">Level</th>
<th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-text-sub-light dark:text-text-sub-dark">Lessons</th>
<th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-text-sub-light dark:text-text-sub-dark">Created</th>
<th class="px-6 py-4 text-right text-xs font-semibold uppercase tracking-wider text-text-sub-light dark:text-text-sub-dark">Actions</th>
</tr>
</thead>
<tbody class="divide-y divide-border-light dark:divide-border-dark">
@if (ViewBag.Courses != null && ((List<CodeWave.Domain.Entities.Course>)ViewBag.Courses).Any())
{
    @foreach (var course in (List<CodeWave.Domain.Entities.Course>)ViewBag.Courses)
    {
        <tr class="hover:bg-background-light dark:hover:bg-background-dark transition-colors">
<td class="px-6 py-4">
<div class="flex items-center gap-4">
<div class="h-12 w-12 rounded-lg bg-primary/10 flex items-center justify-center">
<span class="material-symbols-outlined text-primary" style="font-size: 28px;">menu_book</span>
</div>
<div class="flex flex-col">
<span class="font-semibold text-text-main-light dark:text-text-main-dark">@course.Title</span>
<span class="text-xs text-text-sub-light dark:text-text-sub-dark">ID: @course.Id.ToString().Substring(0, 8)</span>
</div>
</div>
</td>
<td class="px-6 py-4">
<span class="inline-flex items-center gap-1 px-3 py-1 rounded-full text-xs font-medium bg-primary/10 text-primary border border-primary/20">
<span class="material-symbols-outlined" style="font-size: 16px;">code</span>
@course.LearningPath
</span>
</td>
<td class="px-6 py-4 text-sm text-text-sub-light dark:text-text-sub-dark">@(course.DifficultyLevel ?? "N/A")</td>
<td class="px-6 py-4">
<span class="text-sm font-medium text-text-main-light dark:text-text-main-dark">@(course.Lessons?.Count ?? 0)</span>
</td>
<td class="px-6 py-4 text-sm text-text-sub-light dark:text-text-sub-dark">@course.CreatedAt.ToString("MMM dd, yyyy")</td>
<td class="px-6 py-4 text-right">
<div class="flex items-center justify-end gap-2">
<a asp-controller="Admin" asp-action="CRUDCourse" asp-route-id="@course.Id" class="p-2 rounded-lg hover:bg-primary/10 hover:text-primary text-text-sub-light dark:text-text-sub-dark transition-colors">
<span class="material-symbols-outlined" style="font-size: 20px;">edit</span>
</a>
<form asp-controller="Admin" asp-action="DeleteCourse" method="post" class="inline" onsubmit="return confirm('Are you sure you want to delete this course?');">
<input type="hidden" name="id" value="@course.Id" />
<button type="submit" class="p-2 rounded-lg hover:bg-red-100 dark:hover:bg-red-900/20 hover:text-red-600 dark:hover:text-red-400 text-text-sub-light dark:text-text-sub-dark transition-colors">
<span class="material-symbols-outlined" style="font-size: 20px;">delete</span>
</button>
</form>
</div>
</td>
</tr>
    }
}
else
{
    <tr>
        <td colspan="6" class="px-6 py-12 text-center">
            <div class="flex flex-col items-center gap-3">
                <span class="material-symbols-outlined text-text-sub-light dark:text-text-sub-dark" style="font-size: 48px;">menu_book</span>
                <p class="text-text-sub-light dark:text-text-sub-dark font-medium">No courses found</p>
                <a asp-controller="Admin" asp-action="CRUDCourse" class="text-primary hover:underline text-sm">Create your first course</a>
            </div>
        </td>
    </tr>
}
</tbody>
</table>
</div>
<!-- Pagination -->
@if (ViewBag.TotalPages > 1)
{
<div class="flex items-center justify-between border-t border-border-light dark:border-border-dark bg-background-light dark:bg-background-dark px-6 py-4">
<p class="text-sm text-text-sub-light dark:text-text-sub-dark">
Showing <span class="font-medium text-text-main-light dark:text-text-main-dark">@((ViewBag.CurrentPage - 1) * 10 + 1)</span> to <span class="font-medium text-text-main-light dark:text-text-main-dark">@(Math.Min(ViewBag.CurrentPage * 10, ViewBag.TotalCourses))</span> of <span class="font-medium text-text-main-light dark:text-text-main-dark">@ViewBag.TotalCourses</span> results
</p>
<div class="flex items-center gap-2">
@if (ViewBag.CurrentPage > 1)
{
<a asp-controller="Admin" asp-action="CourseManagment" asp-route-page="@(ViewBag.CurrentPage - 1)" asp-route-searchTerm="@ViewBag.SearchTerm" class="px-3 py-2 rounded-lg border border-border-light dark:border-border-dark bg-surface-light dark:bg-surface-dark text-text-sub-light dark:text-text-sub-dark hover:bg-background-light dark:hover:bg-background-dark hover:text-primary transition-colors text-sm font-medium">
Previous
</a>
}
@for (int i = 1; i <= ViewBag.TotalPages; i++)
{
    if (i == ViewBag.CurrentPage)
    {
        <span class="px-3 py-2 rounded-lg bg-primary text-white text-sm font-medium shadow-sm">@i</span>
    }
    else if (i <= 3 || i > ViewBag.TotalPages - 2 || (i >= ViewBag.CurrentPage - 1 && i <= ViewBag.CurrentPage + 1))
    {
        <a asp-controller="Admin" asp-action="CourseManagment" asp-route-page="@i" asp-route-searchTerm="@ViewBag.SearchTerm" class="px-3 py-2 rounded-lg border border-border-light dark:border-border-dark bg-surface-light dark:bg-surface-dark text-text-main-light dark:text-text-main-dark hover:bg-background-light dark:hover:bg-background-dark hover:text-primary transition-colors text-sm font-medium">@i</a>
    }
    else if (i == 4 || i == ViewBag.TotalPages - 1)
    {
        <span class="px-2 text-text-sub-light dark:text-text-sub-dark">...</span>
    }
}
@if (ViewBag.CurrentPage < ViewBag.TotalPages)
{
<a asp-controller="Admin" asp-action="CourseManagment" asp-route-page="@(ViewBag.CurrentPage + 1)" asp-route-searchTerm="@ViewBag.SearchTerm" class="px-3 py-2 rounded-lg border border-border-light dark:border-border-dark bg-surface-light dark:bg-surface-dark text-text-sub-light dark:text-text-sub-dark hover:bg-background-light dark:hover:bg-background-dark hover:text-primary transition-colors text-sm font-medium">
Next
</a>
}
</div>
</div>
}
</div>
</div>
