@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Job Offers Management";
    ViewData["Subtitle"] = "Manage job postings, track applications, and update listings.";
}

<div class="flex flex-col gap-6 max-w-[1400px] mx-auto">
<!-- Stats Cards -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
<div class="flex flex-col p-5 rounded-xl border border-border-light dark:border-border-dark bg-surface-light dark:bg-surface-dark shadow-sm hover:shadow-md transition-shadow">
<div class="flex items-center justify-between mb-4">
<div class="p-2 rounded-lg bg-orange-100 text-orange-600 dark:bg-orange-900/30 dark:text-orange-400">
<span class="material-symbols-outlined" style="font-size: 24px;">work</span>
</div>
<span class="flex items-center gap-1 text-xs font-medium text-green-600 bg-green-100 dark:bg-green-900/30 dark:text-green-400 px-2 py-1 rounded-full">
<span class="material-symbols-outlined" style="font-size: 14px;">trending_up</span> 8%
</span>
</div>
<p class="text-text-sub-light dark:text-text-sub-dark text-sm font-medium">Total Jobs</p>
<h3 class="text-2xl font-bold text-text-main-light dark:text-text-main-dark mt-1">@ViewBag.TotalJobs</h3>
<p class="text-xs text-text-sub-light dark:text-text-sub-dark mt-2">Active listings</p>
</div>
<div class="flex flex-col p-5 rounded-xl border border-border-light dark:border-border-dark bg-surface-light dark:bg-surface-dark shadow-sm hover:shadow-md transition-shadow">
<div class="flex items-center justify-between mb-4">
<div class="p-2 rounded-lg bg-green-100 text-green-600 dark:bg-green-900/30 dark:text-green-400">
<span class="material-symbols-outlined" style="font-size: 24px;">check_circle</span>
</div>
</div>
<p class="text-text-sub-light dark:text-text-sub-dark text-sm font-medium">Active Listings</p>
<h3 class="text-2xl font-bold text-text-main-light dark:text-text-main-dark mt-1">@ViewBag.ActiveJobs</h3>
<p class="text-xs text-text-sub-light dark:text-text-sub-dark mt-2">Published jobs</p>
</div>
<div class="flex flex-col p-5 rounded-xl border border-border-light dark:border-border-dark bg-surface-light dark:bg-surface-dark shadow-sm hover:shadow-md transition-shadow">
<div class="flex items-center justify-between mb-4">
<div class="p-2 rounded-lg bg-red-100 text-red-600 dark:bg-red-900/30 dark:text-red-400">
<span class="material-symbols-outlined" style="font-size: 24px;">schedule</span>
</div>
</div>
<p class="text-text-sub-light dark:text-text-sub-dark text-sm font-medium">Expired</p>
<h3 class="text-2xl font-bold text-text-main-light dark:text-text-main-dark mt-1">@ViewBag.ExpiredJobs</h3>
<p class="text-xs text-text-sub-light dark:text-text-sub-dark mt-2">Past deadline</p>
</div>
<div class="flex flex-col p-5 rounded-xl border border-border-light dark:border-border-dark bg-surface-light dark:bg-surface-dark shadow-sm hover:shadow-md transition-shadow">
<div class="flex items-center justify-between mb-4">
<div class="p-2 rounded-lg bg-blue-100 text-blue-600 dark:bg-blue-900/30 dark:text-blue-400">
<span class="material-symbols-outlined" style="font-size: 24px;">people</span>
</div>
</div>
<p class="text-text-sub-light dark:text-text-sub-dark text-sm font-medium">Applications</p>
<h3 class="text-2xl font-bold text-text-main-light dark:text-text-main-dark mt-1">@ViewBag.TotalApplications</h3>
<p class="text-xs text-text-sub-light dark:text-text-sub-dark mt-2">Total applications</p>
</div>
</div>

<!-- Action Bar -->
<div class="flex flex-col sm:flex-row gap-4 items-start sm:items-center justify-between p-4 rounded-xl border border-border-light dark:border-border-dark bg-surface-light dark:bg-surface-dark shadow-sm">
<form method="get" class="flex flex-1 gap-3 w-full sm:w-auto">
<div class="relative flex-1 min-w-[280px]">
<span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-text-sub-light dark:text-text-sub-dark" style="font-size: 20px;">search</span>
<input name="searchTerm" value="@ViewBag.SearchTerm" class="w-full pl-10 pr-4 py-2.5 rounded-lg bg-background-light dark:bg-background-dark border border-border-light dark:border-border-dark text-text-main-light dark:text-text-main-dark placeholder-text-sub-light dark:placeholder-text-sub-dark focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-all" placeholder="Search jobs..." type="text"/>
</div>
<button type="submit" class="px-5 py-2.5 rounded-lg bg-primary hover:bg-primary-dark text-white font-semibold text-sm transition-colors shadow-sm">
Search
</button>
</form>
<a asp-controller="Admin" asp-action="CRUDJobOffer" class="flex items-center gap-2 px-5 py-2.5 rounded-lg bg-primary hover:bg-primary-dark text-white font-semibold text-sm transition-colors shadow-sm">
<span class="material-symbols-outlined" style="font-size: 20px;">add</span>
Create Job
</a>
</div>

<!-- Jobs Table -->
<div class="rounded-xl border border-border-light dark:border-border-dark bg-surface-light dark:bg-surface-dark shadow-sm overflow-hidden">
<div class="overflow-x-auto">
<table class="w-full text-left">
<thead class="bg-background-light dark:bg-background-dark border-b border-border-light dark:border-border-dark">
<tr>
<th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-text-sub-light dark:text-text-sub-dark">Job Title</th>
<th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-text-sub-light dark:text-text-sub-dark">Company</th>
<th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-text-sub-light dark:text-text-sub-dark">Required Skills</th>
<th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-text-sub-light dark:text-text-sub-dark">Posted Date</th>
<th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-text-sub-light dark:text-text-sub-dark">Deadline</th>
<th class="px-6 py-4 text-right text-xs font-semibold uppercase tracking-wider text-text-sub-light dark:text-text-sub-dark">Actions</th>
</tr>
</thead>
<tbody class="divide-y divide-border-light dark:divide-border-dark">
@if (ViewBag.JobOffers != null && ((List<CodeWave.Domain.Entities.JobOffer>)ViewBag.JobOffers).Any())
{
    @foreach (var job in (List<CodeWave.Domain.Entities.JobOffer>)ViewBag.JobOffers)
    {
        <tr class="hover:bg-background-light dark:hover:bg-background-dark transition-colors">
<td class="px-6 py-4">
<div class="flex items-center gap-4">
<div class="h-12 w-12 rounded-lg bg-primary/10 flex items-center justify-center">
<span class="material-symbols-outlined text-primary" style="font-size: 28px;">work</span>
</div>
<div class="flex flex-col">
<span class="font-semibold text-text-main-light dark:text-text-main-dark">@job.JobTitle</span>
<span class="text-xs text-text-sub-light dark:text-text-sub-dark">ID: @job.Id.ToString().Substring(0, 8)</span>
</div>
</div>
</td>
<td class="px-6 py-4">
<span class="text-sm font-medium text-text-main-light dark:text-text-main-dark">@job.Company</span>
</td>
<td class="px-6 py-4">
<span class="text-sm text-text-sub-light dark:text-text-sub-dark">@(job.RequiredSkills?.Length > 50 ? job.RequiredSkills.Substring(0, 50) + "..." : job.RequiredSkills ?? "N/A")</span>
</td>
<td class="px-6 py-4 text-sm text-text-sub-light dark:text-text-sub-dark">@job.PostedDate.ToString("MMM dd, yyyy")</td>
<td class="px-6 py-4">
@{
    var isExpired = job.Deadline < DateTime.UtcNow;
    var daysUntilDeadline = (job.Deadline - DateTime.UtcNow).Days;
}
@if (isExpired)
{
    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-300 border border-red-200 dark:border-red-800">
        <span class="h-1.5 w-1.5 rounded-full bg-red-500"></span>
        Expired
    </span>
}
else if (daysUntilDeadline <= 7)
{
    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-yellow-100 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-300 border border-yellow-200 dark:border-yellow-800">
        <span class="h-1.5 w-1.5 rounded-full bg-yellow-500"></span>
        @daysUntilDeadline days left
    </span>
}
else
{
    <span class="text-sm text-text-sub-light dark:text-text-sub-dark">@job.Deadline.ToString("MMM dd, yyyy")</span>
}
</td>
<td class="px-6 py-4 text-right">
<div class="flex items-center justify-end gap-2">
<a asp-controller="Admin" asp-action="CRUDJobOffer" asp-route-id="@job.Id" class="p-2 rounded-lg hover:bg-primary/10 hover:text-primary text-text-sub-light dark:text-text-sub-dark transition-colors">
<span class="material-symbols-outlined" style="font-size: 20px;">edit</span>
</a>
<form asp-controller="Admin" asp-action="DeleteJobOffer" method="post" class="inline" onsubmit="return confirm('Are you sure you want to delete this job offer?');">
<input type="hidden" name="id" value="@job.Id" />
<button type="submit" class="p-2 rounded-lg hover:bg-red-100 dark:hover:bg-red-900/20 hover:text-red-600 dark:hover:text-red-400 text-text-sub-light dark:text-text-sub-dark transition-colors">
<span class="material-symbols-outlined" style="font-size: 20px;">delete</span>
</button>
</form>
</div>
</td>
</tr>
    }
}
else
{
    <tr>
        <td colspan="6" class="px-6 py-12 text-center">
            <div class="flex flex-col items-center gap-3">
                <span class="material-symbols-outlined text-text-sub-light dark:text-text-sub-dark" style="font-size: 48px;">work</span>
                <p class="text-text-sub-light dark:text-text-sub-dark font-medium">No job offers found</p>
                <a asp-controller="Admin" asp-action="CRUDJobOffer" class="text-primary hover:underline text-sm">Create your first job offer</a>
            </div>
        </td>
    </tr>
}
</tbody>
</table>
</div>
<!-- Pagination -->
@if (ViewBag.TotalPages > 1)
{
<div class="flex items-center justify-between border-t border-border-light dark:border-border-dark bg-background-light dark:bg-background-dark px-6 py-4">
<p class="text-sm text-text-sub-light dark:text-text-sub-dark">
Showing <span class="font-medium text-text-main-light dark:text-text-main-dark">@((ViewBag.CurrentPage - 1) * 10 + 1)</span> to <span class="font-medium text-text-main-light dark:text-text-main-dark">@(Math.Min(ViewBag.CurrentPage * 10, ViewBag.TotalJobs))</span> of <span class="font-medium text-text-main-light dark:text-text-main-dark">@ViewBag.TotalJobs</span> results
</p>
<div class="flex items-center gap-2">
@if (ViewBag.CurrentPage > 1)
{
<a asp-controller="Admin" asp-action="JobOffers" asp-route-page="@(ViewBag.CurrentPage - 1)" asp-route-searchTerm="@ViewBag.SearchTerm" class="px-3 py-2 rounded-lg border border-border-light dark:border-border-dark bg-surface-light dark:bg-surface-dark text-text-sub-light dark:text-text-sub-dark hover:bg-background-light dark:hover:bg-background-dark hover:text-primary transition-colors text-sm font-medium">
Previous
</a>
}
@for (int i = 1; i <= ViewBag.TotalPages; i++)
{
    if (i == ViewBag.CurrentPage)
    {
        <span class="px-3 py-2 rounded-lg bg-primary text-white text-sm font-medium shadow-sm">@i</span>
    }
    else if (i <= 3 || i > ViewBag.TotalPages - 2 || (i >= ViewBag.CurrentPage - 1 && i <= ViewBag.CurrentPage + 1))
    {
        <a asp-controller="Admin" asp-action="JobOffers" asp-route-page="@i" asp-route-searchTerm="@ViewBag.SearchTerm" class="px-3 py-2 rounded-lg border border-border-light dark:border-border-dark bg-surface-light dark:bg-surface-dark text-text-main-light dark:text-text-main-dark hover:bg-background-light dark:hover:bg-background-dark hover:text-primary transition-colors text-sm font-medium">@i</a>
    }
    else if (i == 4 || i == ViewBag.TotalPages - 1)
    {
        <span class="px-2 text-text-sub-light dark:text-text-sub-dark">...</span>
    }
}
@if (ViewBag.CurrentPage < ViewBag.TotalPages)
{
<a asp-controller="Admin" asp-action="JobOffers" asp-route-page="@(ViewBag.CurrentPage + 1)" asp-route-searchTerm="@ViewBag.SearchTerm" class="px-3 py-2 rounded-lg border border-border-light dark:border-border-dark bg-surface-light dark:bg-surface-dark text-text-sub-light dark:text-text-sub-dark hover:bg-background-light dark:hover:bg-background-dark hover:text-primary transition-colors text-sm font-medium">
Next
</a>
}
</div>
</div>
}
</div>
</div>
