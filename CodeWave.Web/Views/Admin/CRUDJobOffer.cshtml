@model CodeWave.Domain.Entities.JobOffer
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = ViewBag.IsEdit == true ? "Edit Job Offer" : "Create Job Offer";
    ViewData["Subtitle"] = ViewBag.IsEdit == true ? "Update job offer details." : "Fill in the details below to post a new opportunity for students.";
}

<!-- Breadcrumbs -->
<nav class="flex items-center gap-2 text-sm mb-6">
<a class="text-slate-500 hover:text-primary transition-colors font-medium" asp-controller="Admin" asp-action="Index">Dashboard</a>
<span class="material-symbols-outlined text-[16px] text-slate-400">chevron_right</span>
<a class="text-slate-500 hover:text-primary transition-colors font-medium" asp-controller="Admin" asp-action="JobOffers">Jobs</a>
<span class="material-symbols-outlined text-[16px] text-slate-400">chevron_right</span>
<span class="text-primary font-medium">@(ViewBag.IsEdit == true ? "Edit" : "Create New")</span>
</nav>

<div class="max-w-5xl mx-auto w-full">
<div class="flex flex-wrap justify-between items-end gap-4 mb-8">
<div>
<h1 class="text-3xl font-bold text-slate-900 dark:text-white tracking-tight">@(ViewBag.IsEdit == true ? "Edit Job Offer" : "Create New Job Offer")</h1>
<p class="text-slate-500 dark:text-gray-400 mt-1">@(ViewBag.IsEdit == true ? "Update job offer details." : "Fill in the details below to post a new opportunity for students.")</p>
</div>
<div class="flex items-center gap-3">
<a asp-controller="Admin" asp-action="JobOffers" class="px-4 py-2 rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-surface-dark text-slate-700 dark:text-gray-300 text-sm font-medium hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors">
Cancel
</a>
<button type="submit" form="jobOfferForm" class="px-4 py-2 rounded-lg bg-primary text-white text-sm font-medium hover:bg-primary-dark shadow-md shadow-primary/20 transition-all flex items-center gap-2">
<span class="material-symbols-outlined text-[18px]">save</span>
Save Job Offer
</button>
</div>
</div>
<form id="jobOfferForm" asp-controller="Admin" asp-action="CreateOrUpdateJobOffer" method="post" class="space-y-8">
@Html.AntiForgeryToken()
<input type="hidden" asp-for="Id" />
<!-- Section 1: Core Details -->
<section class="bg-white dark:bg-[#251b2e] rounded-xl shadow-sm border border-gray-200 dark:border-gray-800 overflow-hidden">
<div class="border-b border-gray-200 dark:border-gray-700 px-6 py-4 bg-gray-50/50 dark:bg-white/5">
<h2 class="text-lg font-semibold text-slate-900 dark:text-white flex items-center gap-2">
<span class="material-symbols-outlined text-primary">apartment</span>
                                Company &amp; Role
                            </h2>
</div>
<div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-6">
<!-- Job Title -->
<div class="flex flex-col gap-2">
<label class="text-sm font-medium text-text-main dark:text-gray-200" for="job_title">Job Title <span class="text-red-500">*</span></label>
<input asp-for="JobTitle" class="w-full rounded-lg border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-slate-900 dark:text-white h-11 px-4 focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all placeholder:text-gray-400" id="job_title" placeholder="e.g. Senior Frontend Engineer" type="text"/>
<span asp-validation-for="JobTitle" class="text-red-500 text-xs"></span>
</div>
<!-- Company Name -->
<div class="flex flex-col gap-2">
<label class="text-sm font-medium text-text-main dark:text-gray-200" for="company_name">Company Name <span class="text-red-500">*</span></label>
<div class="relative">
<input asp-for="Company" class="w-full rounded-lg border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-slate-900 dark:text-white h-11 px-4 pl-11 focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all placeholder:text-gray-400" id="company_name" placeholder="e.g. CodeWave Inc." type="text"/>
<span asp-validation-for="Company" class="text-red-500 text-xs"></span>
<div class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 flex items-center">
<span class="material-symbols-outlined text-[20px]">business</span>
</div>
</div>
</div>
<!-- Location -->
<div class="flex flex-col gap-2">
<label class="text-sm font-medium text-text-main dark:text-gray-200" for="location">Location <span class="text-red-500">*</span></label>
<div class="relative">
<input class="w-full rounded-lg border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-slate-900 dark:text-white h-11 px-4 pl-11 focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all placeholder:text-gray-400" id="location" placeholder="e.g. Remote / New York, NY" type="text"/>
<div class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 flex items-center">
<span class="material-symbols-outlined text-[20px]">location_on</span>
</div>
</div>
</div>
<!-- Employment Type -->
<div class="flex flex-col gap-2">
<label class="text-sm font-medium text-text-main dark:text-gray-200" for="emp_type">Employment Type</label>
<div class="relative">
<select class="w-full rounded-lg border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-slate-900 dark:text-white h-11 px-4 pl-11 focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all appearance-none cursor-pointer" id="emp_type">
<option disabled="" selected="" value="">Select Type</option>
<option value="full-time">Full-time</option>
<option value="part-time">Part-time</option>
<option value="contract">Contract</option>
<option value="internship">Internship</option>
</select>
<div class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 flex items-center pointer-events-none">
<span class="material-symbols-outlined text-[20px]">schedule</span>
</div>
<div class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 flex items-center pointer-events-none">
<span class="material-symbols-outlined text-[20px]">expand_more</span>
</div>
</div>
</div>
</div>
</section>
<!-- Section 2: Detailed Information -->
<section class="bg-white dark:bg-[#251b2e] rounded-xl shadow-sm border border-gray-200 dark:border-gray-800 overflow-hidden">
<div class="border-b border-gray-200 dark:border-gray-700 px-6 py-4 bg-gray-50/50 dark:bg-white/5">
<h2 class="text-lg font-semibold text-slate-900 dark:text-white flex items-center gap-2">
<span class="material-symbols-outlined text-primary">description</span>
                                Job Details &amp; Skills
                            </h2>
</div>
<div class="p-6 flex flex-col gap-6">
<!-- Description (WYSIWYG Placeholder) -->
<div class="flex flex-col gap-2">
<label class="text-sm font-medium text-text-main dark:text-gray-200">Job Description</label>
<div class="border border-gray-200 dark:border-gray-700 rounded-lg overflow-hidden bg-gray-50 dark:bg-gray-800 focus-within:ring-2 focus-within:ring-primary/20 focus-within:border-primary transition-all">
<!-- Toolbar -->
<div class="flex items-center gap-1 p-2 border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-white/5">
<button class="p-1.5 rounded hover:bg-gray-200 dark:hover:bg-gray-700 text-gray-500 dark:text-gray-400 transition-colors" title="Bold">
<span class="material-symbols-outlined text-[20px]">format_bold</span>
</button>
<button class="p-1.5 rounded hover:bg-gray-200 dark:hover:bg-gray-700 text-gray-500 dark:text-gray-400 transition-colors" title="Italic">
<span class="material-symbols-outlined text-[20px]">format_italic</span>
</button>
<button class="p-1.5 rounded hover:bg-gray-200 dark:hover:bg-gray-700 text-gray-500 dark:text-gray-400 transition-colors" title="List">
<span class="material-symbols-outlined text-[20px]">format_list_bulleted</span>
</button>
<div class="w-px h-4 bg-gray-300 dark:bg-gray-600 mx-1"></div>
<button class="p-1.5 rounded hover:bg-gray-200 dark:hover:bg-gray-700 text-gray-500 dark:text-gray-400 transition-colors" title="Link">
<span class="material-symbols-outlined text-[20px]">link</span>
</button>
</div>
<textarea asp-for="Description" class="w-full bg-transparent border-none p-4 min-h-[200px] focus:ring-0 text-slate-900 dark:text-white placeholder:text-gray-400 resize-y" placeholder="Describe the role, responsibilities, and requirements..."></textarea>
<span asp-validation-for="Description" class="text-red-500 text-xs"></span>
</div>
</div>
<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
<!-- Required Skills -->
<div class="flex flex-col gap-2">
<label class="text-sm font-medium text-text-main dark:text-gray-200">Required Skills</label>
<textarea asp-for="RequiredSkills" class="w-full rounded-lg border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-slate-900 dark:text-white p-3 min-h-[100px] focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all placeholder:text-gray-400 resize-y" placeholder="Enter required skills separated by commas (e.g., React, Node.js, TypeScript)"></textarea>
<span asp-validation-for="RequiredSkills" class="text-red-500 text-xs"></span>
<p class="text-xs text-text-secondary dark:text-gray-500">Enter skills separated by commas.</p>
</div>
<!-- Salary Range -->
<div class="flex flex-col gap-2">
<label class="text-sm font-medium text-text-main dark:text-gray-200" for="salary">Salary Range (Optional)</label>
<div class="relative">
<input class="w-full rounded-lg border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-slate-900 dark:text-white h-11 px-4 pl-11 focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all placeholder:text-gray-400" id="salary" placeholder="e.g. $80k - $120k" type="text"/>
<div class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 flex items-center">
<span class="material-symbols-outlined text-[20px]">attach_money</span>
</div>
</div>
</div>
</div>
</div>
</section>
<!-- Section 3: Operations & Logistics -->
<section class="bg-white dark:bg-[#251b2e] rounded-xl shadow-sm border border-gray-200 dark:border-gray-800 overflow-hidden">
<div class="border-b border-gray-200 dark:border-gray-700 px-6 py-4 bg-gray-50/50 dark:bg-white/5">
<h2 class="text-lg font-semibold text-slate-900 dark:text-white flex items-center gap-2">
<span class="material-symbols-outlined text-primary">settings_applications</span>
                                Operations &amp; Logistics
                            </h2>
</div>
<div class="p-6 grid grid-cols-1 md:grid-cols-3 gap-6">
<!-- Application Deadline -->
<div class="flex flex-col gap-2">
<label class="text-sm font-medium text-text-main dark:text-gray-200" for="deadline">Application Deadline</label>
<div class="relative">
<input asp-for="Deadline" class="w-full rounded-lg border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-slate-900 dark:text-white h-11 px-4 focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" id="deadline" type="date" />
<span asp-validation-for="Deadline" class="text-red-500 text-xs"></span>
</div>
</div>
<!-- Apply Link -->
<div class="flex flex-col gap-2">
<label class="text-sm font-medium text-text-main dark:text-gray-200" for="apply_link">Application Link / Email</label>
<div class="relative">
<input class="w-full rounded-lg border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-slate-900 dark:text-white h-11 px-4 pl-11 focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all placeholder:text-gray-400" id="apply_link" placeholder="https://... or mailto:..." type="text"/>
<div class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 flex items-center">
<span class="material-symbols-outlined text-[20px]">link</span>
</div>
</div>
</div>
<!-- Status -->
<div class="flex flex-col gap-2">
<label class="text-sm font-medium text-text-main dark:text-gray-200" for="status">Status</label>
<div class="relative">
<select class="w-full rounded-lg border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-slate-900 dark:text-white h-11 px-4 pl-11 focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all appearance-none cursor-pointer" id="status">
<option value="draft">Draft</option>
<option selected="" value="active">Active</option>
<option value="closed">Closed</option>
<option value="filled">Filled</option>
</select>
<div class="absolute left-3 top-1/2 -translate-y-1/2 text-green-500 flex items-center pointer-events-none">
<span class="material-symbols-outlined text-[20px] filled" style="font-variation-settings: 'FILL' 1;">circle</span>
</div>
<div class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 flex items-center pointer-events-none">
<span class="material-symbols-outlined text-[20px]">expand_more</span>
</div>
</div>
</div>
</div>
</section>
</form>
</div>
</div>