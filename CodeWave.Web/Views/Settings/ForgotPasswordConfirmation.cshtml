@{
    Layout = null;
}
<!DOCTYPE html>
<html class="dark" lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Password Reset Link Sent - CodeWave</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300..700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
    </style>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        primary: "#b887e3",
                        "background-light": "#f7f6f8",
                        "background-dark": "#19131f"
                    },
                    fontFamily: {
                        display: "Space Grotesk"
                    }
                }
            }
        };
    </script>
</head>
<body class="bg-background-light dark:bg-background-dark font-display text-slate-800 dark:text-slate-200">
    <div class="min-h-screen flex items-center justify-center p-4">
        <div class="w-full max-w-md">
            <div class="bg-[#111318] border border-[#3b4354] rounded-xl p-8">
                <div class="text-center mb-6">
                    <span class="material-symbols-outlined text-green-400 text-5xl mb-4">mark_email_read</span>
                    <h1 class="text-white text-3xl font-bold mb-2">Check Your Email</h1>
                    <p class="text-[#9da6b9] mb-4">Password reset link has been generated.</p>
                </div>

                @if (TempData["ResetLink"] != null)
                {
                    <div class="mb-6 p-4 bg-[#1c1f27] border border-[#3b4354] rounded-lg">
                        <p class="text-white text-sm mb-2">For development purposes, use this link to reset your password:</p>
                        <a href="@TempData["ResetLink"]" class="text-primary hover:text-primary/80 text-sm break-all">
                            @TempData["ResetLink"]
                        </a>
                        <p class="text-[#9da6b9] text-xs mt-2">In production, this link would be sent to: @TempData["Email"]</p>
                    </div>
                }
                else
                {
                    <div class="mb-6 p-4 bg-green-900/50 border border-green-700 rounded-lg text-green-300">
                        @TempData["Success"]
                    </div>
                }

                <div class="text-center">
                    <a asp-controller="User" asp-action="Login" class="inline-block bg-primary text-white h-12 px-6 rounded-lg hover:bg-primary/90 font-medium">
                        Back to Login
                    </a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>



