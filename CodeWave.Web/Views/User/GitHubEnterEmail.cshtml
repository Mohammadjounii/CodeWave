@model CodeWave.Web.Models.GitHubEnterEmailViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>Complete Sign Up — CodeWave</title>
    <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        primary: "#8B5CF6",
                        secondary: "#A78BFA",
                        "background-light": "#F8F9FA",
                        "background-dark": "#111827",
                    },
                    fontFamily: {
                        display: ["Space Mono", "monospace"],
                        sans: ["Inter", "sans-serif"],
                    },
                    borderRadius: {
                        DEFAULT: "12px",
                        lg: '1rem',
                        xl: '1.25rem',
                        '2xl': '1.5rem',
                    },
                    animation: {
                        'blob': 'blob 7s infinite',
                        'fade-in': 'fadeIn 0.5s ease-out',
                    },
                    keyframes: {
                        blob: {
                            '0%': { transform: 'translate(0px, 0px) scale(1)' },
                            '33%': { transform: 'translate(30px, -50px) scale(1.1)' },
                            '66%': { transform: 'translate(-20px, 20px) scale(0.9)' },
                            '100%': { transform: 'translate(0px, 0px) scale(1)' },
                        },
                        fadeIn: {
                            '0%': { opacity: '0', transform: 'translateY(10px)' },
                            '100%': { opacity: '1', transform: 'translateY(0)' },
                        }
                    }
                },
            },
        };
    </script>
    <style>
        body { -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
        .animate-blob { animation: blob 7s infinite; }
        .animation-delay-2000 { animation-delay: 2s; }
        .animation-delay-4000 { animation-delay: 4s; }
        ::-webkit-scrollbar { width: 10px; height: 10px; }
        ::-webkit-scrollbar-track { background: rgba(155,89,245,0.08); border-radius: 999px; }
        ::-webkit-scrollbar-thumb { background: #9b59f5; border-radius: 999px; box-shadow: 0 0 10px rgba(155,89,245,0.9), 0 0 20px rgba(155,89,245,0.5), 0 0 35px rgba(155,89,245,0.2); }
        ::-webkit-scrollbar-thumb:hover { background: #b07eff; }
        ::-webkit-scrollbar-corner { background: transparent; }
        * { scrollbar-width: thin; scrollbar-color: #9b59f5 rgba(155,89,245,0.08); }
    </style>
</head>
<body class="bg-background-light dark:bg-background-dark font-sans text-gray-800 dark:text-gray-200 antialiased min-h-screen flex flex-col relative selection:bg-primary/30 selection:text-primary">

    <div class="fixed inset-0 z-0 pointer-events-none overflow-hidden">
        <div class="absolute -top-32 -right-32 w-[900px] h-[900px] bg-gradient-to-br from-primary/35 via-purple-300/20 to-secondary/30 rounded-full filter blur-[140px] opacity-75"></div>
        <div class="absolute -bottom-32 -left-32 w-[900px] h-[900px] bg-gradient-to-tr from-blue-300/35 via-cyan-300/20 to-sky-300/30 rounded-full filter blur-[140px] opacity-75"></div>
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-gradient-to-br from-purple-400/20 via-indigo-300/15 to-blue-400/20 rounded-full filter blur-[150px] opacity-60"></div>
        <div class="absolute top-0 -left-1/4 w-96 h-96 bg-primary/20 rounded-full filter blur-3xl opacity-60 animate-blob"></div>
        <div class="absolute top-0 -right-1/4 w-96 h-96 bg-purple-300/20 rounded-full filter blur-3xl opacity-60 animate-blob animation-delay-2000"></div>
        <div class="absolute -bottom-32 left-1/4 w-96 h-96 bg-indigo-300/20 rounded-full filter blur-3xl opacity-60 animate-blob animation-delay-4000"></div>
    </div>

    <header class="w-full px-6 lg:px-12 py-6 z-20 flex justify-between items-center absolute top-0 left-0">
        <a class="flex items-center gap-3 group" href="/">
            <img src="/codewaveblacklogo.png" alt="CodeWave Logo" class="h-12 w-12 object-contain dark:hidden"/>
            <img src="/CodeWavelogo.PNG" alt="CodeWave Logo" class="h-12 w-12 object-contain hidden dark:block"/>
            <div class="flex flex-col">
                <span class="text-xl font-display font-bold text-gray-900 dark:text-white tracking-tight group-hover:text-primary transition-colors">CodeWave</span>
            </div>
        </a>
        <div class="hidden sm:block">
            <p class="text-sm font-medium text-gray-500 dark:text-gray-400">Interactive Coding Platform</p>
        </div>
    </header>

    <main class="flex-grow flex items-center justify-center px-4 sm:px-6 lg:px-8 z-10 w-full py-20">
        <div class="w-full max-w-[440px] bg-white/70 dark:bg-gray-800/60 backdrop-blur-xl rounded-2xl p-8 sm:p-12 shadow-[0_8px_30px_rgb(0,0,0,0.04)] border border-white/40 dark:border-gray-700/50 ring-1 ring-gray-900/5 dark:ring-white/10 animate-fade-in">

            <div class="text-center mb-10">
                <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-gradient-to-br from-primary/10 to-purple-100/50 dark:from-primary/20 dark:to-purple-900/20 text-primary mb-6 ring-1 ring-primary/20 shadow-sm">
                    <svg class="w-7 h-7 fill-current" viewBox="0 0 24 24" aria-hidden="true">
                        <path clip-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.168 6.839 9.49.5.092.682-.217.682-.482 0-.237-.009-.868-.014-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.031-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.203 2.398.1 2.651.64.7 1.03 1.595 1.03 2.688 0 3.848-2.338 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.001 10.001 0 0022 12c0-5.523-4.477-10-10-10z" fill-rule="evenodd"/>
                    </svg>
                </div>
                <h1 class="font-display text-2xl font-bold text-gray-900 dark:text-white tracking-tight">One More Step</h1>
                <p class="mt-3 text-sm text-gray-500 dark:text-gray-400 font-medium leading-relaxed">
                    GitHub did not share your email address. Please enter it below to complete your account setup.
                </p>
            </div>

            @if (TempData["Error"] != null)
            {
                <div class="mb-5 text-red-600 dark:text-red-400 text-sm bg-red-50 dark:bg-red-900/20 p-3 rounded-xl border border-red-200 dark:border-red-800">
                    @TempData["Error"]
                </div>
            }

            <form asp-action="GitHubEnterEmail" asp-controller="User" method="post" class="space-y-5">
                @Html.AntiForgeryToken()

                @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
                {
                    <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm bg-red-50 dark:bg-red-900/20 p-3 rounded-xl border border-red-200 dark:border-red-800"></div>
                }

                <div>
                    <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2" asp-for="Email">Email address</label>
                    <div class="relative group">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-gray-400 group-focus-within:text-primary transition-colors">
                            <span class="material-symbols-outlined text-[20px]">mail</span>
                        </div>
                        <input asp-for="Email"
                               type="email"
                               autocomplete="email"
                               placeholder="you@example.com"
                               class="block w-full pl-11 pr-4 py-3.5 border border-gray-200 dark:border-gray-700 rounded-xl bg-white/50 dark:bg-gray-900/50 text-gray-900 dark:text-white placeholder-gray-400 focus:outline-none focus:ring-[3px] focus:ring-primary/10 focus:border-primary transition-all duration-200 sm:text-sm shadow-sm hover:border-gray-300 dark:hover:border-gray-600"/>
                    </div>
                    <span asp-validation-for="Email" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <button type="submit"
                        class="w-full flex justify-center items-center py-3.5 px-4 mt-6 border border-transparent rounded-xl shadow-lg shadow-primary/20 text-sm font-bold text-white bg-primary hover:bg-primary/90 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary dark:focus:ring-offset-gray-900 transition-all duration-200 transform hover:-translate-y-0.5 active:translate-y-0">
                    Complete Sign Up
                    <span class="material-symbols-outlined ml-2 text-lg">arrow_forward</span>
                </button>
            </form>

            <p class="mt-8 text-center text-sm text-gray-600 dark:text-gray-400">
                Changed your mind?
                <a asp-controller="User" asp-action="Login" class="font-bold text-primary hover:text-primary/80 hover:underline transition-colors duration-200">
                    Back to Login
                </a>
            </p>
        </div>
    </main>

</body>
</html>
