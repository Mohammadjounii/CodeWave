@model List<CodeWave.Domain.Entities.Project>
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <script>
        (function() {
            try {
                var theme = localStorage.getItem('theme') || 'dark';
                if (theme === 'dark') document.documentElement.classList.add('dark');
                else document.documentElement.classList.remove('dark');
            } catch(e) { document.documentElement.classList.add('dark'); }
        })();
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>My Projects - CodeWave</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300..700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />
    <style>
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
    </style>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: { extend: { colors: { primary: "#b887e3", "background-light": "#f7f6f8", "background-dark": "#19131f" }, fontFamily: { display: "Space Grotesk" } } }
        };
    </script>
</head>
<body class="bg-background-light dark:bg-background-dark font-display text-gray-800 dark:text-gray-200 min-h-screen">
<div class="flex min-h-screen">
    @await Html.PartialAsync("_UserSidebar")

    <main class="flex-1 p-8 overflow-y-auto">
        <!-- Header -->
        <div class="flex items-center justify-between mb-8">
            <div>
                <h1 class="text-3xl font-black text-gray-900 dark:text-white">My Projects</h1>
                <p class="text-gray-500 dark:text-gray-400 mt-1">Track and showcase your coding projects.</p>
            </div>
            <a asp-controller="Projects" asp-action="Create"
               class="flex items-center gap-2 px-5 py-2.5 rounded-lg bg-primary text-white text-sm font-bold shadow-lg shadow-primary/30 hover:bg-primary/80 transition-all active:scale-95">
                <span class="material-symbols-outlined text-[20px]">add</span>
                Add Project
            </a>
        </div>

        <!-- Notifications -->
        @if (TempData["Success"] != null)
        {
            <div class="mb-6 flex items-center gap-3 p-4 bg-green-100 dark:bg-green-900/30 border border-green-300 dark:border-green-700 rounded-lg text-green-800 dark:text-green-300 text-sm font-medium">
                <span class="material-symbols-outlined text-[20px]">check_circle</span>
                @TempData["Success"]
            </div>
        }

        <!-- Empty state -->
        @if (Model == null || !Model.Any())
        {
            <div class="flex flex-col items-center justify-center py-24 text-center">
                <span class="material-symbols-outlined text-6xl text-gray-300 dark:text-gray-600 mb-4">folder_open</span>
                <h2 class="text-xl font-bold text-gray-700 dark:text-gray-300">No projects yet</h2>
                <p class="text-gray-500 dark:text-gray-400 mt-2 max-w-sm">Add your first project to showcase your work on your CV and job applications.</p>
                <a asp-controller="Projects" asp-action="Create"
                   class="mt-6 flex items-center gap-2 px-5 py-2.5 rounded-lg bg-primary text-white text-sm font-bold hover:bg-primary/80 transition-all">
                    <span class="material-symbols-outlined text-[20px]">add</span>
                    Add Your First Project
                </a>
            </div>
        }
        else
        {
            <!-- Projects grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
                @foreach (var project in Model)
                {
                    <div class="flex flex-col bg-white dark:bg-[#1e1427] border border-gray-200 dark:border-gray-800 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow">
                        <div class="flex items-start justify-between mb-3">
                            <div class="flex items-center gap-3">
                                <div class="p-2 rounded-lg bg-primary/10">
                                    <span class="material-symbols-outlined text-primary text-[22px]">code</span>
                                </div>
                                <h3 class="text-base font-bold text-gray-900 dark:text-white line-clamp-1">@project.Title</h3>
                            </div>
                            <div class="flex gap-1 flex-shrink-0 ml-2">
                                <a asp-controller="Projects" asp-action="Edit" asp-route-id="@project.Id"
                                   class="p-1.5 rounded-md text-gray-400 hover:text-primary hover:bg-primary/10 transition-colors" title="Edit">
                                    <span class="material-symbols-outlined text-[18px]">edit</span>
                                </a>
                                <form asp-controller="Projects" asp-action="Delete" method="post" class="inline"
                                      onsubmit="return confirm('Delete this project?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@project.Id" />
                                    <button type="submit" class="p-1.5 rounded-md text-gray-400 hover:text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors" title="Delete">
                                        <span class="material-symbols-outlined text-[18px]">delete</span>
                                    </button>
                                </form>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(project.Description))
                        {
                            <p class="text-sm text-gray-600 dark:text-gray-400 line-clamp-3 mb-4 flex-1">@project.Description</p>
                        }
                        else
                        {
                            <p class="text-sm text-gray-400 dark:text-gray-600 italic mb-4 flex-1">No description provided.</p>
                        }

                        <div class="flex items-center justify-between pt-3 border-t border-gray-100 dark:border-gray-800 mt-auto">
                            <div class="flex items-center gap-1.5 text-xs text-gray-500 dark:text-gray-400">
                                <span class="material-symbols-outlined text-[16px]">calendar_today</span>
                                <span>@project.CompletionDate.ToString("MMM yyyy")</span>
                            </div>
                            @if (!string.IsNullOrEmpty(project.Result))
                            {
                                <span class="text-xs font-semibold px-2.5 py-1 rounded-full bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 border border-green-200 dark:border-green-800">
                                    @project.Result
                                </span>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </main>
</div>
</body>
</html>
