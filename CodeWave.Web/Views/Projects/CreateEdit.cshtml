@model CodeWave.Domain.Entities.Project
@{
    Layout = null;
    var isEdit = Model.Id != Guid.Empty;
    var pageTitle = isEdit ? "Edit Project" : "Add Project";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <script>
        (function() {
            try {
                var theme = localStorage.getItem('theme') || 'dark';
                if (theme === 'dark') document.documentElement.classList.add('dark');
                else document.documentElement.classList.remove('dark');
            } catch(e) { document.documentElement.classList.add('dark'); }
        })();
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle - CodeWave</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300..700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />
    <style>
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
    </style>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: { extend: { colors: { primary: "#b887e3", "background-light": "#f7f6f8", "background-dark": "#19131f" }, fontFamily: { display: "Space Grotesk" } } }
        };
    </script>
</head>
<body class="bg-background-light dark:bg-background-dark font-display text-gray-800 dark:text-gray-200 min-h-screen">
<div class="flex min-h-screen">
    @await Html.PartialAsync("_UserSidebar")

    <main class="flex-1 p-8 overflow-y-auto">
        <!-- Header -->
        <div class="flex items-center gap-4 mb-8">
            <a asp-controller="Projects" asp-action="Index"
               class="p-2 rounded-lg text-gray-500 hover:text-primary hover:bg-primary/10 transition-colors">
                <span class="material-symbols-outlined">arrow_back</span>
            </a>
            <div>
                <h1 class="text-3xl font-black text-gray-900 dark:text-white">@pageTitle</h1>
                <p class="text-gray-500 dark:text-gray-400 mt-1">
                    @(isEdit ? "Update the details of your project." : "Add a new project to your portfolio.")
                </p>
            </div>
        </div>

        <!-- Form -->
        <div class="max-w-2xl">
            <form asp-controller="Projects" asp-action="Save" method="post" class="space-y-6">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />

                <!-- Title -->
                <div class="flex flex-col gap-2">
                    <label asp-for="Title" class="text-sm font-semibold text-gray-700 dark:text-gray-300">
                        Project Title <span class="text-red-500">*</span>
                    </label>
                    <input asp-for="Title"
                           class="w-full px-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-white/5 text-gray-900 dark:text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary/50 text-sm"
                           placeholder="e.g. E-Commerce Web App" required />
                    <span asp-validation-for="Title" class="text-red-500 text-xs"></span>
                </div>

                <!-- Description -->
                <div class="flex flex-col gap-2">
                    <label asp-for="Description" class="text-sm font-semibold text-gray-700 dark:text-gray-300">
                        Description
                    </label>
                    <textarea asp-for="Description" rows="4"
                              class="w-full px-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-white/5 text-gray-900 dark:text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary/50 text-sm resize-none"
                              placeholder="Briefly describe what this project does, the technologies used, and your role."></textarea>
                </div>

                <!-- Completion Date -->
                <div class="flex flex-col gap-2">
                    <label asp-for="CompletionDate" class="text-sm font-semibold text-gray-700 dark:text-gray-300">
                        Completion Date <span class="text-red-500">*</span>
                    </label>
                    <input asp-for="CompletionDate" type="date"
                           class="w-full px-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-white/5 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary/50 text-sm"
                           required />
                    <span asp-validation-for="CompletionDate" class="text-red-500 text-xs"></span>
                </div>

                <!-- Result / Outcome -->
                <div class="flex flex-col gap-2">
                    <label asp-for="Result" class="text-sm font-semibold text-gray-700 dark:text-gray-300">
                        Outcome / Result
                    </label>
                    <input asp-for="Result"
                           class="w-full px-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-700 bg-white dark:bg-white/5 text-gray-900 dark:text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary/50 text-sm"
                           placeholder="e.g. Deployed, In Progress, Grade A" />
                    <p class="text-xs text-gray-400">A short label shown as a badge on the project card.</p>
                </div>

                <!-- Actions -->
                <div class="flex gap-4 pt-2">
                    <button type="submit"
                            class="flex items-center gap-2 px-6 py-2.5 rounded-lg bg-primary text-white text-sm font-bold shadow-lg shadow-primary/30 hover:bg-primary/80 transition-all active:scale-95">
                        <span class="material-symbols-outlined text-[18px]">save</span>
                        @(isEdit ? "Save Changes" : "Add Project")
                    </button>
                    <a asp-controller="Projects" asp-action="Index"
                       class="flex items-center gap-2 px-6 py-2.5 rounded-lg bg-gray-100 dark:bg-white/5 text-gray-700 dark:text-gray-300 text-sm font-bold hover:bg-gray-200 dark:hover:bg-white/10 transition-all">
                        Cancel
                    </a>
                </div>
            </form>
        </div>
    </main>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
</body>
</html>
