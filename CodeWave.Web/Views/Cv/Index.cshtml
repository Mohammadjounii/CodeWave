        const certificationsJson = document.getElementById('certificationsJson')?.value;
        
        console.log('Loading experiences from JSON:', experienceJson);
        console.log('Loading certifications from JSON:', certificationsJson);
        
        if (experienceJson && experienceJson.trim() !== '' && experienceJson !== '[]' && experienceJson.trim() !== '""') {
            try {
                const experiences = JSON.parse(experienceJson);
                if (Array.isArray(experiences) && experiences.length > 0) {
                    experiences.forEach((exp, arrayIndex) => {
                        // Use the current counter value as the index for the new item
                        const currentIndex = experienceCounter;
                        addExperience(currentIndex);
                        experienceCounter++;
                        
                        // Wait for the DOM to update, then populate the fields
                        // Use a retry mechanism to ensure fields are ready
                        let retries = 0;
                        const maxRetries = 10;
                        const tryPopulate = () => {
                            const titleInput = document.querySelector(`input[name="exp_title_${currentIndex}"]`);
                            const companyInput = document.querySelector(`input[name="exp_company_${currentIndex}"]`);
                            const startInput = document.querySelector(`input[name="exp_start_${currentIndex}"]`);
                            const endInput = document.querySelector(`input[name="exp_end_${currentIndex}"]`);
                            const descInput = document.querySelector(`textarea[name="exp_description_${currentIndex}"]`);
                            const skillsInput = document.querySelector(`input[name="exp_skills_${currentIndex}"]`);
                            
                            if (titleInput || retries >= maxRetries) {
                                if (titleInput) {
                                    titleInput.value = exp.title || '';
                                    titleInput.dispatchEvent(new Event('input', { bubbles: true }));
                                }
                                if (companyInput) {
                                    companyInput.value = exp.company || '';
                                    companyInput.dispatchEvent(new Event('input', { bubbles: true }));
