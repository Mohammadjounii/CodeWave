            }
        }
    }

    // Auto-save to localStorage with debouncing
    let saveTimeout;
    function autoSaveToLocalStorage() {
        clearTimeout(saveTimeout);
        saveTimeout = setTimeout(() => {
            // Update JSON fields first
            updateExperienceJson();
            updateCertificationsJson();
            updateProjectsJson();
            
            // Save to localStorage
            const experienceJson = document.getElementById('experienceJson')?.value || '[]';
            const certificationsJson = document.getElementById('certificationsJson')?.value || '[]';
            const projectsJson = document.getElementById('projectsJson')?.value || '[]';
            
            localStorage.setItem('cv_experience', experienceJson);
            localStorage.setItem('cv_certifications', certificationsJson);
            localStorage.setItem('cv_projects', projectsJson);
            
            console.log('Auto-saved CV data to localStorage');
        }, 1000); // Save 1 second after user stops typing
    }

    // Update JSON on input changes
    document.addEventListener('DOMContentLoaded', function() {
        // Add event listeners for experience, certification, and project fields
        document.addEventListener('input', function(e) {
            if (e.target.classList.contains('exp-field')) {
                updateExperienceJson();
                autoSaveToLocalStorage();
            }
            if (e.target.classList.contains('cert-field')) {
                updateCertificationsJson();
                autoSaveToLocalStorage();
            }
            if (e.target.classList.contains('proj-field')) {
                updateProjectsJson();
                autoSaveToLocalStorage();
            }
        });
        
        // Load existing data from database first
        // Wait a bit to ensure DOM and hidden fields are ready
        setTimeout(() => {
            console.log('=== Loading CV Data ===');
            
            // Ensure sections are expanded so fields are accessible
            ['experience', 'certifications', 'projects'].forEach(sectionId => {
                const content = document.getElementById(sectionId + '-content');
                const icon = document.getElementById(sectionId + '-icon');
                if (content && icon) {
                    content.style.display = 'block';
                    icon.textContent = 'expand_less';
                }
            });
            
            const experienceInput = document.getElementById('experienceJson');
            const certificationsInput = document.getElementById('certificationsJson');
            const projectsInput = document.getElementById('projectsJson');
            
            console.log('Experience JSON value:', experienceInput?.value);
            console.log('Certifications JSON value:', certificationsInput?.value);
            console.log('Projects JSON value:', projectsInput?.value);
            
            // Ensure empty values are set to "[]" for proper JSON handling
            if (experienceInput && (!experienceInput.value || experienceInput.value.trim() === '')) {
                experienceInput.value = '[]';
            }
            if (certificationsInput && (!certificationsInput.value || certificationsInput.value.trim() === '')) {
                certificationsInput.value = '[]';
            }
            if (projectsInput && (!projectsInput.value || projectsInput.value.trim() === '')) {
                projectsInput.value = '[]';
            }
            
            // Load data from database
            loadExperiencesAndCertifications();
            loadProjects();
            
            // Then try to restore from localStorage if available (for unsaved changes)
            setTimeout(() => {
                const savedExperience = localStorage.getItem('cv_experience');
                const savedCertifications = localStorage.getItem('cv_certifications');
                const savedProjects = localStorage.getItem('cv_projects');
                
                // Only restore from localStorage if the hidden fields are empty or only have "[]"
                // This ensures database data takes precedence
                if (experienceInput && (!experienceInput.value || experienceInput.value === '[]' || experienceInput.value.trim() === '') && savedExperience && savedExperience !== '[]') {
                    console.log('Restoring experience from localStorage');
                    experienceInput.value = savedExperience;
                    loadExperiencesAndCertifications();
                }
                
                if (certificationsInput && (!certificationsInput.value || certificationsInput.value === '[]' || certificationsInput.value.trim() === '') && savedCertifications && savedCertifications !== '[]') {
                    console.log('Restoring certifications from localStorage');
                    certificationsInput.value = savedCertifications;
                    loadExperiencesAndCertifications();
                }
                
                if (projectsInput && (!projectsInput.value || projectsInput.value === '[]' || projectsInput.value.trim() === '') && savedProjects && savedProjects !== '[]') {
                    console.log('Restoring projects from localStorage');
                    projectsInput.value = savedProjects;
                    loadProjects();
                }
            }, 300);
        }, 200);
        
        // Update JSON before form submission
        const form = document.getElementById('cvForm');
        if (form) {
            form.addEventListener('submit', function(e) {
                console.log('=== Form Submission Started ===');
                
                // Update all JSON fields before submission
                updateExperienceJson();
                updateCertificationsJson();
                updateProjectsJson();
                
                // Wait a moment for JSON updates to complete
                setTimeout(() => {
                    // Ensure empty arrays are saved as "[]" not empty string
                    const experienceInput = document.getElementById('experienceJson');
                    const certificationsInput = document.getElementById('certificationsJson');
                    const projectsInput = document.getElementById('projectsJson');
                    
                    if (experienceInput && (!experienceInput.value || experienceInput.value.trim() === '')) {
                        experienceInput.value = '[]';
                    }
                    if (certificationsInput && (!certificationsInput.value || certificationsInput.value.trim() === '')) {
                        certificationsInput.value = '[]';
                    }
                    if (projectsInput && (!projectsInput.value || projectsInput.value.trim() === '')) {
                        projectsInput.value = '[]';
                    }
                    
                    console.log('Final experience JSON:', experienceInput?.value);
                    console.log('Final certifications JSON:', certificationsInput?.value);
                    console.log('Final projects JSON:', projectsInput?.value);
                    
                    // Clear localStorage on successful submit
                    localStorage.removeItem('cv_experience');
                    localStorage.removeItem('cv_certifications');
                    localStorage.removeItem('cv_projects');
                    
                    console.log('=== Form Submission Data Ready ===');
                }, 100);
            });
        }
    });

    // Project Management
    function addProject() {
        const container = document.getElementById('projects-container');
        const index = projectCounter++;
        
        const projectHtml = `
            <div class="project-item glass-effect p-6 rounded-xl border border-white/10" data-index="${index}">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="text-gray-900 dark:text-white font-semibold text-lg">Project #${index + 1}</h3>
                    <button type="button" onclick="removeProject(${index})" class="p-2 text-red-400 hover:text-red-300 hover:bg-red-500/10 rounded-lg transition-colors">
                        <span class="material-symbols-outlined">delete</span>
                    </button>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="md:col-span-2">
                        <label class="block text-sm font-medium text-gray-700 dark:text-slate-300 mb-2">Project Name *</label>
                        <input type="text" name="proj_name_${index}" class="proj-field w-full px-4 py-3 bg-gray-100 dark:bg-white/5 border border-gray-300 dark:border-white/10 rounded-lg text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-slate-500 focus:outline-none focus:border-primary transition-colors" placeholder="e.g., E-commerce Platform" />
                    </div>
                    <div class="md:col-span-2">
                        <label class="block text-sm font-medium text-gray-700 dark:text-slate-300 mb-2">Description</label>
                        <textarea name="proj_description_${index}" rows="3" class="proj-field w-full px-4 py-3 bg-gray-100 dark:bg-white/5 border border-gray-300 dark:border-white/10 rounded-lg text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-slate-500 focus:outline-none focus:border-primary transition-colors resize-none" placeholder="Brief description of the project, what it does, and key features..."></textarea>
                    </div>
                    <div class="md:col-span-2">
                        <label class="block text-sm font-medium text-gray-700 dark:text-slate-300 mb-2">Technologies Used (comma-separated)</label>
                        <input type="text" name="proj_technologies_${index}" class="proj-field w-full px-4 py-3 bg-gray-100 dark:bg-white/5 border border-gray-300 dark:border-white/10 rounded-lg text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-slate-500 focus:outline-none focus:border-primary transition-colors" placeholder="e.g., React, Node.js, MongoDB, Express.js" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-slate-300 mb-2">Project Link/URL</label>
                        <input type="url" name="proj_link_${index}" class="proj-field w-full px-4 py-3 bg-gray-100 dark:bg-white/5 border border-gray-300 dark:border-white/10 rounded-lg text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-slate-500 focus:outline-none focus:border-primary transition-colors" placeholder="https://github.com/username/project" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-slate-300 mb-2">Completion Date</label>
                        <input type="month" name="proj_date_${index}" class="proj-field w-full px-4 py-3 bg-gray-100 dark:bg-white/5 border border-gray-300 dark:border-white/10 rounded-lg text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-slate-500 focus:outline-none focus:border-primary transition-colors" />
                    </div>
                </div>
            </div>
        `;
        
        container.insertAdjacentHTML('beforeend', projectHtml);
        // Don't update JSON here - it will be updated when user types (via input event listeners)
        // or when explicitly needed (like on form submit)
    }

    function removeProject(index) {
        const item = document.querySelector(`.project-item[data-index="${index}"]`);
        if (item) {
            item.remove();
            updateProjectsJson();
        }
    }

    function updateProjectsJson() {
        const projects = [];
        const items = document.querySelectorAll('.project-item');
        
        console.log('Updating projects JSON, found', items.length, 'project items');
        
        items.forEach(item => {
            const index = item.getAttribute('data-index');
            // Search within the item for better reliability
            const name = item.querySelector(`input[name="proj_name_${index}"]`)?.value?.trim() || '';
            const description = item.querySelector(`textarea[name="proj_description_${index}"]`)?.value?.trim() || '';
            const technologies = item.querySelector(`input[name="proj_technologies_${index}"]`)?.value?.trim() || '';
            const link = item.querySelector(`input[name="proj_link_${index}"]`)?.value?.trim() || '';
            const date = item.querySelector(`input[name="proj_date_${index}"]`)?.value || '';
            
            console.log(`Project ${index}:`, { name, description, technologies, link, date });
            
            if (name || description || technologies || link || date) {
                projects.push({
                    name,
                    description,
                    technologies: technologies ? technologies.split(',').map(t => t.trim()).filter(t => t) : [],
                    link,
                    date
                });
            } else {
                console.log(`Skipping project ${index} - all fields empty`);
            }
        });
        
        const projectsInput = document.getElementById('projectsJson');
        if (projectsInput) {
            projectsInput.value = JSON.stringify(projects);
            console.log('Updated projects JSON:', projectsInput.value);
        } else {
            console.error('Projects JSON input field not found!');
        }
    }

    // Load existing projects from JSON
    function loadProjects() {
        const projectsJson = document.getElementById('projectsJson')?.value;
        
        console.log('Loading projects from JSON:', projectsJson);
        
        if (projectsJson && projectsJson.trim() !== '' && projectsJson !== '[]' && projectsJson.trim() !== '""') {
            try {
                const projects = JSON.parse(projectsJson);
                if (Array.isArray(projects) && projects.length > 0) {
                    projects.forEach((proj, arrayIndex) => {
                        // Use the current counter value as the index for the new item
                        const currentIndex = projectCounter;
                        addProject(currentIndex);
                        projectCounter++;
                        
                        // Wait for the DOM to update, then populate the fields
                        // Use a retry mechanism to ensure fields are ready
                        let retries = 0;
                        const maxRetries = 10;
                        const tryPopulate = () => {
                            const nameInput = document.querySelector(`input[name="proj_name_${currentIndex}"]`);
                            const descInput = document.querySelector(`textarea[name="proj_description_${currentIndex}"]`);
                            const techInput = document.querySelector(`input[name="proj_technologies_${currentIndex}"]`);
                            const linkInput = document.querySelector(`input[name="proj_link_${currentIndex}"]`);
                            const dateInput = document.querySelector(`input[name="proj_date_${currentIndex}"]`);
                            
                            if (nameInput || retries >= maxRetries) {
                                if (nameInput) {
                                    nameInput.value = proj.name || '';
                                    nameInput.dispatchEvent(new Event('input', { bubbles: true }));
                                }
                                if (descInput) {
                                    descInput.value = proj.description || '';
                                    descInput.dispatchEvent(new Event('input', { bubbles: true }));
                                }
                                if (techInput) {
                                    techInput.value = proj.technologies ? (Array.isArray(proj.technologies) ? proj.technologies.join(', ') : proj.technologies) : '';
                                    techInput.dispatchEvent(new Event('input', { bubbles: true }));
                                }
                                if (linkInput) {
                                    linkInput.value = proj.link || '';
                                    linkInput.dispatchEvent(new Event('input', { bubbles: true }));
                                }
                                if (dateInput) {
                                    dateInput.value = proj.date || '';
                                    dateInput.dispatchEvent(new Event('input', { bubbles: true }));
                                }
                                console.log(`Loaded project ${currentIndex}:`, proj);
                            } else {
                                retries++;
                                setTimeout(tryPopulate, 50);
                            }
                        };
                        setTimeout(tryPopulate, 100 * (arrayIndex + 1)); // Stagger the timeouts to avoid conflicts
                    });
                    // After all fields are populated, update the JSON to sync with form fields
                    setTimeout(() => {
                        console.log('All projects loaded, fields populated');
                        // Update JSON to ensure it matches the populated form fields
                        updateProjectsJson();
                    }, 300 + (projects.length * 150));
                }
            } catch (e) {
                console.error('Error loading projects:', e);
                // If it's not JSON, try to parse as plain text
                try {
                    // Try to parse old format
                    if (projectsJson.includes('Description:') || projectsJson.includes('Technologies:')) {
                        const projectSections = projectsJson.split(/\n\n+/);
                        projectSections.forEach((section, index) => {
                            if (section.trim()) {
                                projectCounter = Math.max(projectCounter, index + 1);
                                addProject();
                                setTimeout(() => {
                                    const lines = section.split('\n').filter(l => l.trim());
                                    if (lines.length > 0) {
                                        const nameInput = document.querySelector(`input[name="proj_name_${index}"]`);
                                        if (nameInput) nameInput.value = lines[0].trim();
                                        
                                        lines.forEach(line => {
                                            if (line.includes('Description:')) {
                                                const descInput = document.querySelector(`textarea[name="proj_description_${index}"]`);
                                                if (descInput) descInput.value = line.replace('Description:', '').trim();
                                            }
                                            if (line.includes('Technologies:') || line.includes('Tech:')) {
                                                const techInput = document.querySelector(`input[name="proj_technologies_${index}"]`);
                                                if (techInput) techInput.value = line.replace(/Technologies?:/, '').trim();
                                            }
                                            if (line.includes('Link:') || line.startsWith('http')) {
                                                const linkInput = document.querySelector(`input[name="proj_link_${index}"]`);
                                                if (linkInput) linkInput.value = line.replace('Link:', '').trim();
                                            }
                                        });
                                    }
                                }, 100);
                            }
                        });
                        setTimeout(() => updateProjectsJson(), 200);
                    }
                } catch (e2) {
                    console.error('Error parsing projects as text:', e2);
                }
            }
        }
    }
</script>

</body>
</html>