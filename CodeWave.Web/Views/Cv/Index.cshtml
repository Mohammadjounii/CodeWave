    // Calculate CV completion percentage
    function calculateCompletion() {
        const form = document.getElementById('cvForm');
        if (!form) return;
        
        const fields = {
            'fullName': form.querySelector('input[name="fullName"]'),
            'email': form.querySelector('input[name="email"]'),
            'education': form.querySelector('input[name="education"]'),
            'educationDetails': form.querySelector('textarea[name="educationDetails"]'),
            'programmingLanguages': form.querySelector('textarea[name="programmingLanguages"]'),
            'summary': form.querySelector('textarea[name="summary"]'),
            'experience': form.querySelector('textarea[name="experience"]'),
            'certifications': form.querySelector('textarea[name="certifications"]'),
            'projects': form.querySelector('textarea[name="projects"]')
        };
        
        let completed = 0;
        let total = Object.keys(fields).length;
        
        Object.values(fields).forEach(field => {
            if (field && field.value && field.value.trim() !== '') {
                completed++;
            }
        });
        
        const percentage = Math.round((completed / total) * 100);
        updateCompletionUI(percentage);
    }

    // Update completion UI
    function updateCompletionUI(percentage) {
        const bar = document.getElementById('completion-bar');
        const text = document.getElementById('completion-percentage');
        
        if (bar) {
            bar.style.width = percentage + '%';
        }
        
        if (text) {
            text.textContent = percentage + '%';
        }
    }

    // Auto-save to localStorage
    function initializeAutoSave() {
        const form = document.getElementById('cvForm');
        if (!form) return;
        
        // Load saved data
        const savedData = localStorage.getItem('cvFormData');
        if (savedData && !hasFormData()) {
            try {
                const data = JSON.parse(savedData);
                Object.keys(data).forEach(key => {
                    const field = form.querySelector(`[name="${key}"]`);
                    if (field && !field.value) {
                        field.value = data[key];
                    }
                });
                calculateCompletion();
            } catch (e) {
                console.error('Error loading saved data:', e);
            }
        }
        
        // Save on input
        form.addEventListener('input', function(e) {
            if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') {
                saveFormData();
                calculateCompletion();
            }
        });
        
        // Clear saved data on successful submit
        form.addEventListener('submit', function() {
            localStorage.removeItem('cvFormData');
        });
    }

    // Save form data to localStorage
    function saveFormData() {
        const form = document.getElementById('cvForm');
        if (!form) return;
        
        const formData = new FormData(form);
        const data = {};
        
        for (let [key, value] of formData.entries()) {
            if (key !== '__RequestVerificationToken' && key !== 'cvPicture') {
                data[key] = value;
            }
        }
        
        localStorage.setItem('cvFormData', JSON.stringify(data));
    }

    // Check if form has existing data
    function hasFormData() {
        const form = document.getElementById('cvForm');
        if (!form) return false;
        
        const inputs = form.querySelectorAll('input[type="text"], input[type="email"], input[type="tel"], input[type="number"], textarea');
        for (let input of inputs) {
            if (input.value && input.value.trim() !== '') {
                return true;
            }
        }
        return false;
    }

