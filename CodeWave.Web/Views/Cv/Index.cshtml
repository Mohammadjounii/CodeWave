<!-- Profile Picture Modal -->
<div id="profilePictureModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/70 backdrop-blur-sm">
        <div class="bg-white dark:bg-[#111318] rounded-xl p-8 max-w-md w-full mx-4 border border-gray-300 dark:border-[#3b4354] shadow-2xl">
        <div class="flex justify-between items-center mb-6">
            <h2 class="text-gray-900 dark:text-white text-2xl font-bold">Profile Picture</h2>
            <button onclick="closeProfilePictureModal()" class="text-gray-600 dark:text-slate-400 hover:text-gray-900 dark:hover:text-white transition-colors">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        
        <div class="flex flex-col items-center gap-6">
            <!-- Large Profile Picture -->
            <div class="size-48 rounded-full bg-cover bg-center bg-no-repeat border-4 border-primary shadow-lg"
                 id="modalProfilePicture"
                 style='background-image:url("@displayPictureUrl"); background-color: #4a5568;'>
            </div>
            
            <!-- Upload Form -->
            <form id="profilePictureForm" asp-controller="Cv" asp-action="UploadProfilePicture" method="post" enctype="multipart/form-data" class="w-full">
                @Html.AntiForgeryToken()
                <label for="profilePictureInput" class="flex items-center justify-center gap-2 w-full bg-primary text-white h-12 px-6 rounded-lg hover:bg-primary/90 transition-colors cursor-pointer">
                    <span class="material-symbols-outlined">upload</span>
                    <span>Change Picture</span>
                </label>
                <input type="file" id="profilePictureInput" name="profilePicture" accept="image/jpeg,image/jpg,image/png,image/gif" class="hidden" onchange="handleFileSelect(this)" />
            </form>
        </div>
    </div>
</div>

<script>
    function openProfilePictureModal() {
        document.getElementById('profilePictureModal').classList.remove('hidden');
        document.getElementById('profilePictureModal').classList.add('flex');
        document.body.style.overflow = 'hidden';
    }

    function closeProfilePictureModal() {
        document.getElementById('profilePictureModal').classList.add('hidden');
        document.getElementById('profilePictureModal').classList.remove('flex');
        document.body.style.overflow = 'auto';
    }

    function handleFileSelect(input) {
        if (input.files && input.files[0]) {
            var file = input.files[0];
            
            // Validate file size (max 5MB)
            if (file.size > 5 * 1024 * 1024) {
                alert('File size too large. Please upload an image smaller than 5MB.');
                input.value = '';
                return;
            }

            // Validate file type
            var allowedTypes = ['image/jpeg', 'image/jpg', 'image/png', 'image/gif'];
            if (!allowedTypes.includes(file.type)) {
                alert('Invalid file type. Please upload a JPG, PNG, or GIF image.');
                input.value = '';
                return;
            }

            // Preview the image before upload
            var reader = new FileReader();
            reader.onload = function(e) {
                document.getElementById('modalProfilePicture').style.backgroundImage = 'url(' + e.target.result + ')';
            };
            reader.readAsDataURL(file);

            // Submit the form
            document.getElementById('profilePictureForm').submit();
        }
    }

    // Close modal when clicking outside
    document.getElementById('profilePictureModal').addEventListener('click', function(e) {
        if (e.target === this) {
            closeProfilePictureModal();
        }
    });

    // Close modal with Escape key
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
            closeProfilePictureModal();
        }
    });

    // Template selection handlers
    document.querySelectorAll('input[name="template"]').forEach(radio => {
        radio.addEventListener('change', function() {
            // Visual feedback is handled by CSS
        });
    });

    // Upgrade template selection handler
    document.querySelectorAll('input[name="upgradeTemplate"]').forEach(radio => {
        radio.addEventListener('change', function() {
            document.getElementById('upgradeTemplateInput').value = this.value;
        });
    });

    // Tab switching functionality
    function switchTab(tabName) {
        // Hide all tab contents
        document.querySelectorAll('.tab-content').forEach(content => {
            content.classList.add('hidden');
        });

        // Remove active state from all tabs
        document.querySelectorAll('.tab-button').forEach(button => {
            button.classList.remove('text-white', 'border-primary');
            button.classList.add('text-slate-400', 'border-transparent');
        });

        // Show selected tab content
        document.getElementById('content-' + tabName).classList.remove('hidden');

        // Activate selected tab
        const activeTab = document.getElementById('tab-' + tabName);
        activeTab.classList.remove('text-slate-400', 'border-transparent');
        activeTab.classList.add('text-white', 'border-primary');
    }

    // Handle CV file selection
    function handleCVFileSelect(input) {
        if (input.files && input.files[0]) {
            const fileName = input.files[0].name;
            const fileSize = (input.files[0].size / (1024 * 1024)).toFixed(2);
            const display = document.getElementById('file-name-display');
            display.textContent = `Selected: ${fileName} (${fileSize} MB)`;
            display.classList.remove('hidden');
        }
    }

    // Handle CV Picture preview
    function handleCVPicturePreview(input) {
        if (input.files && input.files[0]) {
            const file = input.files[0];
            
            // Validate file size (max 5MB)
            if (file.size > 5 * 1024 * 1024) {
                alert('File size too large. Please upload an image smaller than 5MB.');
                input.value = '';
                return;
            }

            // Validate file type
            const allowedTypes = ['image/jpeg', 'image/jpg', 'image/png', 'image/gif'];
            if (!allowedTypes.includes(file.type)) {
                alert('Invalid file type. Please upload a JPG, PNG, or GIF image.');
                input.value = '';
                return;
            }

            // Preview the image
            const reader = new FileReader();
            reader.onload = function(e) {
                const preview = document.getElementById('cvPicturePreview');
                const previewImg = document.getElementById('cvPicturePreviewImg');
                if (preview && previewImg) {
                    previewImg.src = e.target.result;
                    preview.classList.remove('hidden');
                }
            };
            reader.readAsDataURL(file);
        }
    }

    // Drag and drop for CV picture
    function initializeDragAndDrop() {
        const cvPictureLabel = document.getElementById('cvPictureLabel');
        const cvPictureInput = document.getElementById('cvPictureInput');
        
        if (cvPictureLabel && cvPictureInput) {
            function preventDefaults(e) {
                e.preventDefault();
                e.stopPropagation();
            }

            ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
                cvPictureLabel.addEventListener(eventName, preventDefaults, false);
            });

            ['dragenter', 'dragover'].forEach(eventName => {
                cvPictureLabel.addEventListener(eventName, () => {
                    cvPictureLabel.classList.add('border-primary', 'bg-primary/10');
                }, false);
            });

            ['dragleave', 'drop'].forEach(eventName => {
                cvPictureLabel.addEventListener(eventName, () => {
                    cvPictureLabel.classList.remove('border-primary', 'bg-primary/10');
                }, false);
            });

            cvPictureLabel.addEventListener('drop', (e) => {
                const dt = e.dataTransfer;
                const files = dt.files;
                if (files.length > 0) {
                    cvPictureInput.files = files;
                    handleCVPicturePreview(cvPictureInput);
                }
            }, false);
        }
    }

