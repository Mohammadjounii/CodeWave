
@{
    Layout = null;
}
<!DOCTYPE html>

<html class="" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Onboarding - Language Interest</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24
        }

        .group:has(input:checked) {
            --tw-border-opacity: 1;
            border-color: rgb(19 91 236 / var(--tw-border-opacity));
            --tw-bg-opacity: 1;
            background-color: rgb(19 91 236 / 0.1);
        }

            .group:has(input:checked) .icon {
                --tw-text-opacity: 1;
                color: rgb(19 91 236 / var(--tw-text-opacity));
            }

            .group:has(input:checked) h2 {
                --tw-text-opacity: 1;
                color: rgb(248 250 252 / var(--tw-text-opacity));
            }
        ::-webkit-scrollbar { width: 10px; height: 10px; }
        ::-webkit-scrollbar-track { background: rgba(155,89,245,0.08); border-radius: 999px; }
        ::-webkit-scrollbar-thumb { background: #9b59f5; border-radius: 999px; box-shadow: 0 0 10px rgba(155,89,245,0.9), 0 0 20px rgba(155,89,245,0.5), 0 0 35px rgba(155,89,245,0.2); }
        ::-webkit-scrollbar-thumb:hover { background: #b07eff; box-shadow: 0 0 14px rgba(176,126,255,1), 0 0 28px rgba(176,126,255,0.6), 0 0 45px rgba(155,89,245,0.3); }
        ::-webkit-scrollbar-corner { background: transparent; }
        * { scrollbar-width: thin; scrollbar-color: #9b59f5 rgba(155,89,245,0.08); }
    </style>
    <script id="tailwind-config">
        tailwind.config = {
          darkMode: "class",
          theme: {
            extend: {
              colors: {
                "primary": "#135bec",
                "background-light": "#f6f6f8",
                "background-dark": "#101622",
              },
              fontFamily: {
                "display": ["Space Grotesk", "sans-serif"]
              },
              borderRadius: {"DEFAULT": "0.5rem", "lg": "1rem", "xl": "1.5rem", "full": "9999px"},
              boxShadow: {
                "soft": "0 10px 30px -10px rgba(0, 0, 0, 0.1)",
                "soft-dark": "0 10px 30px -10px rgba(0, 0, 0, 0.3)"
              }
            }
          }
        };
    </script>
</head>
<body class="font-display">
    <div class="relative flex h-auto min-h-screen w-full flex-col items-center justify-center bg-background-light dark:bg-background-dark group/design-root overflow-hidden p-4 sm:p-6 lg:p-8">
        <!-- Background Gradient Blobs -->
        <div class="absolute top-0 left-0 w-96 h-96 bg-primary/20 rounded-full filter blur-3xl opacity-50 animate-blob dark:opacity-30"></div>
        <div class="absolute bottom-0 right-0 w-96 h-96 bg-purple-400/20 rounded-full filter blur-3xl opacity-50 animate-blob animation-delay-4000 dark:opacity-30"></div>
        <div class="layout-container flex h-full grow flex-col justify-center items-center w-full max-w-2xl z-10">
            <div class="layout-content-container flex w-full flex-col items-center justify-center gap-6">
                <!-- Main Content Card -->
                <div class="w-full max-w-lg rounded-xl shadow-soft dark:shadow-soft-dark glass-card p-6 sm:p-8 md:p-10 space-y-8">
                    <!-- ProgressBar -->
                    <div class="flex flex-col gap-2">
                        <div class="flex gap-6 justify-between"><p class="text-slate-600 dark:text-slate-400 text-sm font-medium leading-normal">Step 6 of 6</p></div>
                        <div class="rounded-full bg-slate-200 dark:bg-slate-700 h-2"><div class="h-2 rounded-full bg-primary" style="width: 100%;"></div></div>
                    </div>
                    <div class="space-y-4">
                        <!-- HeadlineText -->
                        <h1 class="text-slate-900 dark:text-white tracking-tight text-3xl sm:text-4xl font-bold leading-tight text-center">What language interests you most?</h1>
                        <!-- BodyText -->
                        <p class="text-slate-600 dark:text-slate-400 text-base font-normal leading-normal text-center">Choose the language you're most interested in learning. This will help us personalize your learning path.</p>
                    </div>
                    <!-- Language Selection -->
                    <form method="post" asp-controller="Welcome" asp-action="LanguageInterest" class="space-y-4">
                        <div class="grid grid-cols-1 gap-4">
                            <!-- Python Option -->
                            <label class="group relative flex cursor-pointer flex-col gap-3 rounded-xl border-2 border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 p-6 transition-all hover:border-primary/50 hover:shadow-lg">
                                <input type="radio" name="preferredLanguage" value="Python" class="sr-only" required />
                                <div class="flex items-center gap-4">
                                    <div class="icon flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-400">
                                        <span class="material-symbols-outlined text-3xl">code</span>
                                    </div>
                                    <div class="flex-1">
                                        <h2 class="text-slate-900 dark:text-white text-lg font-bold leading-tight">Python</h2>
                                        <p class="text-slate-600 dark:text-slate-400 text-sm font-normal leading-normal mt-1">Perfect for beginners. Great for data science, automation, and web development.</p>
                                    </div>
                                </div>
                            </label>

                            <!-- Java Option -->
                            <label class="group relative flex cursor-pointer flex-col gap-3 rounded-xl border-2 border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 p-6 transition-all hover:border-primary/50 hover:shadow-lg">
                                <input type="radio" name="preferredLanguage" value="Java" class="sr-only" required />
                                <div class="flex items-center gap-4">
                                    <div class="icon flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-400">
                                        <span class="material-symbols-outlined text-3xl">coffee</span>
                                    </div>
                                    <div class="flex-1">
                                        <h2 class="text-slate-900 dark:text-white text-lg font-bold leading-tight">Java</h2>
                                        <p class="text-slate-600 dark:text-slate-400 text-sm font-normal leading-normal mt-1">A powerful, object-oriented language widely used in enterprise, Android, and backend development.</p>
                                    </div>
                                </div>
                            </label>
                        </div>
                        <!-- ButtonGroup -->
                        <div class="flex flex-col sm:flex-row gap-3 pt-6">
                            <a asp-controller="Welcome" asp-action="UserSchedule" class="flex w-full sm:w-auto cursor-pointer items-center justify-center overflow-hidden rounded-lg h-12 px-5 bg-slate-200/80 dark:bg-slate-500/30 text-slate-700 dark:text-slate-300 text-base font-bold leading-normal tracking-wide hover:bg-slate-300/80 dark:hover:bg-slate-500/50 transition-colors duration-200">
                                <span class="truncate">Back</span>
                            </a>
                            <button type="submit" class="flex w-full sm:flex-1 cursor-pointer items-center justify-center overflow-hidden rounded-lg h-12 px-5 bg-primary text-white text-base font-bold leading-normal tracking-wide hover:bg-primary/90 transition-colors duration-200 shadow-lg shadow-primary/30">
                                <span class="truncate">Continue to Assessment</span>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
    <style>
        .glass-card {
            background: rgba(255, 255, 255, 0.2);
            backdrop-filter: blur(16px) saturate(180%);
            -webkit-backdrop-filter: blur(16px) saturate(180%);
            border: 1px solid rgba(255, 255, 255, 0.125);
        }

        .dark .glass-card {
            background: rgba(30, 41, 59, 0.5);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }
    </style>
</body>
</html>



