
@{
    Layout = null;
}


<!DOCTYPE html>

<html class="" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Onboarding - Goal Setting</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24
        }
        ::-webkit-scrollbar { width: 10px; height: 10px; }
        ::-webkit-scrollbar-track { background: rgba(155,89,245,0.08); border-radius: 999px; }
        ::-webkit-scrollbar-thumb { background: #9b59f5; border-radius: 999px; box-shadow: 0 0 10px rgba(155,89,245,0.9), 0 0 20px rgba(155,89,245,0.5), 0 0 35px rgba(155,89,245,0.2); }
        ::-webkit-scrollbar-thumb:hover { background: #b07eff; box-shadow: 0 0 14px rgba(176,126,255,1), 0 0 28px rgba(176,126,255,0.6), 0 0 45px rgba(155,89,245,0.3); }
        ::-webkit-scrollbar-corner { background: transparent; }
        * { scrollbar-width: thin; scrollbar-color: #9b59f5 rgba(155,89,245,0.08); }
    </style>
    <script>tailwind.config = {darkMode: "class", theme: {extend: {colors: {primary: "#135bec", "background-light": "#f6f6f8", "background-dark": "#101622"}, fontFamily: {display: "Space Grotesk"}, borderRadius: {DEFAULT: "0.5rem", lg: "1rem", xl: "1.5rem", full: "9999px"}}}};</script>
</head>
<body class="bg-background-light dark:bg-background-dark font-display">
    <div class="relative flex min-h-screen w-full flex-col items-center justify-center p-4 sm:p-6 lg:p-8">
        <!-- Background Gradient -->
        <div class="absolute inset-0 z-0 overflow-hidden">
            <div class="absolute -top-1/4 left-0 h-1/2 w-1/2 rounded-full bg-primary/20 blur-3xl dark:bg-primary/10"></div>
            <div class="absolute -bottom-1/4 right-0 h-1/2 w-1/2 rounded-full bg-cyan-500/20 blur-3xl dark:bg-cyan-500/10"></div>
        </div>
        <!-- Main Content Panel -->
        <div class="relative z-10 w-full max-w-4xl rounded-xl border border-white/10 bg-white/40 p-6 shadow-2xl backdrop-blur-2xl dark:bg-black/20 sm:p-8 md:p-12">
            <div class="flex flex-col gap-8">
                <!-- ProgressBar -->
                <div class="flex flex-col gap-3">
                    <div class="flex justify-between">
                        <p class="text-sm font-medium text-slate-600 dark:text-slate-400">Step 2 of 6</p>
                    </div>
                    <div class="h-2 rounded-full bg-slate-200 dark:bg-slate-700">
                        <div class="h-2 rounded-full bg-primary" style="width: 33%;"></div>
                    </div>
                </div>
                <!-- PageHeading -->
                <div class="flex flex-wrap justify-between gap-3">
                    <div class="flex flex-col gap-2">
                        <h1 class="text-3xl font-bold tracking-tight text-slate-900 dark:text-white sm:text-4xl">What is your main goal?</h1>
                        <p class="text-base text-slate-600 dark:text-slate-400">This will help us personalize your learning path.</p>
                    </div>
                </div>
                <!-- TextGrid -->
                <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
                    <button class="flex flex-1 flex-col gap-4 rounded-xl border-2 border-primary bg-primary/10 p-5 text-left ring-2 ring-primary ring-offset-2 ring-offset-background-light dark:ring-offset-background-dark dark:bg-primary/20">
                        <span class="material-symbols-outlined text-primary text-3xl">work</span>
                        <div class="flex flex-col gap-1">
                            <h2 class="text-base font-bold text-slate-900 dark:text-white">Get a Job</h2>
                            <p class="text-sm text-slate-600 dark:text-slate-300">Land a role in the tech industry.</p>
                        </div>
                    </button>
                    <button class="flex flex-1 flex-col gap-4 rounded-xl border border-slate-300 bg-slate-50 p-5 text-left transition-all hover:border-primary/50 hover:bg-primary/5 dark:border-slate-700 dark:bg-slate-800/50 dark:hover:border-primary/50 dark:hover:bg-primary/10">
                        <span class="material-symbols-outlined text-slate-500 dark:text-slate-400 text-3xl">groups</span>
                        <div class="flex flex-col gap-1">
                            <h2 class="text-base font-bold text-slate-900 dark:text-white">Start Freelancing</h2>
                            <p class="text-sm text-slate-600 dark:text-slate-400">Become your own boss.</p>
                        </div>
                    </button>
                    <button class="flex flex-1 flex-col gap-4 rounded-xl border border-slate-300 bg-slate-50 p-5 text-left transition-all hover:border-primary/50 hover:bg-primary/5 dark:border-slate-700 dark:bg-slate-800/50 dark:hover:border-primary/50 dark:hover:bg-primary/10">
                        <span class="material-symbols-outlined text-slate-500 dark:text-slate-400 text-3xl">developer_mode</span>
                        <div class="flex flex-col gap-1">
                            <h2 class="text-base font-bold text-slate-900 dark:text-white">Build My Own App</h2>
                            <p class="text-sm text-slate-600 dark:text-slate-400">Bring your ideas to life.</p>
                        </div>
                    </button>
                    <button class="flex flex-1 flex-col gap-4 rounded-xl border border-slate-300 bg-slate-50 p-5 text-left transition-all hover:border-primary/50 hover:bg-primary/5 dark:border-slate-700 dark:bg-slate-800/50 dark:hover:border-primary/50 dark:hover:bg-primary/10">
                        <span class="material-symbols-outlined text-slate-500 dark:text-slate-400 text-3xl">school</span>
                        <div class="flex flex-col gap-1">
                            <h2 class="text-base font-bold text-slate-900 dark:text-white">Prepare for University</h2>
                            <p class="text-sm text-slate-600 dark:text-slate-400">Succeed in your studies.</p>
                        </div>
                    </button>
                    <button class="flex flex-1 flex-col gap-4 rounded-xl border border-slate-300 bg-slate-50 p-5 text-left transition-all hover:border-primary/50 hover:bg-primary/5 dark:border-slate-700 dark:bg-slate-800/50 dark:hover:border-primary/50 dark:hover:bg-primary/10">
                        <span class="material-symbols-outlined text-slate-500 dark:text-slate-400 text-3xl">auto_awesome</span>
                        <div class="flex flex-col gap-1">
                            <h2 class="text-base font-bold text-slate-900 dark:text-white">Personal Growth</h2>
                            <p class="text-sm text-slate-600 dark:text-slate-400">Learn for fun and curiosity.</p>
                        </div>
                    </button>
                    <button class="flex flex-1 flex-col gap-4 rounded-xl border border-slate-300 bg-slate-50 p-5 text-left transition-all hover:border-primary/50 hover:bg-primary/5 dark:border-slate-700 dark:bg-slate-800/50 dark:hover:border-primary/50 dark:hover:bg-primary/10">
                        <span class="material-symbols-outlined text-slate-500 dark:text-slate-400 text-3xl">trending_up</span>
                        <div class="flex flex-col gap-1">
                            <h2 class="text-base font-bold text-slate-900 dark:text-white">Upskill at Work</h2>
                            <p class="text-sm text-slate-600 dark:text-slate-400">Advance in your current career.</p>
                        </div>
                    </button>
                </div>
                <!-- ButtonGroup -->
                <form method="post" asp-controller="Welcome" asp-action="UserGoal">
                    <input type="hidden" name="goal" id="selectedGoal" value="" />
                    <div class="mt-4 flex flex-col-reverse justify-between gap-4 sm:flex-row">
                        <a asp-controller="Welcome" asp-action="UserInterest" class="flex h-12 min-w-[84px] cursor-pointer items-center justify-center overflow-hidden rounded-lg bg-slate-200 px-5 text-base font-bold text-slate-700 transition-colors hover:bg-slate-300 dark:bg-slate-800 dark:text-slate-300 dark:hover:bg-slate-700">
                            <span class="truncate">Back</span>
                        </a>
                        <button type="submit" class="flex h-12 min-w-[84px] flex-1 cursor-pointer items-center justify-center overflow-hidden rounded-lg bg-primary px-5 text-base font-bold text-white shadow-lg shadow-primary/30 transition-colors hover:bg-primary/90 sm:flex-none">
                            <span class="truncate">Next</span>
                        </button>
                    </div>
                </form>
                <script>
                    document.querySelectorAll('button[class*="rounded-xl border"]').forEach(btn => {
                        btn.addEventListener('click', function() {
                            document.querySelectorAll('button[class*="rounded-xl border"]').forEach(b => {
                                b.classList.remove('border-2', 'border-primary', 'bg-primary/10', 'ring-2', 'ring-primary');
                                b.classList.add('border', 'border-slate-300', 'bg-slate-50');
                            });
                            this.classList.remove('border', 'border-slate-300', 'bg-slate-50');
                            this.classList.add('border-2', 'border-primary', 'bg-primary/10', 'ring-2', 'ring-primary');
                            document.getElementById('selectedGoal').value = this.querySelector('h2').textContent;
                        });
                    });
                </script>
            </div>
        </div>
    </div>
</body>
</html>
