
@{
    Layout = null;
}
<!DOCTYPE html>

<html class="" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Onboarding - Skill Level</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght@400,FILL@0..1&amp;display=swap" rel="stylesheet" />
    <script>
        tailwind.config = {
          darkMode: "class",
          theme: {
            extend: {
              colors: {
                "primary": "#135bec",
                "background-light": "#f6f6f8",
                "background-dark": "#101622",
              },
              fontFamily: {
                "display": ["Space Grotesk", "sans-serif"]
              },
              borderRadius: {
                "DEFAULT": "0.5rem",
                "lg": "1rem",
                "xl": "1.5rem",
                "full": "9999px"
              },
            },
          },
        }
    </script>
    <style>
        .glassmorphism {
            background: rgba(255, 255, 255, 0.1);
            -webkit-backdrop-filter: blur(10px);
            backdrop-filter: blur(10px);
        }

        .dark .glassmorphism {
            background: rgba(41, 51, 72, 0.3);
        }

        .background-shapes {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            overflow: hidden;
            z-index: 0;
        }

        .shape-1 {
            position: absolute;
            top: 10%;
            left: 5%;
            width: 300px;
            height: 300px;
            background: radial-gradient(circle, rgba(19, 91, 236, 0.2), transparent 70%);
            border-radius: 50%;
            filter: blur(50px);
        }

        .shape-2 {
            position: absolute;
            bottom: 15%;
            right: 10%;
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(19, 91, 236, 0.15), transparent 70%);
            border-radius: 50%;
            filter: blur(60px);
        }

        .radio-card:has(input:checked) {
            border-color: #135bec;
            box-shadow: 0 0 0 2px #135bec40;
        }

            .radio-card:has(input:checked) .material-symbols-outlined {
                color: #135bec;
            }

            .radio-card:has(input:checked) p:first-child {
                color: #135bec;
            }

        .dark .radio-card:has(input:checked) p:first-child {
            color: #135bec;
        }

    </style>
</head>
<body class="font-display">
    <div class="relative flex min-h-screen w-full flex-col items-center justify-center bg-background-light dark:bg-background-dark group/design-root overflow-hidden">
        <div class="background-shapes">
            <div class="shape-1"></div>
            <div class="shape-2"></div>
        </div>
        <div class="relative z-10 flex h-full w-full max-w-4xl grow flex-col justify-center px-4 py-10 sm:px-6 lg:px-8">
            <div class="flex flex-col gap-8">
                <!-- Progress Bar -->
                <div class="flex flex-col gap-3">
                    <div class="flex justify-between">
                        <p class="text-sm font-medium text-slate-600 dark:text-slate-400">Step 2 of 4</p>
                    </div>
                    <div class="h-2 w-full rounded-full bg-slate-200 dark:bg-slate-700">
                        <div class="h-2 rounded-full bg-primary" style="width: 50%;"></div>
                    </div>
                </div>
                <!-- Page Heading -->
                <div class="flex flex-col items-center gap-3 text-center">
                    <h1 class="text-3xl font-bold tracking-tight text-slate-900 dark:text-white sm:text-4xl md:text-5xl">What's your coding level?</h1>
                    <p class="text-base text-slate-600 dark:text-slate-400">This helps us personalize your learning path.</p>
                </div>
                <!-- Radio List as Cards -->
                <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
                    <label class="radio-card group relative cursor-pointer rounded-xl border border-solid border-slate-300 dark:border-slate-700 p-6 text-center transition-all duration-300 hover:border-primary/50 hover:shadow-lg glassmorphism">
                        <input class="absolute h-0 w-0 opacity-0" name="skill-level" type="radio" />
                        <div class="flex flex-col items-center gap-4">
                            <div class="flex h-16 w-16 items-center justify-center rounded-lg bg-slate-200/50 dark:bg-slate-800/50">
                                <span class="material-symbols-outlined text-3xl text-slate-700 dark:text-slate-300 transition-colors">eco</span>
                            </div>
                            <div class="flex grow flex-col gap-1">
                                <p class="text-lg font-bold text-slate-800 dark:text-slate-100 transition-colors">Beginner</p>
                                <p class="text-sm text-slate-600 dark:text-slate-400">I'm new to coding or just starting out.</p>
                            </div>
                        </div>
                    </label>
                    <label class="radio-card group relative cursor-pointer rounded-xl border border-solid border-slate-300 dark:border-slate-700 p-6 text-center transition-all duration-300 hover:border-primary/50 hover:shadow-lg glassmorphism">
                        <input checked="" class="absolute h-0 w-0 opacity-0" name="skill-level" type="radio" />
                        <div class="flex flex-col items-center gap-4">
                            <div class="flex h-16 w-16 items-center justify-center rounded-lg bg-slate-200/50 dark:bg-slate-800/50">
                                <span class="material-symbols-outlined text-3xl text-slate-700 dark:text-slate-300 transition-colors">code</span>
                            </div>
                            <div class="flex grow flex-col gap-1">
                                <p class="text-lg font-bold text-slate-800 dark:text-slate-100 transition-colors">Intermediate</p>
                                <p class="text-sm text-slate-600 dark:text-slate-400">I know the basics and want to build real projects.</p>
                            </div>
                        </div>
                    </label>
                    <label class="radio-card group relative cursor-pointer rounded-xl border border-solid border-slate-300 dark:border-slate-700 p-6 text-center transition-all duration-300 hover:border-primary/50 hover:shadow-lg glassmorphism">
                        <input class="absolute h-0 w-0 opacity-0" name="skill-level" type="radio" />
                        <div class="flex flex-col items-center gap-4">
                            <div class="flex h-16 w-16 items-center justify-center rounded-lg bg-slate-200/50 dark:bg-slate-800/50">
                                <span class="material-symbols-outlined text-3xl text-slate-700 dark:text-slate-300 transition-colors">rocket_launch</span>
                            </div>
                            <div class="flex grow flex-col gap-1">
                                <p class="text-lg font-bold text-slate-800 dark:text-slate-100 transition-colors">Advanced</p>
                                <p class="text-sm text-slate-600 dark:text-slate-400">I'm experienced and looking to master new skills.</p>
                            </div>
                        </div>
                    </label>
                </div>
                <!-- Button Group -->
                <form method="post" asp-controller="Welcome" asp-action="UserSkill">
                    <input type="hidden" name="skillLevel" id="selectedSkillLevel" value="Intermediate" />
                    <div class="flex flex-col-reverse justify-between gap-3 pt-4 sm:flex-row">
                        <a asp-controller="Welcome" asp-action="UserGoal" class="flex h-12 min-w-[84px] cursor-pointer items-center justify-center overflow-hidden rounded-xl bg-slate-200 px-5 text-base font-bold text-slate-700 ring-1 ring-inset ring-slate-300 transition-colors hover:bg-slate-300 dark:bg-slate-800 dark:text-slate-200 dark:ring-slate-700 dark:hover:bg-slate-700">
                            <span class="truncate">Back</span>
                        </a>
                        <button type="submit" class="flex h-12 min-w-[84px] cursor-pointer items-center justify-center overflow-hidden rounded-xl bg-primary px-5 text-base font-bold text-white shadow-lg shadow-primary/30 transition-colors hover:bg-primary/90">
                            <span class="truncate">Next</span>
                        </button>
                    </div>
                </form>
                <script>
                    document.querySelectorAll('label.radio-card').forEach(label => {
                        label.addEventListener('click', function() {
                            const input = this.querySelector('input[type="radio"]');
                            input.checked = true;
                            const skillText = this.querySelector('p.text-lg').textContent;
                            document.getElementById('selectedSkillLevel').value = skillText;
                        });
                    });
                </script>
            </div>
        </div>
    </div>
</body>
</html>