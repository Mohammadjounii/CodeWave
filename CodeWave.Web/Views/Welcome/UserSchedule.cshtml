
@{
    Layout = null;
}
<!DOCTYPE html>

<html class="" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Onboarding - Weekly Commitment</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    <script>tailwind.config = {darkMode: "class", theme: {extend: {colors: {primary: "#135bec", "background-light": "#f6f6f8", "background-dark": "#101622"}, fontFamily: {display: "Space Grotesk"}, borderRadius: {DEFAULT: "0.5rem", lg: "1rem", xl: "1.5rem", full: "9999px"}, boxShadow: {soft: "0 10px 30px -10px rgba(0, 0, 0, 0.1)", "soft-dark": "0 10px 30px -10px rgba(0, 0, 0, 0.3)"}}}};</script>
    <style>
        .glass-card {
            background: rgba(255, 255, 255, 0.2);
            backdrop-filter: blur(16px) saturate(180%);
            -webkit-backdrop-filter: blur(16px) saturate(180%);
            border: 1px solid rgba(255, 255, 255, 0.125);
        }

        .dark .glass-card {
            background: rgba(30, 41, 59, 0.5);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }
        ::-webkit-scrollbar { width: 10px; height: 10px; }
        ::-webkit-scrollbar-track { background: rgba(155,89,245,0.08); border-radius: 999px; }
        ::-webkit-scrollbar-thumb { background: #9b59f5; border-radius: 999px; box-shadow: 0 0 10px rgba(155,89,245,0.9), 0 0 20px rgba(155,89,245,0.5), 0 0 35px rgba(155,89,245,0.2); }
        ::-webkit-scrollbar-thumb:hover { background: #b07eff; box-shadow: 0 0 14px rgba(176,126,255,1), 0 0 28px rgba(176,126,255,0.6), 0 0 45px rgba(155,89,245,0.3); }
        ::-webkit-scrollbar-corner { background: transparent; }
        * { scrollbar-width: thin; scrollbar-color: #9b59f5 rgba(155,89,245,0.08); }
    </style>
</head>
<body class="font-display">
    <div class="relative flex h-auto min-h-screen w-full flex-col items-center justify-center bg-background-light dark:bg-background-dark group/design-root overflow-hidden p-4 sm:p-6 lg:p-8">
        <!-- Background Gradient Blobs -->
        <div class="absolute top-0 left-0 w-96 h-96 bg-primary/20 rounded-full filter blur-3xl opacity-50 animate-blob dark:opacity-30"></div>
        <div class="absolute bottom-0 right-0 w-96 h-96 bg-purple-400/20 rounded-full filter blur-3xl opacity-50 animate-blob animation-delay-4000 dark:opacity-30"></div>
        <div class="layout-container flex h-full grow flex-col justify-center items-center w-full max-w-2xl z-10">
            <div class="layout-content-container flex w-full flex-col items-center justify-center gap-6">
                <!-- Main Content Card -->
                <div class="w-full max-w-lg rounded-xl shadow-soft dark:shadow-soft-dark glass-card p-6 sm:p-8 md:p-10 space-y-8">
                    <!-- ProgressBar -->
                    <div class="flex flex-col gap-2">
                        <div class="flex gap-6 justify-between"><p class="text-slate-600 dark:text-slate-400 text-sm font-medium leading-normal">Step 5 of 6</p></div>
                        <div class="rounded-full bg-slate-200 dark:bg-slate-700 h-2"><div class="h-2 rounded-full bg-primary" style="width: 83%;"></div></div>
                    </div>
                    <div class="space-y-4">
                        <!-- HeadlineText -->
                        <h1 class="text-slate-900 dark:text-white tracking-tight text-3xl sm:text-4xl font-bold leading-tight text-center">What's your weekly goal?</h1>
                        <!-- BodyText -->
                        <p class="text-slate-600 dark:text-slate-400 text-base font-normal leading-normal text-center">Consistency is key. Even a few hours a week makes a big difference.</p>
                    </div>
                    <!-- Slider -->
                    <div class="pt-4 pb-2">
                        <div class="relative w-full">
                            <div class="text-center mb-4">
                                <p class="text-3xl font-bold text-slate-900 dark:text-white">
                                    <span class="text-primary">7</span> hours / week
                                </p>
                            </div>
                            <div class="relative flex h-4 w-full items-center">
                                <input class="w-full h-2 bg-slate-200 dark:bg-slate-700 rounded-full appearance-none cursor-pointer" max="20" min="1" style="--thumb-color: var(--color-primary, #135bec); --track-color: var(--color-primary, #135bec);" type="range" value="7" />
                            </div>
                            <div class="flex justify-between text-xs text-slate-500 dark:text-slate-400 mt-2 px-1">
                                <span>1hr</span>
                                <span>20+ hrs</span>
                            </div>
                        </div>
                    </div>
                    <!-- ButtonGroup -->
                    <form method="post" asp-controller="Welcome" asp-action="UserSchedule">
                        <input type="hidden" name="weeklyHours" id="weeklyHours" value="7" />
                        <div class="flex flex-col sm:flex-row gap-3 pt-6">
                            <a asp-controller="Welcome" asp-action="UserMotivation" class="flex w-full sm:w-auto cursor-pointer items-center justify-center overflow-hidden rounded-lg h-12 px-5 bg-slate-200/80 dark:bg-slate-500/30 text-slate-700 dark:text-slate-300 text-base font-bold leading-normal tracking-wide hover:bg-slate-300/80 dark:hover:bg-slate-500/50 transition-colors duration-200">
                                <span class="truncate">Back</span>
                            </a>
                            <button type="submit" class="flex w-full sm:flex-1 cursor-pointer items-center justify-center overflow-hidden rounded-lg h-12 px-5 bg-primary text-white text-base font-bold leading-normal tracking-wide hover:bg-primary/90 transition-colors duration-200 shadow-lg shadow-primary/30">
                                <span class="truncate">Ready To Be Coding</span>
                            </button>
                        </div>
                    </form>
                    <script>
                        document.querySelector('input[type="range"]').addEventListener('input', function() {
                            const hours = this.value;
                            document.querySelector('span.text-primary').textContent = hours;
                            document.getElementById('weeklyHours').value = hours;
                        });
                    </script>
                </div>
            </div>
        </div>
    </div>
</body>
</html>