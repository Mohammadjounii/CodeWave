
@{
    Layout = null;
}
<!DOCTYPE html>

<html class="" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Onboarding - Interest Selection</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24
        }

        .group:has(input:checked) {
            --tw-border-opacity: 1;
            border-color: rgb(19 91 236 / var(--tw-border-opacity));
            --tw-bg-opacity: 1;
            background-color: rgb(19 91 236 / 0.1);
        }

            .group:has(input:checked) .icon {
                --tw-text-opacity: 1;
                color: rgb(19 91 236 / var(--tw-text-opacity));
            }

            .group:has(input:checked) h2 {
                --tw-text-opacity: 1;
                color: rgb(248 250 252 / var(--tw-text-opacity));
            }
    </style>
    <script id="tailwind-config">
        tailwind.config = {
          darkMode: "class",
          theme: {
            extend: {
              colors: {
                "primary": "#135bec",
                "background-light": "#f6f6f8",
                "background-dark": "#101622",
              },
              fontFamily: {
                "display": ["Space Grotesk", "sans-serif"]
              },
              borderRadius: {"DEFAULT": "0.5rem", "lg": "1rem", "xl": "1.5rem", "full": "9999px"},
            },
          },
        }
    </script>
</head>
<body class="font-display">
    <div class="relative flex min-h-screen w-full flex-col items-center justify-center bg-background-light dark:bg-background-dark p-4 sm:p-6 lg:p-8">
        <div class="absolute inset-0 z-0 overflow-hidden">
            <div class="absolute left-[-10%] top-[20%] h-96 w-96 rounded-full bg-primary/20 blur-[120px]"></div>
            <div class="absolute bottom-[10%] right-[-10%] h-96 w-96 rounded-full bg-purple-500/20 blur-[120px]"></div>
        </div>
        <main class="relative z-10 flex w-full max-w-4xl flex-col gap-8 rounded-xl bg-white/50 p-6 backdrop-blur-xl dark:bg-black/20 md:p-12">
            <div class="flex flex-col gap-3">
                <div class="flex justify-between gap-6">
                    <p class="text-sm font-medium text-slate-600 dark:text-slate-400">Step 2 of 4</p>
                </div>
                <div class="h-1.5 w-full rounded-full bg-slate-200 dark:bg-slate-700">
                    <div class="h-1.5 w-1/2 rounded-full bg-primary"></div>
                </div>
            </div>
            <div class="flex flex-wrap items-center justify-between gap-4">
                <div class="flex flex-col gap-2">
                    <h1 class="text-3xl font-bold text-slate-900 dark:text-white sm:text-4xl">What are you interested in learning?</h1>
                    <p class="text-base font-normal text-slate-600 dark:text-slate-400">Select all that apply. This will help us personalize your learning journey.</p>
                </div>
            </div>
            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
                <label class="group relative cursor-pointer rounded-xl border border-slate-300 bg-white/50 p-5 transition-all duration-200 hover:border-primary/80 dark:border-slate-700 dark:bg-slate-800/50" for="web-dev">
                    <input class="peer absolute h-full w-full opacity-0" id="web-dev" type="checkbox" />
                    <div class="flex flex-col gap-4">
                        <span class="material-symbols-outlined icon text-3xl text-slate-500 dark:text-slate-400">code</span>
                        <div class="flex flex-col gap-1">
                            <h2 class="text-lg font-bold text-slate-800 dark:text-slate-200">Web Development</h2>
                            <p class="text-sm font-normal text-slate-600 dark:text-slate-400">Build modern websites and web applications.</p>
                        </div>
                    </div>
                </label>
                <label class="group relative cursor-pointer rounded-xl border border-slate-300 bg-white/50 p-5 transition-all duration-200 hover:border-primary/80 dark:border-slate-700 dark:bg-slate-800/50" for="mobile-apps">
                    <input class="peer absolute h-full w-full opacity-0" id="mobile-apps" type="checkbox" />
                    <div class="flex flex-col gap-4">
                        <span class="material-symbols-outlined icon text-3xl text-slate-500 dark:text-slate-400">phone_iphone</span>
                        <div class="flex flex-col gap-1">
                            <h2 class="text-lg font-bold text-slate-800 dark:text-slate-200">Mobile Apps</h2>
                            <p class="text-sm font-normal text-slate-600 dark:text-slate-400">Create apps for iOS and Android.</p>
                        </div>
                    </div>
                </label>
                <label class="group relative cursor-pointer rounded-xl border border-slate-300 bg-white/50 p-5 transition-all duration-200 hover:border-primary/80 dark:border-slate-700 dark:bg-slate-800/50" for="game-dev">
                    <input class="peer absolute h-full w-full opacity-0" id="game-dev" type="checkbox" />
                    <div class="flex flex-col gap-4">
                        <span class="material-symbols-outlined icon text-3xl text-slate-500 dark:text-slate-400">stadia_controller</span>
                        <div class="flex flex-col gap-1">
                            <h2 class="text-lg font-bold text-slate-800 dark:text-slate-200">Game Development</h2>
                            <p class="text-sm font-normal text-slate-600 dark:text-slate-400">Design and develop interactive games.</p>
                        </div>
                    </div>
                </label>
                <label class="group relative cursor-pointer rounded-xl border border-slate-300 bg-white/50 p-5 transition-all duration-200 hover:border-primary/80 dark:border-slate-700 dark:bg-slate-800/50" for="ai-ml">
                    <input class="peer absolute h-full w-full opacity-0" id="ai-ml" type="checkbox" />
                    <div class="flex flex-col gap-4">
                        <span class="material-symbols-outlined icon text-3xl text-slate-500 dark:text-slate-400">neurology</span>
                        <div class="flex flex-col gap-1">
                            <h2 class="text-lg font-bold text-slate-800 dark:text-slate-200">AI &amp; Machine Learning</h2>
                            <p class="text-sm font-normal text-slate-600 dark:text-slate-400">Explore the future of artificial intelligence.</p>
                        </div>
                    </div>
                </label>
                <label class="group relative cursor-pointer rounded-xl border border-slate-300 bg-white/50 p-5 transition-all duration-200 hover:border-primary/80 dark:border-slate-700 dark:bg-slate-800/50" for="cybersecurity">
                    <input class="peer absolute h-full w-full opacity-0" id="cybersecurity" type="checkbox" />
                    <div class="flex flex-col gap-4">
                        <span class="material-symbols-outlined icon text-3xl text-slate-500 dark:text-slate-400">security</span>
                        <div class="flex flex-col gap-1">
                            <h2 class="text-lg font-bold text-slate-800 dark:text-slate-200">Cybersecurity</h2>
                            <p class="text-sm font-normal text-slate-600 dark:text-slate-400">Learn to protect systems and data.</p>
                        </div>
                    </div>
                </label>
                <label class="group relative cursor-pointer rounded-xl border border-slate-300 bg-white/50 p-5 transition-all duration-200 hover:border-primary/80 dark:border-slate-700 dark:bg-slate-800/50" for="data-science">
                    <input class="peer absolute h-full w-full opacity-0" id="data-science" type="checkbox" />
                    <div class="flex flex-col gap-4">
                        <span class="material-symbols-outlined icon text-3xl text-slate-500 dark:text-slate-400">database</span>
                        <div class="flex flex-col gap-1">
                            <h2 class="text-lg font-bold text-slate-800 dark:text-slate-200">Data Science</h2>
                            <p class="text-sm font-normal text-slate-600 dark:text-slate-400">Analyze data to find insights.</p>
                        </div>
                    </div>
                </label>
            </div>
            <form method="post" asp-controller="Welcome" asp-action="UserInterest">
                <div class="mt-4 flex flex-col-reverse items-center gap-3 sm:flex-row sm:justify-end">
                    <a asp-controller="Welcome" asp-action="UserInterest" class="flex h-12 w-full cursor-pointer items-center justify-center rounded-xl bg-slate-200 px-6 text-base font-bold text-slate-700 transition-colors hover:bg-slate-300 dark:bg-slate-800 dark:text-slate-200 dark:hover:bg-slate-700 sm:w-auto">
                        <span class="truncate">Skip</span>
                    </a>
                    <button type="submit" class="flex h-12 w-full cursor-pointer items-center justify-center rounded-xl bg-primary px-6 text-base font-bold text-white transition-colors hover:bg-primary/90 sm:w-auto">
                        <span class="truncate">Next</span>
                    </button>
                </div>
            </form>
        </main>
    </div>
</body>
</html>
