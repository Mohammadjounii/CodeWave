@using CodeWave.Application.DTOs
@model QuizResultDto
@{
    Layout = null;
    var quiz = ViewBag.Quiz as QuizDto;
    var attempt = ViewBag.Attempt as QuizAttemptDto;
}

<!DOCTYPE html>
<html class="light dark" lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>Quiz Results - CodeWave</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        primary: "#9d64cf",
                        "background-light": "#f7f6f8",
                        "background-dark": "#19141e"
                    },
                    fontFamily: {
                        display: "Inter"
                    },
                    borderRadius: {
                        DEFAULT: "0.25rem",
                        lg: "0.5rem",
                        xl: "0.75rem",
                        full: "9999px"
                    }
                }
            }
        };
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
    </style>
</head>
<body class="bg-background-light dark:bg-background-dark font-display text-[#151118] dark:text-white transition-colors duration-200">
    <!-- Main Content Layout -->
    <main class="flex min-h-screen flex-col py-8 px-4 sm:px-6 lg:px-8">
        <div class="w-full max-w-5xl mx-auto space-y-8">
            <!-- Breadcrumbs -->
            <nav class="flex flex-wrap items-center text-sm text-[#776189] dark:text-gray-400">
                <a class="hover:text-primary transition-colors" href="/Home">Dashboard</a>
                <span class="mx-2 text-gray-400">/</span>
                <a class="hover:text-primary transition-colors" href="@Url.Action("Index", "Quiz")">Quizzes</a>
                <span class="mx-2 text-gray-400">/</span>
                <span class="font-medium text-[#151118] dark:text-white">Results</span>
            </nav>

            <!-- Results Header -->
            <div class="bg-white dark:bg-[#1e1427] rounded-xl p-8 shadow-sm border border-[#e5e7eb] dark:border-gray-800 text-center">
                <div class="mb-6">
                    @if (Model.IsPassed)
                    {
                        <div class="inline-block p-4 rounded-full bg-green-100 dark:bg-green-900/30 mb-4">
                            <span class="material-symbols-outlined text-green-600 dark:text-green-400 text-6xl">celebration</span>
                        </div>
                    }
                    else
                    {
                        <div class="inline-block p-4 rounded-full bg-red-100 dark:bg-red-900/30 mb-4">
                            <span class="material-symbols-outlined text-red-600 dark:text-red-400 text-6xl">sentiment_dissatisfied</span>
                        </div>
                    }
                </div>
                <h1 class="text-3xl font-bold text-[#151118] dark:text-white mb-2">
                    @(Model.IsPassed ? "🎉 Congratulations!" : "Keep Learning!")
                </h1>
                <p class="text-[#776189] dark:text-gray-400 mb-6">@(quiz?.Title ?? "Quiz Results")</p>
                
                <!-- Score Display -->
                <div class="mb-6">
                    <div class="text-6xl font-bold mb-2 @(Model.IsPassed ? "text-green-600 dark:text-green-400" : "text-red-600 dark:text-red-400")">
                        @Math.Round(Model.Score, 0)%
                    </div>
                    <p class="text-lg text-[#776189] dark:text-gray-400">
                        @Model.CorrectAnswers out of @Model.TotalQuestions questions correct
                    </p>
                </div>

                <!-- Progress Bar -->
                <div class="mb-6">
                    <div class="h-3 w-full bg-[#f2f0f4] dark:bg-[#2a2035] rounded-full overflow-hidden max-w-md mx-auto">
                        <div class="h-full @(Model.IsPassed ? "bg-green-500" : "bg-red-500") rounded-full transition-all duration-1000" 
                             style="width: @Model.Score%"></div>
                    </div>
                </div>

                <!-- Stats -->
                <div class="flex items-center justify-center gap-6 text-sm text-[#776189] dark:text-gray-400 flex-wrap">
                    <div class="flex items-center gap-2">
                        <span class="material-symbols-outlined text-[18px]">schedule</span>
                        <span>@Model.TimeSpentMinutes minutes</span>
                    </div>
                    @if (quiz != null)
                    {
                        <div class="flex items-center gap-2">
                            <span class="material-symbols-outlined text-[18px]">target</span>
                            <span>Passing: @quiz.PassingScore%</span>
                        </div>
                    }
                    <div class="flex items-center gap-2">
                        <span class="material-symbols-outlined text-[18px] @(Model.IsPassed ? "text-green-600 dark:text-green-400" : "text-red-600 dark:text-red-400")">@(Model.IsPassed ? "check_circle" : "cancel")</span>
                        <span>@(Model.IsPassed ? "Passed" : "Not Passed")</span>
                    </div>
                </div>
            </div>

            <!-- Question Results -->
            <div>
                <h2 class="text-2xl font-bold text-[#151118] dark:text-white mb-6">Question Review</h2>
                <div class="space-y-4">
                    @for (int i = 0; i < Model.QuestionResults.Count; i++)
                    {
                        var qResult = Model.QuestionResults[i];
                        var question = quiz?.Questions?.FirstOrDefault(q => q.Id == qResult.QuestionId);
                        
                        <div class="bg-white dark:bg-[#1e1427] rounded-xl shadow-sm border-2 @(qResult.IsCorrect ? "border-green-200 dark:border-green-800" : "border-red-200 dark:border-red-800") overflow-hidden">
                            <div class="p-6">
                                <div class="flex items-start gap-4 mb-4">
                                    <div class="flex-shrink-0">
                                        @if (qResult.IsCorrect)
                                        {
                                            <div class="w-10 h-10 rounded-full bg-green-100 dark:bg-green-900/30 flex items-center justify-center">
                                                <span class="material-symbols-outlined text-green-600 dark:text-green-400">check_circle</span>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="w-10 h-10 rounded-full bg-red-100 dark:bg-red-900/30 flex items-center justify-center">
                                                <span class="material-symbols-outlined text-red-600 dark:text-red-400">cancel</span>
                                            </div>
                                        }
                                    </div>
                                    <div class="flex-1">
                                        <h3 class="text-lg font-semibold text-[#151118] dark:text-white mb-4">@qResult.QuestionText</h3>
                                        
                                        @if (question != null)
                                        {
                                            <div class="space-y-2">
                                                @foreach (var option in question.AnswerOptions)
                                                {
                                                    var isSelected = qResult.SelectedAnswerId == option.Id;
                                                    var isCorrect = option.IsCorrect;
                                                    
                                                    <div class="p-3 rounded-lg @(isCorrect ? "bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800" : isSelected ? "bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800" : "bg-background-light dark:bg-[#2a2035] border border-[#e5e7eb] dark:border-gray-800")">
                                                        <div class="flex items-center gap-2">
                                                            @if (isCorrect)
                                                            {
                                                                <span class="material-symbols-outlined text-green-600 dark:text-green-400 text-[18px]">check_circle</span>
                                                                <span class="text-sm font-semibold text-green-700 dark:text-green-400">Correct Answer</span>
                                                            }
                                                            else if (isSelected)
                                                            {
                                                                <span class="material-symbols-outlined text-red-600 dark:text-red-400 text-[18px]">cancel</span>
                                                                <span class="text-sm font-semibold text-red-700 dark:text-red-400">Your Answer</span>
                                                            }
                                                            <span class="text-sm text-[#151118] dark:text-gray-200 ml-auto">@option.Text</span>
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Actions -->
            <div class="flex items-center justify-center gap-4 flex-wrap pt-6">
                <a href="@Url.Action("Index", "Quiz")" 
                   class="px-6 py-2.5 rounded-lg text-sm font-medium text-[#776189] dark:text-gray-400 hover:bg-[#f2f0f4] dark:hover:bg-[#2a2035] transition-colors flex items-center gap-2">
                    <span class="material-symbols-outlined text-[18px]">arrow_back</span>
                    Back to Quizzes
                </a>
                @if (quiz != null)
                {
                    <a href="@Url.Action("Take", "Quiz", new { quizId = quiz.Id })" 
                       class="bg-primary hover:bg-primary/90 text-white px-8 py-2.5 rounded-lg text-sm font-semibold shadow-lg shadow-primary/30 transition-all active:scale-95 flex items-center gap-2">
                        Retake Quiz
                        <span class="material-symbols-outlined text-[18px]">refresh</span>
                    </a>
                }
                <a href="/Home" 
                   class="bg-green-600 hover:bg-green-700 text-white px-8 py-2.5 rounded-lg text-sm font-semibold shadow-lg shadow-green-600/30 transition-all active:scale-95 flex items-center gap-2">
                    Dashboard
                    <span class="material-symbols-outlined text-[18px]">dashboard</span>
                </a>
            </div>
        </div>
    </main>

    <script>
        @if (Model.IsPassed)
        {
            <text>
            document.addEventListener('DOMContentLoaded', function() {
                setTimeout(() => {
                    confetti({
                        particleCount: 100,
                        spread: 70,
                        origin: { y: 0.6 },
                        colors: ['#22c55e', '#10b981', '#34d399']
                    });
                }, 300);
            });
            </text>
        }
    </script>
</body>
</html>
