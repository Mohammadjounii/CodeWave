@using CodeWave.Application.DTOs
@model QuizDto
@{
    Layout = null;
    var attemptId = ViewBag.AttemptId as Guid?;
    var timeLimitMinutes = ViewBag.TimeLimitMinutes as int? ?? 30;
    var courseTitle = ViewBag.CourseTitle as string ?? "Course";
}

<!DOCTYPE html>
<html class="light dark" lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>CodeWave - Coding Quizzes</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script id="tailwind-config">tailwind.config = {darkMode: "class", theme: {extend: {colors: {primary: "#9d64cf", "background-light": "#f7f6f8", "background-dark": "#19141e"}, fontFamily: {display: "Inter"}, borderRadius: {DEFAULT: "0.25rem", lg: "0.5rem", xl: "0.75rem", full: "9999px"}}}};</script>
    <style>
        .code-syntax-keyword {
            color: #d73a49
        }
        .code-syntax-string {
            color: #032f62
        }
        .code-syntax-function {
            color: #6f42c1
        }
        .code-syntax-number {
            color: #005cc5
        }
        .form-radio:checked {
            background-image: url(https://lh3.googleusercontent.com/aida-public/AB6AXuBMVHLjrGP_M9labWnHKDHNq26LtiCaIWfGw__WSTWgMadnrbWi1LUJxzMJjLc5KU7sQLjqyn8tO007xGhe-QhdBuoX4lgqrKvzbS0LmH-PS9wZeWRzBonEFU_SH6f_7tZ5IRBM0_TZcKzK7H6Ey2it-31QzImnBW-Y0FeSaEkmrrPyfUIKowkD8PZzFliGHz7OKsAi_4JAyMyE7AAT09jMpmES7WgsdDsRI2kaOnMk5ULnB06xHWUKRxTybRgCOP4_cMaZ_iepUjY);
            border-color: transparent;
            background-color: currentColor;
            background-size: 100% 100%;
            background-position: center;
            background-repeat: no-repeat
        }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
    </style>
</head>
<body class="bg-background-light dark:bg-background-dark font-display text-[#151118] dark:text-white transition-colors duration-200">

<!-- Main Content Layout -->
<main class="flex min-h-[calc(100vh-73px)] flex-col items-center py-8 px-4 sm:px-6 lg:px-8">
<div class="w-full max-w-5xl space-y-8">
<!-- Breadcrumbs -->
<nav class="flex flex-wrap items-center text-sm text-[#776189] dark:text-gray-400">
<a class="hover:text-primary transition-colors" href="@Url.Action("Index", "Home")">Dashboard</a>
<span class="mx-2 text-gray-400">/</span>
<a class="hover:text-primary transition-colors" href="@Url.Action("Index", "Quiz")">Quizzes</a>
<span class="mx-2 text-gray-400">/</span>
<span class="font-medium text-[#151118] dark:text-white">@Model.Title</span>
</nav>
<!-- Quiz Header & Progress -->
<div class="bg-white dark:bg-[#1e1427] rounded-xl p-6 shadow-sm border border-[#e5e7eb] dark:border-gray-800">
<div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-6">
<div>
<h1 class="text-2xl font-bold text-[#151118] dark:text-white">@Model.Title</h1>
<p class="text-[#776189] dark:text-gray-400 text-sm mt-1">@Model.Description</p>
</div>
<div class="flex items-center gap-3">
<div class="flex items-center gap-1 text-[#776189] dark:text-gray-400 bg-background-light dark:bg-[#2a2035] px-3 py-1.5 rounded-lg">
<span class="material-symbols-outlined text-[20px]">timer</span>
<span id="timer" class="text-sm font-medium">@timeLimitMinutes:00</span>
</div>
<a href="@Url.Action("Index", "Quiz")" class="text-sm font-medium text-[#776189] dark:text-gray-400 hover:text-red-500 transition-colors px-3 py-1.5">
                            Quit Quiz
                        </a>
</div>
</div>
<!-- Progress Bar Component -->
<div class="flex flex-col gap-2">
<div class="flex justify-between items-end">
<span class="text-primary font-bold text-sm">Question <span id="currentQuestion">1</span> of <span id="totalQuestions">@Model.Questions.Count</span></span>
<span class="text-[#776189] dark:text-gray-400 text-xs font-medium"><span id="progressPercent">0</span>% Completed</span>
</div>
<div class="h-2.5 w-full bg-[#f2f0f4] dark:bg-[#2a2035] rounded-full overflow-hidden">
<div id="progressBar" class="h-full bg-primary rounded-full transition-all duration-500 ease-out" style="width: 0%"></div>
</div>
</div>
</div>
<!-- Two Column Layout for Question -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
<!-- Left Column: Problem Statement & Code -->
<div class="flex flex-col gap-6">
<!-- Question Card -->
<div class="bg-white dark:bg-[#1e1427] rounded-xl shadow-sm border border-[#e5e7eb] dark:border-gray-800 overflow-hidden h-full flex flex-col">
<div class="p-6 border-b border-[#f2f0f4] dark:border-gray-800 bg-background-light/50 dark:bg-[#251b2e]">
<h3 id="questionText" class="text-lg font-bold text-[#151118] dark:text-white leading-tight">
                                <!-- Question text will be rendered here -->
                            </h3>
<p id="questionHint" class="mt-2 text-[#776189] dark:text-gray-400 text-sm">
                                <!-- Question hint will be rendered here -->
                            </p>
</div>
<!-- Code Snippet Display -->
<div id="codeSnippetContainer" class="p-6 bg-[#282c34] dark:bg-[#0d0912] flex-grow font-mono text-sm leading-relaxed overflow-x-auto hidden">
<pre><code id="codeSnippet" class="language-python block text-[#abb2bf]"><!-- Code will be rendered here --></code></pre>
</div>
<!-- Hint Section -->
<div id="hintSection" class="p-4 bg-primary/5 dark:bg-primary/10 border-t border-primary/10 flex items-start gap-3 hidden">
<span class="material-symbols-outlined text-primary mt-0.5">lightbulb</span>
<div>
<p class="text-sm font-medium text-primary">Need a hint?</p>
<p id="hintText" class="text-xs text-[#776189] dark:text-gray-400 mt-1"><!-- Hint text will be rendered here --></p>
</div>
</div>
</div>
</div>
<!-- Right Column: Interactive Answers -->
<div class="flex flex-col gap-6">
<div class="bg-white dark:bg-[#1e1427] rounded-xl shadow-sm border border-[#e5e7eb] dark:border-gray-800 p-6 h-full flex flex-col justify-between">
<div>
<div class="flex justify-between items-center mb-6">
<h4 class="text-base font-semibold text-[#151118] dark:text-white">Select your answer</h4>
<span class="bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 text-xs font-bold px-2 py-1 rounded uppercase tracking-wide">Single Choice</span>
</div>
<!-- Options List -->
<div id="answerOptions" class="space-y-3">
<!-- Options will be rendered here -->
</div>
</div>
<!-- Action Buttons -->
<div class="mt-8 pt-6 border-t border-[#f2f0f4] dark:border-gray-800 flex items-center justify-between">
<button id="prevBtn" onclick="previousQuestion()" class="px-6 py-2.5 rounded-lg text-sm font-medium text-[#776189] dark:text-gray-400 hover:bg-[#f2f0f4] dark:hover:bg-[#2a2035] transition-colors flex items-center gap-2 hidden">
<span class="material-symbols-outlined text-[18px]">arrow_back</span>
                                Previous
                            </button>
<div class="flex gap-3">
<button id="skipBtn" onclick="skipQuestion()" class="px-6 py-2.5 rounded-lg text-sm font-medium text-[#776189] dark:text-gray-400 hover:text-[#151118] dark:hover:text-white transition-colors">
                                    Skip
                                </button>
<button id="nextBtn" onclick="nextQuestion()" class="bg-primary hover:bg-primary/90 text-white px-8 py-2.5 rounded-lg text-sm font-semibold shadow-lg shadow-primary/30 transition-all active:scale-95 flex items-center gap-2">
                                    Next
                                    <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
</button>
<button id="submitBtn" onclick="submitQuiz()" class="bg-primary hover:bg-primary/90 text-white px-8 py-2.5 rounded-lg text-sm font-semibold shadow-lg shadow-primary/30 transition-all active:scale-95 flex items-center gap-2 hidden">
                                    Submit
                                    <span class="material-symbols-outlined text-[18px]">check</span>
</button>
</div>
</div>
</div>
</div>
</div>
<!-- Additional Learning Resource / Footer Context -->
<div class="mt-8 flex justify-center">
<div class="inline-flex items-center gap-2 text-sm text-[#776189] dark:text-gray-500 bg-white dark:bg-[#1e1427] px-4 py-2 rounded-full shadow-sm border border-[#e5e7eb] dark:border-gray-800">
<span class="material-symbols-outlined text-[18px]">school</span>
<span>This question is from the <a class="text-primary hover:underline" href="@Url.Action("Course", "LearningPath", new { courseId = Model.CourseId })">@courseTitle</a></span>
</div>
</div>
</div>
</main>

<script>
    const questions = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Questions));
    const attemptId = '@attemptId';
    const timeLimitSeconds = @(timeLimitMinutes * 60);
    let currentQuestionIndex = 0;
    let answers = {};
    let timeRemaining = timeLimitSeconds;
    let timerInterval = null;

    document.addEventListener('DOMContentLoaded', function() {
        renderQuestion();
        startTimer();
    });

    function renderQuestion() {
        const question = questions[currentQuestionIndex];
        const progress = ((currentQuestionIndex + 1) / questions.length) * 100;
        
        document.getElementById('progressBar').style.width = progress + '%';
        document.getElementById('progressPercent').textContent = Math.round(progress);
        document.getElementById('currentQuestion').textContent = currentQuestionIndex + 1;
        document.getElementById('totalQuestions').textContent = questions.length;

        document.getElementById('prevBtn').classList.toggle('hidden', currentQuestionIndex === 0);
        document.getElementById('nextBtn').classList.toggle('hidden', currentQuestionIndex === questions.length - 1);
        document.getElementById('submitBtn').classList.toggle('hidden', currentQuestionIndex !== questions.length - 1);
        document.getElementById('skipBtn').classList.toggle('hidden', currentQuestionIndex === questions.length - 1);

        // Render question text
        document.getElementById('questionText').textContent = question.Text;
        
        // Check if question has code snippet (stored in a custom property or parse from text)
        const codeMatch = question.Text.match(/```(?:python|java|javascript)?\n?([\s\S]*?)```/);
        const hasCode = codeMatch !== null;
        
        if (hasCode) {
            const codeContent = codeMatch[1].trim();
            document.getElementById('codeSnippet').innerHTML = highlightCode(codeContent);
            document.getElementById('codeSnippetContainer').classList.remove('hidden');
            
            // Show hint section
            document.getElementById('hintSection').classList.remove('hidden');
            document.getElementById('hintText').innerHTML = 'Analyze the code snippet carefully. Pay attention to syntax, operators, and data types.';
            document.getElementById('questionHint').textContent = 'Analyze the code snippet carefully.';
        } else {
            document.getElementById('codeSnippetContainer').classList.add('hidden');
            document.getElementById('hintSection').classList.add('hidden');
            document.getElementById('questionHint').textContent = '';
        }

        // Render answer options
        const optionsContainer = document.getElementById('answerOptions');
        const isSelected = answers[question.Id] !== undefined;
        optionsContainer.innerHTML = question.AnswerOptions.map((option, index) => {
            const optionLetter = String.fromCharCode(65 + index); // A, B, C, D
            const selected = answers[question.Id] === option.Id;
            return `
                <label class="group relative flex items-center p-4 rounded-lg border-2 ${selected ? 'border-primary bg-primary/5 dark:bg-primary/10' : 'border-[#e5e7eb] dark:border-[#2a2035] hover:border-primary/50 dark:hover:border-primary/50 hover:bg-primary/5 dark:hover:bg-primary/10'} cursor-pointer transition-all duration-200">
                    <input class="size-5 text-primary border-gray-300 dark:border-gray-600 focus:ring-primary dark:focus:ring-offset-[#1e1427]" 
                           name="question-${question.Id}" 
                           type="radio" 
                           value="${option.Id}"
                           ${selected ? 'checked' : ''}
                           onchange="selectAnswer('${question.Id}', '${option.Id}')"/>
                    <span class="ml-3 flex-1 font-mono text-sm text-[#151118] dark:text-gray-200">${option.Text}</span>
                    ${selected ? '<span class="absolute right-4 text-primary text-xs font-medium">Selected</span>' : '<span class="absolute right-4 hidden group-hover:block text-primary text-xs font-medium">Select</span>'}
                </label>
            `;
        }).join('');
    }

    function highlightCode(code) {
        // Simple syntax highlighting for Python
        return code
            .replace(/(\bdef\b|\bif\b|\belse\b|\bfor\b|\bwhile\b|\breturn\b|\bclass\b|\bimport\b|\bfrom\b|\bas\b|\bin\b|\band\b|\bor\b|\bnot\b|\bTrue\b|\bFalse\b|\bNone\b)/g, '<span class="text-[#c678dd]">$1</span>')
            .replace(/(["'])(?:(?=(\\?))\2.)*?\1/g, '<span class="text-[#98c379]">$&</span>')
            .replace(/\b(\d+\.?\d*)\b/g, '<span class="text-[#d19a66]">$1</span>')
            .replace(/(\w+)\s*(?=\()/g, '<span class="text-[#e5c07b]">$1</span>')
            .replace(/#.*$/gm, '<span class="text-[#776189] italic">$&</span>');
    }

    function selectAnswer(questionId, optionId) {
        answers[questionId] = optionId;
        renderQuestion(); // Re-render to update UI
    }

    function nextQuestion() {
        if (currentQuestionIndex < questions.length - 1) {
            currentQuestionIndex++;
            renderQuestion();
        }
    }

    function previousQuestion() {
        if (currentQuestionIndex > 0) {
            currentQuestionIndex--;
            renderQuestion();
        }
    }

    function skipQuestion() {
        if (currentQuestionIndex < questions.length - 1) {
            nextQuestion();
        }
    }

    function startTimer() {
        timerInterval = setInterval(() => {
            timeRemaining--;
            const minutes = Math.floor(timeRemaining / 60);
            const seconds = timeRemaining % 60;
            const timerEl = document.getElementById('timer');
            timerEl.textContent = `${minutes}:${seconds.toString().padStart(2, '0')}`;
            
            if (timeRemaining <= 0) {
                clearInterval(timerInterval);
                submitQuiz(true);
            } else if (timeRemaining <= 60) {
                timerEl.classList.add('text-red-500');
            }
        }, 1000);
    }

    async function submitQuiz(timeout = false) {
        if (timerInterval) clearInterval(timerInterval);
        
        if (!timeout && !confirm('Are you sure you want to submit your quiz?')) {
            startTimer();
            return;
        }

        const answerList = questions.map(q => ({
            QuestionId: q.Id,
            AnswerOptionId: answers[q.Id] || null
        }));

        try {
            const response = await fetch('@Url.Action("Submit", "Quiz")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                },
                body: JSON.stringify({
                    AttemptId: attemptId,
                    Answers: answerList
                })
            });

            const result = await response.json();
            
            if (response.ok) {
                window.location.href = '@Url.Action("Results", "Quiz")?attemptId=' + attemptId;
            } else {
                alert('Error submitting quiz: ' + (result.message || 'Unknown error'));
            }
        } catch (error) {
            alert('Error submitting quiz: ' + error.message);
        }
    }
</script>
</body>
</html>
