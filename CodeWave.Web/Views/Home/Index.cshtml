                                                <span class="material-symbols-outlined text-sm mr-2 text-gray-800 dark:text-slate-400">lock</span>
                                                <span>View Offer</span>
                                            </div>
                                        }
                                        else
                                        {
                                            <a class="group w-full bg-primary/20 hover:bg-primary/30 text-primary dark:text-white h-11 rounded-xl text-sm shadow-lg shadow-primary/25 hover:shadow-xl hover:shadow-primary/30 flex items-center justify-center font-semibold transition-all duration-300 transform hover:scale-[1.02] active:scale-[0.98]" asp-controller="JobOffer" asp-action="Index" asp-route-filter="backend">
