                        </section>
                    </div>
                </div>

            </div>
        </main>

</div>

<!-- Profile Picture Modal -->
<div id="profilePictureModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/70 backdrop-blur-sm">
    <div class="bg-[#111318] rounded-xl p-8 max-w-md w-full mx-4 border border-[#3b4354] shadow-2xl">
        <div class="flex justify-between items-center mb-6">
            <h2 class="text-gray-900 dark:text-white text-2xl font-bold">Profile Picture</h2>
            <button onclick="closeProfilePictureModal()" class="text-gray-900 dark:text-slate-400 hover:text-gray-900 dark:hover:text-white transition-colors">
                <span class="material-symbols-outlined text-gray-800 dark:text-slate-400">close</span>
            </button>
        </div>
        
        <div class="flex flex-col items-center gap-6">
            <!-- Large Profile Picture -->
            <div class="size-48 rounded-full bg-cover bg-center bg-no-repeat border-4 border-primary shadow-lg"
                 id="modalProfilePicture"
                 style='background-image:url("@displayPictureUrl"); background-color: #4a5568;'>
            </div>
            
            <!-- Upload Form -->
            <form id="profilePictureForm" asp-controller="Home" asp-action="UploadProfilePicture" method="post" enctype="multipart/form-data" class="w-full">
                @Html.AntiForgeryToken()
                <label for="profilePictureInput" class="flex items-center justify-center gap-2 w-full bg-primary text-white h-12 px-6 rounded-lg hover:bg-primary/90 transition-colors cursor-pointer">
                    <span class="material-symbols-outlined text-white">upload</span>
                    <span>Change Picture</span>
                </label>
                <input type="file" id="profilePictureInput" name="profilePicture" accept="image/jpeg,image/jpg,image/png,image/gif" class="hidden" onchange="handleFileSelect(this)" />
            </form>
        </div>
    </div>
</div>

<script>
    function openProfilePictureModal() {
        document.getElementById('profilePictureModal').classList.remove('hidden');
        document.getElementById('profilePictureModal').classList.add('flex');
        document.body.style.overflow = 'hidden';
    }

    function closeProfilePictureModal() {
        document.getElementById('profilePictureModal').classList.add('hidden');
        document.getElementById('profilePictureModal').classList.remove('flex');
        document.body.style.overflow = 'auto';
    }

    function handleFileSelect(input) {
        if (input.files && input.files[0]) {
            var file = input.files[0];
            
            // Validate file size (max 5MB)
            if (file.size > 5 * 1024 * 1024) {
                alert('File size too large. Please upload an image smaller than 5MB.');
                input.value = '';
                return;
            }

            // Validate file type
            var allowedTypes = ['image/jpeg', 'image/jpg', 'image/png', 'image/gif'];
            if (!allowedTypes.includes(file.type)) {
                alert('Invalid file type. Please upload a JPG, PNG, or GIF image.');
                input.value = '';
                return;
            }

            // Preview the image before upload
            var reader = new FileReader();
            reader.onload = function(e) {
                document.getElementById('modalProfilePicture').style.backgroundImage = 'url(' + e.target.result + ')';
            };
            reader.readAsDataURL(file);

            // Submit the form
            document.getElementById('profilePictureForm').submit();
        }
    }

    // Job filtering functionality
    let currentJobFilter = 'all';

    function filterJobs(filter) {
        currentJobFilter = filter;
        const jobCards = document.querySelectorAll('.job-card');
        const filterButtons = document.querySelectorAll('.job-filter-btn');

        // Update filter button styles - use purple color like sidebar selected tab
        filterButtons.forEach(btn => {
            const btnFilter = btn.getAttribute('data-filter');
            if (btnFilter === filter) {
                // Selected state: purple background with purple text (like sidebar)
                btn.classList.remove('text-gray-900', 'dark:text-slate-300', 'bg-gray-100', 'dark:bg-white/5', 'border-gray-300', 'dark:border-white/10', 'border', 'text-gray-700', 'text-white', 'bg-gradient-to-r', 'from-primary', 'to-purple-600', 'shadow-lg', 'shadow-primary/30');
                btn.classList.add('bg-primary/20', 'text-primary', 'dark:text-white', 'hover:bg-primary/30', 'shadow-lg', 'shadow-primary/25', 'font-semibold');
            } else {
                // Unselected state: gray background
                btn.classList.remove('bg-primary/20', 'text-primary', 'dark:text-white', 'hover:bg-primary/30', 'shadow-lg', 'shadow-primary/25', 'font-semibold', 'text-white', 'bg-gradient-to-r', 'from-primary', 'to-purple-600');
                btn.classList.add('text-gray-900', 'dark:text-slate-300', 'bg-gray-100', 'dark:bg-white/5', 'border', 'border-gray-300', 'dark:border-white/10', 'font-medium');
            }
        });

        // Filter job cards
        jobCards.forEach(card => {
            const jobType = card.getAttribute('data-job-type');
            const location = card.getAttribute('data-location');

            if (filter === 'all') {
                card.style.display = 'flex';
            } else if (filter === 'remote' && location === 'remote') {
                card.style.display = 'flex';
            } else if (filter === jobType) {
                card.style.display = 'flex';
            } else {
                card.style.display = 'none';
            }
        });
    }

    function toggleJobFilters() {
        const filterContainer = document.querySelector('.job-filter-btn').parentElement;
        filterContainer.style.display = filterContainer.style.display === 'none' ? 'flex' : 'none';
    }

    // Close modal when clicking outside
    document.getElementById('profilePictureModal').addEventListener('click', function(e) {
        if (e.target === this) {
            closeProfilePictureModal();
        }
    });

    // Close modal with Escape key
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
            closeProfilePictureModal();
        }
    });

    // Toggle View All Skills
    function toggleAllSkills() {
        const hiddenSkills = document.getElementById('hiddenSkills');
        const viewAllBtn = document.getElementById('viewAllSkillsBtn');
        const viewAllIcon = document.getElementById('viewAllIcon');
        
        if (hiddenSkills && viewAllBtn && viewAllIcon) {
            if (hiddenSkills.classList.contains('hidden')) {
                hiddenSkills.classList.remove('hidden');
                viewAllBtn.innerHTML = '<span>Show Less</span><span class="material-symbols-outlined text-sm text-gray-800 dark:text-white" id="viewAllIcon">expand_less</span>';
            } else {
                hiddenSkills.classList.add('hidden');
                viewAllBtn.innerHTML = '<span>View All Skills</span><span class="material-symbols-outlined text-sm text-gray-800 dark:text-white" id="viewAllIcon">expand_more</span>';
            }
        }
    }
</script>

</body>
</html>
