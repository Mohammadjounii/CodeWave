                                            <span class="px-3 py-1.5 bg-gray-100 dark:bg-white/5 text-gray-900 dark:text-slate-300 text-xs rounded-full border border-gray-300 dark:border-white/10 font-medium">Python</span>
                                            <span class="px-3 py-1.5 bg-gray-100 dark:bg-white/5 text-gray-900 dark:text-slate-300 text-xs rounded-full border border-gray-300 dark:border-white/10 font-medium">AWS</span>
