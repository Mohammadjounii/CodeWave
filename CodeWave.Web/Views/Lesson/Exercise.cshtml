@model CodeWave.Domain.Entities.CodingExercise
@{
    Layout = "_Layout";
}

<div class="max-w-4xl mx-auto p-4">
    <h1 class="text-2xl font-bold">@Model.Title</h1>
    <p class="mb-4">@Model.Description</p>

    <label class="block mb-2 font-medium">Code</label>
    <textarea id="codeArea" rows="16" class="w-full font-mono p-3 border rounded">@Model.StarterCode</textarea>

    <div class="flex gap-2 mt-3">
        <button id="runBtn" class="px-4 py-2 bg-green-600 text-white rounded">Run</button>
        <button id="submitBtn" class="px-4 py-2 bg-blue-600 text-white rounded">Submit</button>
        <select id="timeout" class="border rounded px-2">
            <option value="3">3s</option>
            <option value="5" selected>5s</option>
            <option value="10">10s</option>
        </select>
    </div>

    <div class="mt-4">
        <h3 class="font-semibold">Console output</h3>
        <pre id="console" class="bg-black text-white p-3 rounded min-h-[80px]">&gt; Output will appear here...</pre>
    </div>

    <div id="submitResult" class="mt-4 hidden p-4 rounded"></div>
</div>

@section Scripts {
    <script>
        const runBtn = document.getElementById('runBtn');
        const submitBtn = document.getElementById('submitBtn');
        const codeArea = document.getElementById('codeArea');
        const consoleEl = document.getElementById('console');
        const timeoutEl = document.getElementById('timeout');
        const submitResult = document.getElementById('submitResult');

        const exerciseId = '@Model.Id';
        const lessonId = '@Model.LessonId';

        // RUN — just executes code, no validation
        runBtn.addEventListener('click', async () => {
            runBtn.disabled = true;
            consoleEl.textContent = '> Running...';
            submitResult.classList.add('hidden');

            const payload = {
                code: codeArea.value,
                timeoutSeconds: parseInt(timeoutEl.value)
            };

            try {
                const res = await fetch('/api/CodeRunner/run-java', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                if (!res.ok) {
                    const txt = await res.text();
                    consoleEl.textContent = '> Server error: ' + txt;
                    runBtn.disabled = false;
                    return;
                }

                const json = await res.json();

                let out = '';
                if (json.compileError) {
                    out += '=== Compilation Error ===\n' + json.stderr + '\n';
                } else if (json.timedOut) {
                    out += '=== Timeout ===\nExecution timed out.\n' + (json.stderr || '') + '\n';
                } else {
                    if (json.stdout) out += json.stdout + '\n';
                    if (json.stderr) out += '=== Stderr ===\n' + json.stderr + '\n';
                }

                out += `\n(exit code: ${json.exitCode ?? 0})`;
                consoleEl.textContent = out;
            } catch (err) {
                consoleEl.textContent = '> Network or server error: ' + err;
            } finally {
                runBtn.disabled = false;
            }
        });

        // SUBMIT — validates code against expected output and marks lesson complete
        submitBtn.addEventListener('click', async () => {
            submitBtn.disabled = true;
            submitBtn.textContent = 'Checking...';
            submitResult.classList.add('hidden');
            consoleEl.textContent = '> Running and checking your answer...';

            const payload = {
                language: 'java',
                code: codeArea.value,
                exerciseId: exerciseId
            };

            try {
                const res = await fetch('/api/code/run', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                if (!res.ok) {
                    const txt = await res.text();
                    consoleEl.textContent = '> Server error: ' + txt;
                    return;
                }

                const json = await res.json();

                // Show output in console
                consoleEl.textContent = json.output || '(no output)';

                // Show pass/fail result
                submitResult.classList.remove('hidden');

                if (json.isCorrect) {
                    submitResult.className = 'mt-4 p-4 rounded bg-green-100 border border-green-500 text-green-800';
                    submitResult.innerHTML = `
                        <strong>Correct!</strong> All test cases passed (${json.passedTests}/${json.totalTests}).
                        <br>Lesson marked as complete.
                    `;

                    // Mark lesson as complete
                    await fetch('/api/progress/completeLesson?lessonId=' + lessonId, {
                        method: 'POST'
                    });

                    submitBtn.textContent = 'Completed!';
                    submitBtn.disabled = true;
                    submitBtn.className = 'px-4 py-2 bg-gray-400 text-white rounded cursor-not-allowed';
                } else {
                    submitResult.className = 'mt-4 p-4 rounded bg-red-100 border border-red-500 text-red-800';

                    let resultHtml = `<strong>Not quite.</strong> ${json.passedTests}/${json.totalTests} test cases passed.<br>`;

                    if (json.testCaseResults && json.testCaseResults.length > 0) {
                        resultHtml += '<ul class="mt-2 list-disc list-inside">';
                        json.testCaseResults.forEach(tc => {
                            const icon = tc.passed ? '✓' : '✗';
                            resultHtml += `<li>${icon} ${tc.description || 'Test case'}</li>`;
                        });
                        resultHtml += '</ul>';
                    }

                    submitResult.innerHTML = resultHtml;
                    submitBtn.textContent = 'Submit';
                    submitBtn.disabled = false;
                }
            } catch (err) {
                consoleEl.textContent = '> Network or server error: ' + err;
                submitBtn.textContent = 'Submit';
                submitBtn.disabled = false;
            }
        });
    </script>
}
