@{
    Layout = null;
}
<!DOCTYPE html>
<html class="light dark" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Interactive Lesson Interface - with AI Chat</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;900&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        ::-webkit-scrollbar { width: 10px; height: 10px; }
        ::-webkit-scrollbar-track { background: rgba(155,89,245,0.08); border-radius: 999px; }
        ::-webkit-scrollbar-thumb { background: #9b59f5; border-radius: 999px; box-shadow: 0 0 10px rgba(155,89,245,0.9), 0 0 20px rgba(155,89,245,0.5), 0 0 35px rgba(155,89,245,0.2); }
        ::-webkit-scrollbar-thumb:hover { background: #b07eff; box-shadow: 0 0 14px rgba(176,126,255,1), 0 0 28px rgba(176,126,255,0.6), 0 0 45px rgba(155,89,245,0.3); }
        ::-webkit-scrollbar-corner { background: transparent; }
        * { scrollbar-width: thin; scrollbar-color: #9b59f5 rgba(155,89,245,0.08); }
    </style>
    <script id="tailwind-config">tailwind.config = {darkMode: "class", theme: {extend: {colors: {primary: "#b887e3", "background-light": "#f7f6f8", "background-dark": "#19131f", "panel-light": "#ffffff", "panel-dark": "#18202f", "text-light": "#0d121b", "text-dark": "#f8f9fc", "border-light": "#e7ebf3", "border-dark": "#2c3647", success: "#10B981", error: "#EF4444"}, fontFamily: {display: "Inter"}, borderRadius: {DEFAULT: "0.25rem", lg: "0.5rem", xl: "0.75rem", full: "9999px"}}}};</script>
</head>
<body class="font-display bg-background-light dark:bg-background-dark text-text-light dark:text-text-dark">
    <div class="relative flex h-screen w-full flex-col group/design-root overflow-hidden">
        <header class="flex items-center justify-between whitespace-nowrap border-b border-solid border-border-light dark:border-border-dark px-6 py-3 bg-panel-light dark:bg-panel-dark flex-shrink-0">
            <div class="flex items-center gap-4">
                <div class="size-6 text-primary">
                    <svg fill="none" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
                        <path d="M13.8261 30.5736C16.7203 29.8826 20.2244 29.4783 24 29.4783C27.7756 29.4783 31.2797 29.8826 34.1739 30.5736C36.9144 31.2278 39.9967 32.7669 41.3563 33.8352L24.8486 7.36089C24.4571 6.73303 23.5429 6.73303 23.1514 7.36089L6.64374 33.8352C8.00331 32.7669 11.0856 31.2278 13.8261 30.5736Z" fill="currentColor"></path>
                        <path clip-rule="evenodd" d="M39.998 35.764C39.9944 35.7463 39.9875 35.7155 39.9748 35.6706C39.9436 35.5601 39.8949 35.4259 39.8346 35.2825C39.8168 35.2403 39.7989 35.1993 39.7813 35.1602C38.5103 34.2887 35.9788 33.0607 33.7095 32.5189C30.9875 31.8691 27.6413 31.4783 24 31.4783C20.3587 31.4783 17.0125 31.8691 14.2905 32.5189C12.0012 33.0654 9.44505 34.3104 8.18538 35.1832C8.17384 35.2075 8.16216 35.233 8.15052 35.2592C8.09919 35.3751 8.05721 35.4886 8.02977 35.589C8.00356 35.6848 8.00039 35.7333 8.00004 35.7388C8.00004 35.739 8 35.7393 8.00004 35.7388C8.00004 35.7641 8.0104 36.0767 8.68485 36.6314C9.34546 37.1746 10.4222 37.7531 11.9291 38.2772C14.9242 39.319 19.1919 40 24 40C28.8081 40 33.0758 39.319 36.0709 38.2772C37.5778 37.7531 38.6545 37.1746 39.3151 36.6314C39.9006 36.1499 39.9857 35.8511 39.998 35.764ZM4.95178 32.7688L21.4543 6.30267C22.6288 4.4191 25.3712 4.41909 26.5457 6.30267L43.0534 32.777C43.0709 32.8052 43.0878 32.8338 43.104 32.8629L41.3563 33.8352C43.104 32.8629 43.1038 32.8626 43.104 32.8629L43.1051 32.865L43.1065 32.8675L43.1101 32.8739L43.1199 32.8918C43.1276 32.906 43.1377 32.9246 43.1497 32.9473C43.1738 32.9925 43.2062 33.0545 43.244 33.1299C43.319 33.2792 43.4196 33.489 43.5217 33.7317C43.6901 34.1321 44 34.9311 44 35.7391C44 37.4427 43.003 38.7775 41.8558 39.7209C40.6947 40.6757 39.1354 41.4464 37.385 42.0552C33.8654 43.2794 29.133 44 24 44C18.867 44 14.1346 43.2794 10.615 42.0552C8.86463 41.4464 7.30529 40.6757 6.14419 39.7209C4.99695 38.7775 3.99999 37.4427 3.99999 35.7391C3.99999 34.8725 4.29264 34.0922 4.49321 33.6393C4.60375 33.3898 4.71348 33.1804 4.79687 33.0311C4.83898 32.9556 4.87547 32.8935 4.9035 32.8471C4.91754 32.8238 4.92954 32.8043 4.93916 32.7889L4.94662 32.777L4.95178 32.7688ZM35.9868 29.004L24 9.77997L12.0131 29.004C12.4661 28.8609 12.9179 28.7342 13.3617 28.6282C16.4281 27.8961 20.0901 27.4783 24 27.4783C27.9099 27.4783 31.5719 27.8961 34.6383 28.6282C35.082 28.7342 35.5339 28.8609 35.9868 29.004Z" fill="currentColor" fill-rule="evenodd"></path>
                    </svg>
                </div>
                <h2 class="text-lg font-bold leading-tight tracking-[-0.015em]">CodeLearn</h2>
                <span class="material-symbols-outlined text-text-light/50 dark:text-text-dark/50">chevron_right</span>
                <span class="text-sm font-medium">Python Basics</span>
            </div>
            <div class="flex items-center gap-4">
                <button class="flex max-w-[480px] cursor-pointer items-center justify-center overflow-hidden rounded-lg h-10 bg-primary/10 dark:bg-primary/20 text-primary gap-2 text-sm font-bold leading-normal tracking-[0.015em] px-4">
                    <span class="material-symbols-outlined !text-xl">chevron_left</span>
                    <span>Previous</span>
                </button>
                <button class="flex max-w-[480px] cursor-pointer items-center justify-center overflow-hidden rounded-lg h-10 bg-primary/10 dark:bg-primary/20 text-primary gap-2 text-sm font-bold leading-normal tracking-[0.015em] px-4">
                    <span>Next</span>
                    <span class="material-symbols-outlined !text-xl">chevron_right</span>
                </button>
                <div class="bg-center bg-no-repeat aspect-square bg-cover rounded-full size-10" data-alt="User avatar" style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuDyuiUoYigBkVCdP1obW57pcm15Qk_ovQ9cDPESFb6E0ocr2kAdWEmn1L3KF4fkhoLEVftNrOg3Cy1qgIaK_6AU69ixnBTgAj1YtC223gnDCGLKOSUxIPGQoW6cX81eiqunwgA-px9uLsWo5clFUA2Ju3YBkUxYTOfBh9mrJum0ojeAM_RzYluTHa7_qkKEiKJSsfQR2B5Hie22DPaCR8f76LuR5B-vZLZ3Y6Vbrjg3DPKmVXP6m0fGo6IhWwIkTp9i4kU8p8fz_Tw");'></div>
            </div>
        </header>
        <main class="grid flex-1 grid-cols-1 md:grid-cols-[35fr_45fr_20fr] min-h-0">
            <div class="hidden md:flex flex-col bg-panel-light dark:bg-panel-dark h-full border-r border-border-light dark:border-border-dark">
                <div class="overflow-y-auto p-6 space-y-6">
                    <p class="tracking-light text-[28px] font-bold leading-tight">Introduction to Python Variables</p>
                    <div class="relative flex items-center justify-center bg-primary/20 bg-cover bg-center aspect-video rounded-lg p-4" data-alt="Abstract gradient animation thumbnail for the lesson video">
                        <button class="flex shrink-0 items-center justify-center rounded-full size-16 bg-black/40 text-white">
                            <span class="material-symbols-outlined !text-4xl" style="font-variation-settings: 'FILL' 1;">play_arrow</span>
                        </button>
                    </div>
                    <p class="text-base font-normal leading-relaxed">
                        In programming, a variable is a container for storing data values. Unlike other programming languages, Python has no command for declaring a variable. A variable is created the moment you first assign a value to it. This lesson will walk you through the basics of creating and using variables in Python.
                    </p>
                    <p class="text-base font-normal leading-relaxed">
                        Think of a variable as a labeled box where you can store information. You can change what's inside the box, and you can look at what's inside whenever you need to.
                    </p>
                    <div class="p-4 bg-background-light dark:bg-background-dark rounded-lg">
                        <h3 class="font-bold mb-2">Key Takeaways:</h3>
                        <ul class="list-disc list-inside space-y-1 text-sm">
                            <li>Variables are created with an assignment statement.</li>
                            <li>Python is dynamically typed, so you don't need to declare the type.</li>
                            <li>Variable names are case-sensitive.</li>
                            <li>Choose descriptive names for your variables to make your code readable.</li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="col-span-1 md:col-span-1 flex flex-col h-full bg-background-light dark:bg-background-dark border-r border-border-light dark:border-border-dark">
                <div class="flex-1 flex flex-col min-h-0">
                    <div class="flex-shrink-0 flex items-center justify-between p-2 border-b border-border-light dark:border-border-dark bg-panel-light dark:bg-panel-dark">
                        <span class="text-sm font-medium px-2">main.py</span>
                        <div class="flex items-center gap-2">
                            <button class="flex min-w-[84px] max-w-[480px] cursor-pointer items-center justify-center overflow-hidden rounded-lg h-9 px-4 bg-primary/10 dark:bg-primary/20 text-primary text-sm font-bold leading-normal tracking-[0.015em] gap-2">
                                <span class="material-symbols-outlined !text-lg">play_arrow</span>
                                <span class="truncate">Run</span>
                            </button>
                            <button class="flex min-w-[84px] max-w-[480px] cursor-pointer items-center justify-center overflow-hidden rounded-lg h-9 px-4 bg-primary text-white text-sm font-bold leading-normal tracking-[0.015em] gap-2">
                                <span class="material-symbols-outlined !text-lg">check_circle</span>
                                <span class="truncate">Submit</span>
                            </button>
                        </div>
                    </div>
                    <div class="flex-1 bg-[#1E1E1E] p-4 font-mono text-sm text-gray-300 overflow-auto">
                        <div class="flex">
                            <div class="text-right pr-4 text-gray-500 select-none">
                                1<br />2<br />3<br />4<br />5<br />6<br />7<br />8
                            </div>
<pre><code># 1. Create a variable named 'greeting'
greeting = "Hello, Coder!"
# 2. Create a variable for your favorite number
favorite_number = 7
# 3. Print both variables to the console
print(greeting)
print("My favorite number is:", favorite_number)</code></pre>
                        </div>
                    </div>
                    <div class="h-1/3 flex flex-col border-t-2 border-border-light dark:border-border-dark min-h-[150px]">
                        <div class="flex-shrink-0 flex items-center justify-between p-2 border-b border-border-light dark:border-border-dark bg-panel-light dark:bg-panel-dark">
                            <span class="text-sm font-bold px-2">Console</span>
                            <button class="text-xs font-medium text-text-light/60 dark:text-text-dark/60 hover:text-text-light dark:hover:text-text-dark">Clear</button>
                        </div>
                        <div class="flex-1 bg-panel-light dark:bg-panel-dark p-4 font-mono text-sm overflow-auto">
                            <p class="text-text-light/70 dark:text-text-dark/70">&gt; Your output will appear here...</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="hidden md:flex flex-col h-full bg-panel-light dark:bg-panel-dark">
                <div class="flex flex-shrink-0 items-center p-4 border-b border-border-light dark:border-border-dark">
                    <h3 class="font-bold text-sm text-text-light/80 dark:text-text-dark/80 tracking-wide">AI HELPER / HINTS / EXPLAIN</h3>
                </div>
                <div class="flex-1 p-4 overflow-y-auto space-y-4">
                    <div class="flex items-start gap-3">
                        <div class="flex-shrink-0 size-8 rounded-full bg-primary/20 flex items-center justify-center text-primary">
                            <span class="material-symbols-outlined !text-xl">smart_toy</span>
                        </div>
                        <div class="bg-background-light dark:bg-background-dark p-3 rounded-xl rounded-tl-none">
                            <p class="text-sm leading-relaxed">Hey there! Stuck on something? I can help explain the code, give you a hint, or even show you the solution if you're really stuck. Just ask!</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-3 justify-end">
                        <div class="bg-primary text-white p-3 rounded-xl rounded-tr-none">
                            <p class="text-sm leading-relaxed">Can you explain what a variable is in simple terms?</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-3">
                        <div class="flex-shrink-0 size-8 rounded-full bg-primary/20 flex items-center justify-center text-primary">
                            <span class="material-symbols-outlined !text-xl">smart_toy</span>
                        </div>
                        <div class="bg-background-light dark:bg-background-dark p-3 rounded-xl rounded-tl-none">
                            <p class="text-sm leading-relaxed">Of course! Think of a variable like a labeled box where you can store information. You give the box a name (the variable name) and put something inside it (the value). You can change what's in the box or just peek inside to see what it holds anytime.</p>
                        </div>
                    </div>
                </div>
                <div class="p-4 border-t border-border-light dark:border-border-dark space-y-3 flex-shrink-0">
                    <div class="grid grid-cols-2 gap-2 text-sm">
                        <button class="text-center p-2 rounded-lg bg-primary/10 dark:bg-primary/20 text-primary font-medium hover:bg-primary/20 dark:hover:bg-primary/30 transition-colors">Explain Code</button>
                        <button class="text-center p-2 rounded-lg bg-primary/10 dark:bg-primary/20 text-primary font-medium hover:bg-primary/20 dark:hover:bg-primary/30 transition-colors">Hint</button>
                        <button class="text-center p-2 rounded-lg bg-primary/10 dark:bg-primary/20 text-primary font-medium hover:bg-primary/20 dark:hover:bg-primary/30 transition-colors">Show Solution</button>
                    </div>
                    <div class="relative">
                        <input class="w-full h-10 pl-4 pr-10 rounded-lg bg-background-light dark:bg-background-dark border border-border-light dark:border-border-dark focus:ring-2 focus:ring-primary focus:border-transparent transition-shadow text-sm" placeholder="Ask AI Helper..." type="text" />
                        <button class="absolute right-2 top-1/2 -translate-y-1/2 size-7 flex items-center justify-center bg-primary text-white rounded-md hover:bg-primary/90 transition-colors">
                            <span class="material-symbols-outlined !text-lg">send</span>
                        </button>
                    </div>
                </div>
            </div>
        </main>
    </div>

</body>
</html>